# 1. Nhung thu may se tu tao ra khi nhan nut "Run"
.gradle/
build/
app/build/

# 2. Nhung thu chua thong tin ca nhan cua may ban (Gay loi duong dan neu mang sang may khac)
local.properties
.idea/workspace.xml
.idea/libraries/

# 3. File rac he thong (Khong lien quan den code)
*.hprof
.DS_Store
serviceAccountKey.json
accs.txt

# 4. Tap tin du lieu JSON (Tranh commit cac file data lon)
app/src/main/assets/*.json

# 5. Thu muc scratch/prototype (co file JSON >100MB, khong dua len GitHub)
scratch/
src_backup/
mobile_rootie_finalproject/

# 6. Log / debug dump (JVM crash, UI automator)
hs_err_pid*.log
replay_pid*.log
ui.xml
ui2.xml
ui-test.xml

# 7. DB export/backup tu device (chi dung khi debug local)
db-export/
device_db_pull/
device_db_pull2/
rootie-db-*
-HOCKY3NAM3-ROOTIE-db-export-*

# 8. Backup drawable cu
.drawable_lock_backup/
# 9. File zip lon trong app (khong dua len GitHub)
app/*.zip
