<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/quiz_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/btn_continue"
        android:layout_alignParentTop="true"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="56dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/lexend"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:text="Để mang lại kết quả tối ưu nhất, hãy chọn lộ trình phù hợp với nhu cầu của bạn."
                android:textColor="#3E4D44"
                android:textSize="14sp" />

            <!-- Card 1: Quiz cơ bản (Basic) -->
            <RelativeLayout
                android:id="@+id/card_quiz_basic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/quiz_bg_option"
                android:clickable="true"
                android:focusable="true"
                android:padding="20dp">

                <!-- Selection Checkmark Top-Right -->
                <ImageView
                    android:id="@+id/iv_check_basic"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:src="@drawable/ic_circle_checked"
                    android:visibility="gone" />

                <!-- Inside card content (centered layout) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <!-- Light green circle background, contains clipboard icon -->
                    <FrameLayout
                        android:id="@+id/fl_icon_basic_bg"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/com_bg_post"
                        android:backgroundTint="#F0F5EC"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/iv_icon_basic"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_checklist_pen"
                            app:tint="#3E4D44" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Quiz cơ bản"
                        android:textColor="#3E4D44"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="LỰA CHỌN TINH GIẢN"
                        android:textColor="#879578"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:gravity="center"
                        android:text="15 câu hỏi • ~2 phút • Phân tích nhanh"
                        android:textColor="#888888"
                        android:textSize="13sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Card 2: Quiz chuyên sâu (Advanced) - SELECTED BY DEFAULT -->
            <RelativeLayout
                android:id="@+id/card_quiz_advanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/quiz_bg_card_border"
                android:clickable="true"
                android:focusable="true"
                android:padding="20dp">

                <!-- Selection Checkmark Top-Right -->
                <ImageView
                    android:id="@+id/iv_check_advanced"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:src="@drawable/ic_circle_checked"
                    android:visibility="visible" />

                <!-- Inside card content (centered layout) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <!-- Dark green circle background, contains microscope icon -->
                    <FrameLayout
                        android:id="@+id/fl_icon_advanced_bg"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/com_bg_post"
                        android:backgroundTint="#3E4D44"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/iv_icon_advanced"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_advanced" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Quiz chuyên sâu"
                        android:textColor="#3E4D44"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="PHỔ BIẾN NHẤT"
                        android:textColor="#879578"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:gravity="center"
                        android:text="30 câu hỏi • Phân tích chi tiết"
                        android:textColor="#888888"
                        android:textSize="13sp" />
                </LinearLayout>
            </RelativeLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Continue Button (Sticky Bottom) -->
    <FrameLayout
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_btn_buy"
        android:backgroundTint="#677559"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/lexend"
            android:text="Tiếp tục"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Top Header (overlay) -->
    <RelativeLayout
        android:id="@+id/rl_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_gradient_header"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Cấp độ phân tích"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/layoutNotification"
            layout="@layout/include_notification_bell"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp" />
    </RelativeLayout>

</RelativeLayout>
