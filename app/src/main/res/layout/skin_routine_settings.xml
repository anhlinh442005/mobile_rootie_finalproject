<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Top Bar Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/skin_bg_top_bar_gradient"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Cài đặt Routine"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnNotification"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Thông báo"
            android:padding="13dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_notification"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/btnSaveConfig"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Thông báo nhắc nhở -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Thông báo nhắc nhở"
                android:textColor="#3E4D44"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Morning Reminder Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="41dp"
                            android:layout_height="41dp"
                            android:background="@drawable/skin_bg_circle_grey"
                            android:backgroundTint="#E3E5C9"
                            android:padding="10dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_skin_sun"
                                app:tint="#3E4D44" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="Nhắc nhở buổi sáng"
                                android:textColor="#3E4D44"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvMorningTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/lexend"
                                android:text="06 : 30 AM"
                                android:textColor="#8E8E93"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/switchMorningReminderContainer"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switchMorningReminderThumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_switch_thumb" />
                        </FrameLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEFEC"
                        android:layout_marginVertical="12dp" />

                    <!-- Evening Reminder Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="41dp"
                            android:layout_height="41dp"
                            android:background="@drawable/skin_bg_circle_grey"
                            android:backgroundTint="#E3E5C9"
                            android:padding="10dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_moon_outline"
                                app:tint="#3E4D44" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="Nhắc nhở buổi tối"
                                android:textColor="#3E4D44"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvEveningTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/lexend"
                                android:text="09 : 45 PM"
                                android:textColor="#8E8E93"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/switchEveningReminderContainer"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switchEveningReminderThumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_switch_thumb" />
                        </FrameLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEFEC"
                        android:layout_marginVertical="12dp" />

                    <!-- 15 Mins Lead Reminder Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="41dp"
                            android:layout_height="41dp"
                            android:background="@drawable/skin_bg_circle_grey"
                            android:backgroundTint="#E3E5C9"
                            android:padding="10dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_clock"
                                app:tint="@color/primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/lexend"
                            android:text="Nhắc trước 15 phút"
                            android:textColor="#3E4D44"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <FrameLayout
                            android:id="@+id/switchLeadReminderContainer"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switchLeadReminderThumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_switch_thumb" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 2: Gợi ý routine từ AI -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnAiSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#D8E8C6"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <FrameLayout
                        android:id="@+id/ivSparklesContainer"
                        android:layout_width="43dp"
                        android:layout_height="43dp"
                        android:background="@drawable/skin_bg_circle_grey"
                        android:backgroundTint="#EEFAE0"
                        android:padding="10dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_skin_ai_sparkles" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/ivSparklesContainer"
                        android:layout_toStartOf="@id/ivAiArrow"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="Gợi ý Routine từ AI"
                                android:textColor="#3E4D44"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/skin_bg_tab_selected"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="1dp"
                                android:text="MỚI"
                                android:textColor="#DDDFC4"
                                android:textSize="9sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend"
                            android:text="AI Skincare mới của Rootie giúp tối ưu hóa các bước dựa trên tình trạng da của bạn"
                            android:textColor="#8E8E93"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivAiArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_next"
                        app:tint="@color/primary" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 3: Các bước dưỡng da -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Các bước dưỡng da"
                    android:textColor="#3E4D44"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnAddStep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/skin_bg_coin_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="+ Thêm bước"
                    android:textColor="#677559"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Tab Selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/skin_bg_tab_container"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tabMorning"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/skin_bg_tab_selected"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Sáng"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabEvening"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Tối"
                    android:textColor="#3E4D44"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Skincare Steps Dynamic List Container -->
            <LinearLayout
                android:id="@+id/layoutSkincareSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Save configuration Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSaveConfig"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/skin_bg_tab_selected"
        android:fontFamily="@font/lexend"
        android:text="Lưu cấu hình"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
