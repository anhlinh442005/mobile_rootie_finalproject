<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    android:layout_marginHorizontal="2dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EAEAEA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAvatarChar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_circle_green"
                android:backgroundTint="#EDF3ED"
                android:gravity="center"
                android:text="N"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro_bold"/>

            <TextView
                android:id="@+id/tvReviewerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Bảo Nguyên"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:fontFamily="@font/be_vietnam_pro_bold"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <LinearLayout
                android:id="@+id/llStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivStar1"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/star_on"
                    app:tint="#FFC107"/>

                <ImageView
                    android:id="@+id/ivStar2"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/star_on"
                    app:tint="#FFC107"/>

                <ImageView
                    android:id="@+id/ivStar3"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/star_on"
                    app:tint="#FFC107"/>

                <ImageView
                    android:id="@+id/ivStar4"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/star_on"
                    app:tint="#FFC107"/>

                <ImageView
                    android:id="@+id/ivStar5"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/star_on"
                    app:tint="#FFC107"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvReviewComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text='"Chất kem rất mỏng nhẹ, thấm nhanh và không để lại vệt trắng trên da. Rất ưng ý!"'
            android:textColor="@color/content"
            android:textSize="13sp"
            android:fontFamily="@font/lexend"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
