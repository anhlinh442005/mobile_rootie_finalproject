<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Header Icon (Optional) -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_logout_outline"
            app:tint="#E53935"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng xuất khỏi Rootie?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:fontFamily="@font/be_vietnam_pro"
            android:layout_marginBottom="8dp" />

        <!-- Message -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn có chắc chắn muốn đăng xuất không? Để tiếp tục sử dụng các tính năng cá nhân hoá, bạn sẽ cần đăng nhập lại."
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:textAlignment="center"
            android:fontFamily="@font/be_vietnam_pro"
            android:layout_marginBottom="24dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Cancel Button -->
            <TextView
                android:id="@+id/btnCancelLogout"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_rounded_solid"
                android:text="Hủy"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center" />

            <!-- Confirm Button -->
            <TextView
                android:id="@+id/btnConfirmLogout"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_solid_red"
                android:text="Đăng xuất"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
