<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:layout_marginBottom="16dp">

    <!-- Color Dot -->
    <androidx.cardview.widget.CardView
        android:id="@+id/issue_dot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginTop="4dp"
        app:cardCornerRadius="7dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#C82323" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/issue_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mụn"
                android:textColor="@color/content"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/issue_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/skin_bg_badge_grey"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Nhẹ"
                android:textColor="@color/content"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/issue_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Một số nốt mụn viêm ở vùng cằm và má"
            android:textColor="@color/content"
            android:textSize="13sp"
            android:alpha="0.8" />
    </LinearLayout>

</LinearLayout>
