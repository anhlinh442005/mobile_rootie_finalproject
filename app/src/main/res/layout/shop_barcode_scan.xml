<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <LinearLayout
        android:id="@+id/barcode_scan_header"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/barcode_scan_btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back_thin"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="44dp"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:text="Quét mã vạch sản phẩm"
            android:textColor="@color/primary"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/barcode_scan_instruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Đưa mã vạch sản phẩm vào khung hình\nGiữ điện thoại ổn định và đủ ánh sáng"
        android:textColor="@color/content"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barcode_scan_header" />

    <FrameLayout
        android:id="@+id/barcode_scan_preview_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/skin_bg_camera_preview"
        android:clipToOutline="true"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barcode_scan_instruction">

        <androidx.camera.view.PreviewView
            android:id="@+id/barcode_scan_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <View
            android:id="@+id/barcode_scan_frame"
            android:layout_width="260dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/shop_barcode_scan_frame" />
    </FrameLayout>

    <ProgressBar
        android:id="@+id/barcode_scan_loading"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barcode_scan_preview_container" />

    <TextView
        android:id="@+id/barcode_scan_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:gravity="center"
        android:text="Đang tìm sản phẩm..."
        android:textColor="@color/content"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barcode_scan_loading" />

</androidx.constraintlayout.widget.ConstraintLayout>
