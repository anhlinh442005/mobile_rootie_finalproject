<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg_sheet"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/com_bg_post"
            android:backgroundTint="@color/neutral" />

        <TextView
            android:id="@+id/home_login_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/home_login_title"
            android:fontFamily="@font/be_vietnam_pro"
            android:textColor="@color/neutral"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/home_login_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/home_login_subtitle"
            android:textAppearance="@style/TextAppearance.Rootie.Content"
            android:textColor="@color/neutral"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/home_login_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/home_input_email"
               android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/home_bg_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Nhập email hoặc số điện thoại"
                android:importantForAutofill="no"
                android:inputType="textVisiblePassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/primary"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                android:layout_marginTop="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/home_input_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:hint="Mật khẩu"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/home_forgot_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="@string/home_forgot_password"
                android:textColor="@color/neutral"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/home_btn_login"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="@string/home_btn_login"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="@string/home_or_login_with"
                android:textColor="@color/neutral"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/home_login_google"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_google" />

                <ImageView
                    android:id="@+id/home_login_facebook"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_facebook" />

            </LinearLayout>

            <TextView
                android:id="@+id/home_register_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="@color/neutral"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/home_guest_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/home_guest_continue"
                android:textColor="@color/neutral"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
