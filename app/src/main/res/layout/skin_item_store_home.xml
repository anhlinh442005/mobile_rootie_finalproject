<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/skin_bg_store_card"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- Ảnh cửa hàng -->
    <ImageView
        android:id="@+id/skin_store_image"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/imv_logo" />

    <!-- Thông tin cửa hàng -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/skin_store_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Rootie Gò Vấp"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/skin_store_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="27 Quang Trung, P.10, Gò Vấp,\nTp. Hồ Chí Minh"
            android:textColor="@color/content"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/skin_store_hours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="10:00 AM - 20:00PM"
            android:textColor="@color/primary"
            android:textSize="12sp" />

        <!-- Nút Đặt lịch -->
        <TextView
            android:id="@+id/skin_store_btn_book"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_gravity="end"
            android:background="@drawable/skin_bg_btn_book"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="Đặt lịch"
            android:textColor="@color/neutral"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
