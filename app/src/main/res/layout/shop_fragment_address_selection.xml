<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_header_gradient"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back_thin"
            app:tint="@color/primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn địa chỉ"
            android:textColor="@color/primary"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Address Steps Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clStepsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toBottomOf="@id/clToolbar">

        <!-- Line connecting Step 1 and Step 2 -->
        <View
            android:id="@+id/viewConnectingLine"
            android:layout_width="2dp"
            android:layout_height="32dp"
            android:background="#807F7F"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/guidelineDots"
            app:layout_constraintEnd_toEndOf="@id/guidelineDots"
            app:layout_constraintTop_toBottomOf="@id/clStep1"
            app:layout_constraintBottom_toTopOf="@id/clStep2" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="22dp" />

        <!-- Step 1: Province Selection -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clStep1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/viewStep1Dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_circle_grey"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvStep1Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:text="Chọn Tỉnh/Thành phố"
                android:textColor="@color/primary"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvStep1Change"
                app:layout_constraintStart_toEndOf="@id/viewStep1Dot"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvStep1Change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thay đổi"
                android:textColor="#8B8682"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textSize="13sp"
                android:visibility="gone"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Step 2: District Selection (initially gone) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clStep2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/clStep1">

            <View
                android:id="@+id/viewStep2Dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_circle_green"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvStep2Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Chọn Quận/Huyện"
                android:textColor="@color/primary"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/viewStep2Dot"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Search Input Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clSearchBar"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_btn_outlined"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/clStepsContainer">

        <ImageView
            android:id="@+id/ivSearchIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            app:tint="@color/gray_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:hint="Nhập tìm Tỉnh/Thành phố"
            android:textColor="@color/primary"
            android:textColorHint="@color/gray_dark"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:inputType="text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnClearSearch"
            app:layout_constraintStart_toEndOf="@id/ivSearchIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnClearSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_close"
            android:visibility="gone"
            app:tint="@color/gray_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Address Items RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAddressItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clSearchBar" />

</androidx.constraintlayout.widget.ConstraintLayout>
