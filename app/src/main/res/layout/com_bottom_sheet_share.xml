<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/com_bg_bottom_sheet_green"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#DEDEDE"
        android:layout_marginBottom="24dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/llRepost"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_reup"
                    android:padding="12dp"
                    android:background="@drawable/com_bg_circle_gray" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Đăng lại"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llCopy"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_copy"
                    android:padding="12dp"
                    android:background="@drawable/com_bg_circle_gray" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Sao chép\nliên kết"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llReport"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_warning_outline"
                    android:padding="12dp"
                    android:background="@drawable/com_bg_circle_gray" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Báo cáo"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llSave"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_dowload"
                    android:padding="12dp"
                    android:background="@drawable/com_bg_circle_gray" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Lưu video"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llNotInterested"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_break_heart"
                    android:padding="12dp"
                    android:background="@drawable/com_bg_circle_gray" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Không\nquan tâm"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
