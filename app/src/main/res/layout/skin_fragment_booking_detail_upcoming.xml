<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/skin_detail_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/skin_detail_btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/primary"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiết lịch hẹn"
            android:textAlignment="center"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro"
            android:layout_marginEnd="32dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/skin_detail_header"
        app:layout_constraintBottom_toTopOf="@id/skin_detail_bottom_actions"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Top Summary -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_btn_solid_dark"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/skin_detail_service_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Soi da cơ bản"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/skin_detail_store_image_card"/>

                <TextView
                    android:id="@+id/skin_detail_status_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sắp diễn ra"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:background="@drawable/skin_bg_btn_book"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/skin_detail_service_name"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/skin_detail_order_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã đặt lịch: RS202605200001"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/skin_detail_status_tag"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ImageView
                    android:id="@+id/skin_detail_btn_copy"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clipboard_outline"
                    app:tint="@color/white"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/skin_detail_order_id"
                    app:layout_constraintTop_toTopOf="@id/skin_detail_order_id"
                    app:layout_constraintBottom_toBottomOf="@id/skin_detail_order_id"/>

                <View
                    android:id="@+id/skin_detail_divider"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="#88FFFFFF"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintTop_toBottomOf="@id/skin_detail_order_id"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/skin_detail_store_image_card"/>

                <ImageView
                    android:id="@+id/skin_detail_ic_date"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar_outline"
                    app:tint="@color/white"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/skin_detail_divider"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/skin_detail_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 tháng 5, 2024\nThứ 2"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginStart="8dp"
                    app:layout_constraintTop_toTopOf="@id/skin_detail_ic_date"
                    app:layout_constraintStart_toEndOf="@id/skin_detail_ic_date"/>

                <ImageView
                    android:id="@+id/skin_detail_ic_time"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/white"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/skin_detail_date"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/skin_detail_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:00 - 10:45 (45 phút)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:layout_marginStart="8dp"
                    app:layout_constraintTop_toTopOf="@id/skin_detail_ic_time"
                    app:layout_constraintBottom_toBottomOf="@id/skin_detail_ic_time"
                    app:layout_constraintStart_toEndOf="@id/skin_detail_ic_time"/>

                <!-- Circular Image on Right -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/skin_detail_store_image_card"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="-20dp">
                    <ImageView
                        android:id="@+id/skin_detail_store_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/imv_logo"/>
                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Card 2: Store Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_store_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/primary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi nhánh đã chọn"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/skin_detail_store_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rootie Gò Vấp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"/>

                <TextView
                    android:id="@+id/skin_detail_store_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="27 Quang Trung, P.10, Gò Vấp, Tp. HCM"
                    android:textColor="@color/content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="24dp"/>

                <TextView
                    android:id="@+id/skin_detail_store_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(027) 7100 2020"
                    android:textColor="@color/content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="24dp"/>
            </LinearLayout>

            <!-- Card 3: User Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_store_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_user_outline"
                        app:tint="@color/primary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin cá nhân"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/skin_detail_user_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nguyễn Khánh Xuân"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"/>

                <TextView
                    android:id="@+id/skin_detail_user_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(+84) 38 725 3686"
                    android:textColor="@color/content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="24dp"/>

                <TextView
                    android:id="@+id/skin_detail_user_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="xuannk23411@st.uel.edu.vn"
                    android:textColor="@color/content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="24dp"/>
            </LinearLayout>

            <!-- Card 4: Note Info -->
            <LinearLayout
                android:id="@+id/skin_detail_note_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_store_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/primary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ghi chú"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/skin_detail_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ưu tiên về kiểm tra tình trạng mụn ẩn, lỗ chân lông to và da không đều màu."
                    android:textColor="@color/content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"/>
            </LinearLayout>

            <!-- Card 5: Policy Info -->
            <LinearLayout
                android:id="@+id/skin_detail_policy_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_store_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_article_outline"
                        app:tint="@color/primary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chính sách huỷ lịch"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/skin_detail_policy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bạn có thể huỷ lịch hẹn ít nhất trong 2h.\nNếu muộn hơn, Rootie có quyền từ chối nhận lịch trong tương lai."
                    android:textColor="@color/content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/skin_detail_bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@color/neutral">

        <TextView
            android:id="@+id/skin_detail_btn_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/skin_bg_btn_solid_dark"
            android:text="Xem chi tiết"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textAlignment="center"
            android:fontFamily="@font/be_vietnam_pro"
            android:padding="14dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/skin_detail_btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/skin_bg_btn_outline_dark"
            android:text="Huỷ lịch"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textAlignment="center"
            android:fontFamily="@font/be_vietnam_pro"
            android:padding="14dp"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
