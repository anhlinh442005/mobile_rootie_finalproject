<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/neutral">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cắt ảnh đại diện"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/lexend"
            android:layout_marginBottom="6dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kéo để di chuyển, dùng thanh trượt để phóng to"
            android:textColor="@color/gray_dark"
            android:textSize="13sp"
            android:fontFamily="@font/lexend"
            android:layout_marginBottom="16dp" />

        <!-- Image Container Frame -->
        <FrameLayout
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:background="#FFFFFF"
            android:clipChildren="true"
            android:clipToPadding="true">

            <!-- The source ImageView to be cropped -->
            <ImageView
                android:id="@+id/iv_crop_source"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="matrix" />

            <!-- The transparent circle cutout overlay -->
            <com.veganbeauty.app.utils.CircleCropOverlayView
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- Zoom label & seekbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thu nhỏ"
                android:textColor="@color/gray_dark"
                android:textSize="12sp"
                android:fontFamily="@font/lexend" />

            <SeekBar
                android:id="@+id/sb_zoom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phóng to"
                android:textColor="@color/gray_dark"
                android:textSize="12sp"
                android:fontFamily="@font/lexend" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_crop_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Hủy"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:background="@drawable/bg_dialog_btn_cancel" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_crop_confirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Cắt và Lưu"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:background="@drawable/bg_dialog_btn_confirm" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
