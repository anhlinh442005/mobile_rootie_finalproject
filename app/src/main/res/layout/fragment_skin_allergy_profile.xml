<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/skin_allergy_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_alignParentTop="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="56dp"
        android:paddingBottom="@dimen/home_nav_bar_height"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp"
            android:clipToPadding="false"
            android:clipChildren="false">

            <!-- Section: Skin Type Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="15dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_checklist"
                            app:tint="#3E4D44" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="LOẠI DA CỦA BẠN"
                            android:textColor="#3E4D44"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_skin_type_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Da dầu nhạy cảm"
                        android:textColor="#3E4D44"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tv_skin_type_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Làn da của bạn có xu hướng tiết nhiều dầu ở vùng chữ T nhưng dễ dàng bị kích ứng, đỏ rát bởi các tác nhân môi trường hoặc mỹ phẩm mạnh."
                        android:textColor="#3E4D44"
                        android:textSize="15sp"
                        android:lineSpacingMultiplier="1.25"
                        android:layout_marginBottom="16dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EAECE3"
                        android:layout_marginVertical="12dp" />

                    <!-- Detailed Skin Metrics Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Chỉ số làn da chi tiết"
                        android:textColor="#3E4D44"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Sensitivity Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Độ nhạy cảm"
                            android:textColor="#555555"
                            android:textSize="15sp" />
                        <ProgressBar
                            android:id="@+id/pb_sensitivity"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:progress="80"
                            android:progressDrawable="@drawable/progress_sensitivity" />
                        <TextView
                            android:id="@+id/tv_sensitivity_val"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="80%"
                            android:textColor="#3E4D44"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Hydration Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Độ ẩm"
                            android:textColor="#555555"
                            android:textSize="15sp" />
                        <ProgressBar
                            android:id="@+id/pb_hydration"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:progress="60"
                            android:progressDrawable="@drawable/progress_hydration" />
                        <TextView
                            android:id="@+id/tv_hydration_val"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="60%"
                            android:textColor="#3E4D44"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Elasticity Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Độ đàn hồi"
                            android:textColor="#555555"
                            android:textSize="15sp" />
                        <ProgressBar
                            android:id="@+id/pb_elasticity"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:progress="75"
                            android:progressDrawable="@drawable/progress_elasticity" />
                        <TextView
                            android:id="@+id/tv_elasticity_val"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="75%"
                            android:textColor="#3E4D44"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Sebum Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Độ dầu"
                            android:textColor="#555555"
                            android:textSize="15sp" />
                        <ProgressBar
                            android:id="@+id/pb_sebum"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:progress="85"
                            android:progressDrawable="@drawable/progress_oily" />
                        <TextView
                            android:id="@+id/tv_sebum_val"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="85%"
                            android:textColor="#3E4D44"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EAECE3"
                        android:layout_marginBottom="12dp" />

                    <!-- Skin Area Distribution details -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Hiện trạng phân bổ vùng da"
                        android:textColor="#3E4D44"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_skin_areas_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Vùng chữ T nhiều dầu nhờn, bóng loáng, vùng chữ U khô nhẹ nhạy cảm dễ ửng đỏ rát."
                        android:textColor="#3E4D44"
                        android:textSize="15sp"
                        android:lineSpacingMultiplier="1.2"
                        android:layout_marginBottom="16dp" />

                    <!-- Accuracy Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/com_bg_post"
                        android:backgroundTint="#EAECE3">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_badge_check" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="Độ chính xác 98%"
                            android:textColor="#677559"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Ingredients Analysis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_chemistry_flask"
                    app:tint="#3E4D44" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Phân tích thành phần"
                    android:textColor="#3E4D44"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- AVOID GROUP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/com_bg_post"
                        android:backgroundTint="#C00707" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="NÊN TRÁNH"
                        android:textColor="#3E4D44"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.veganbeauty.app.core.view.FlowLayout
                    android:id="@+id/ll_avoid_pills_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp" />

            </LinearLayout>

            <!-- CAUTION GROUP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/com_bg_post"
                        android:backgroundTint="#677559" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="CẨN TRỌNG"
                        android:textColor="#3E4D44"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.veganbeauty.app.core.view.FlowLayout
                    android:id="@+id/ll_caution_pills_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp" />

            </LinearLayout>

            <!-- SUITABLE GROUP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/com_bg_post"
                        android:backgroundTint="#E4F5E8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="PHÙ HỢP"
                        android:textColor="#3E4D44"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.veganbeauty.app.core.view.FlowLayout
                    android:id="@+id/ll_suitable_pills_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp" />

            </LinearLayout>

            <!-- Section: Skin Comparison — grid 2x2, không khung ngoài -->
            <LinearLayout
                android:id="@+id/skin_comparison_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/lexend"
                    android:text="So sánh &amp; Đánh giá hiệu quả"
                    android:textColor="#3E4D44"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/lexend"
                    android:text="Chỉ số da (Cũ → Mới)"
                    android:textColor="#7E8A83"
                    android:textSize="14sp" />

                <!-- Hàng 1: Độ ẩm | Độ dầu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- Độ ẩm da -->
                    <LinearLayout
                        android:id="@+id/skin_compare_hydration_cell"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_expert_reason_card"
                        android:backgroundTint="#F7F9FA"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/lexend"
                            android:maxLines="1"
                            android:text="Độ ẩm da"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/skin_compare_hydration_old"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#7E8A83"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="4dp"
                                android:text="→"
                                android:textColor="#7E8A83"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/skin_compare_hydration_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#3E4D44"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/skin_compare_hydration_diff"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend"
                            android:maxLines="2"
                            android:text="0% (Duy trì)"
                            android:textColor="#677559"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Độ dầu -->
                    <LinearLayout
                        android:id="@+id/skin_compare_sebum_cell"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_expert_reason_card"
                        android:backgroundTint="#F7F9FA"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/lexend"
                            android:maxLines="1"
                            android:text="Độ dầu"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/skin_compare_sebum_old"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#7E8A83"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="4dp"
                                android:text="→"
                                android:textColor="#7E8A83"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/skin_compare_sebum_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#3E4D44"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/skin_compare_sebum_diff"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend"
                            android:maxLines="2"
                            android:text="0% (Duy trì)"
                            android:textColor="#677559"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Hàng 2: Nhạy cảm | Đàn hồi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- Độ nhạy cảm -->
                    <LinearLayout
                        android:id="@+id/skin_compare_sensitivity_cell"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_expert_reason_card"
                        android:backgroundTint="#F7F9FA"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/lexend"
                            android:maxLines="1"
                            android:text="Độ nhạy cảm"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/skin_compare_sensitivity_old"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#7E8A83"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="4dp"
                                android:text="→"
                                android:textColor="#7E8A83"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/skin_compare_sensitivity_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#3E4D44"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/skin_compare_sensitivity_diff"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend"
                            android:maxLines="2"
                            android:text="0% (Duy trì)"
                            android:textColor="#677559"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Độ đàn hồi -->
                    <LinearLayout
                        android:id="@+id/skin_compare_elasticity_cell"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_expert_reason_card"
                        android:backgroundTint="#F7F9FA"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/lexend"
                            android:maxLines="1"
                            android:text="Độ đàn hồi"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/skin_compare_elasticity_old"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#7E8A83"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="4dp"
                                android:text="→"
                                android:textColor="#7E8A83"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/skin_compare_elasticity_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend"
                                android:text="50%"
                                android:textColor="#3E4D44"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/skin_compare_elasticity_diff"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend"
                            android:maxLines="2"
                            android:text="0% (Duy trì)"
                            android:textColor="#677559"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Phân tích hiệu quả sản phẩm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_expert_reason_card"
                    android:backgroundTint="#F2FBF6"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/lexend"
                        android:text="Phân tích hiệu quả sản phẩm đang dùng"
                        android:textColor="#02542D"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/skin_tv_product_efficacy_analysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:lineSpacingMultiplier="1.4"
                        android:text="Chưa có đủ dữ liệu lịch sử để phân tích hiệu quả sản phẩm."
                        android:textColor="#3E4D44"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Products in Use -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:text="Sản phẩm đang sử dụng"
                android:textColor="#3E4D44"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/ll_products_in_use_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="0dp" />

            <!-- Section: AI Recommendations -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#3E4D44"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_ai_outline"
                            app:tint="#EAECE3" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Lời khuyên từ Rootie AI"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_recommendation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Với nền da dầu nhạy cảm, ưu tiên hàng đầu của bạn là làm sạch nhẹ nhàng và phục hồi hàng rào bảo vệ da. Tránh các loại sữa rửa mặt tạo bọt quá mạnh hoặc chứa sulfate. Hãy bổ sung tinh chất Rau má để làm dịu các vùng da đỏ và duy trì độ ẩm bằng các loại gel dưỡng mỏng nhẹ không gây bít tắc lỗ chân lông."
                        android:textColor="#F7F9FA"
                        android:textSize="15sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Navigation Actions Section (Buttons for navigating elsewhere) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <!-- Button 1: Xem Báo cáo làn da cá nhân -->
                <FrameLayout
                    android:id="@+id/btn_view_skin_report"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_btn_buy"
                    android:backgroundTint="#677559"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/lexend"
                        android:text="Xem Báo cáo làn da cá nhân"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Button 2: Thiết lập Routine & Nhắc hẹn -->
                <FrameLayout
                    android:id="@+id/btn_setup_routine"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_btn_buy"
                    android:backgroundTint="#DDDFC4"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/lexend"
                        android:text="Thiết lập Routine &amp; Nhắc hẹn"
                        android:textColor="#677559"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Button: QUAY LẠI LÀM QUIZ -->
                <FrameLayout
                    android:id="@+id/btn_retake_quiz"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_btn_buy"
                    android:backgroundTint="#F2F3EB"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/lexend"
                        android:text="QUAY LẠI LÀM QUIZ"
                        android:textColor="#3E4D44"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp" />

    <!-- Top Header (overlay) -->
    <RelativeLayout
        android:id="@+id/rl_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_gradient_header"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="56dp"
            android:ellipsize="end"
            android:fontFamily="@font/be_vietnam_pro"
            android:maxLines="1"
            android:text="Hồ sơ da &amp; Dị ứng"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/layoutNotification"
            layout="@layout/include_notification_bell"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp" />
    </RelativeLayout>

</RelativeLayout>
