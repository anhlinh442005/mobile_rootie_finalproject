<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <View
        android:id="@+id/viewDismiss"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/llInputContainer" />

    <LinearLayout
        android:id="@+id/llInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/white">

        <LinearLayout
            android:id="@+id/llQuickEmojis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView android:id="@+id/tvEmoji1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="❤️" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/tvEmoji2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="👌" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/tvEmoji3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="😍" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/tvEmoji4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🙌" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/tvEmoji5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔥" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/tvEmoji6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="✨" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/tvEmoji7" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="😯" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/tvEmoji8" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="😂" android:textSize="24sp" android:gravity="center" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardMaxElevation="0dp">
                <ImageView
                    android:id="@+id/ivMyAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_avatar" />
            </androidx.cardview.widget.CardView>

            <EditText
                android:id="@+id/etComment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@drawable/com_bg_post_edit_text"
                android:hint="Bạn nghĩ gì về nội dung này?"
                android:textColorHint="#999999"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:inputType="textMultiLine"
                android:maxLines="4" />

            <ImageView
                android:id="@+id/ivSubmitComment"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/com_bg_circle_green"
                android:src="@drawable/ic_plane"
                android:padding="8dp"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
