<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFBF4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="72dp">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/ivClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:src="@drawable/com_ic_close_thin"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Đóng"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tạo bài viết"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/btnPost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng"
                android:textColor="@color/content"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- User Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">
                    
                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivUserAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img_avatar"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ánh Linh"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                            <LinearLayout
                                android:id="@+id/llPrivacy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="2dp"
                                android:background="@drawable/com_bg_chip_solid_normal"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tvPrivacy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Công khai"
                                android:textColor="@color/content"
                                android:textSize="12sp"/>
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_arrow_down"
                                app:tint="@color/content"
                                android:layout_marginStart="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Topics -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/com_bg_post_options_container"
                    android:padding="12dp"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn chủ đề bài đăng"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/llTopicsContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Routine" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Review" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reels" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kiến thức" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hỏi đáp" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cuộc sống" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvAddTopic" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <!-- Skin Issues -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/com_bg_post_options_container"
                    android:padding="12dp"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vấn đề về da"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/llSkinIssuesContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Da dầu" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mụn" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Da khô" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thâm mụn" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dị ứng" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvAddSkinIssue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="@color/content" android:background="@drawable/com_bg_chip_solid_normal" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:textSize="12sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <!-- Input Area -->
                <EditText
                    android:id="@+id/etContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="150dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/com_bg_post_edit_text"
                    android:hint="Chia sẻ nội dung chăm da với cộng đồng Rootie..."
                    android:textColorHint="@color/content"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:gravity="top|start"
                    android:padding="16dp"
                    android:inputType="textMultiLine"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="12dp">
                    <LinearLayout
                        android:id="@+id/llImagePreviewContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"/>
                </HorizontalScrollView>

                <!-- Attached Products Preview -->
                <LinearLayout
                    android:id="@+id/llAttachedProductsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sản phẩm đã dùng"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="16dp"/>
                        
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:paddingHorizontal="16dp"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/llAttachedProductsList"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"/>
                    </HorizontalScrollView>
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Bottom Menu -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="72dp"
        app:behavior_hideable="false"
        android:background="@drawable/com_bg_bottom_sheet_rounded"
        android:elevation="8dp">

        <View
            android:id="@+id/vHandle"
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/com_bg_filter_normal"/>

        <!-- Horizontal state -->
        <LinearLayout
            android:id="@+id/llHorizontalIcons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp"
            android:weightSum="7"
            android:visibility="visible">
            
            <ImageView android:id="@+id/ivAddMediaHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="28dp" android:src="@drawable/ic_camera" app:tint="@color/primary"/>
            <ImageView android:layout_width="0dp" android:layout_weight="1" android:layout_height="28dp" android:src="@drawable/ic_account_outline" app:tint="@color/primary"/>
            <ImageView android:layout_width="0dp" android:layout_weight="1" android:layout_height="28dp" android:src="@drawable/ic_account_location" app:tint="@color/primary"/>
            <ImageView android:id="@+id/ivAddProductHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="28dp" android:src="@drawable/ic_bag" app:tint="@color/primary"/>
            <ImageView android:layout_width="0dp" android:layout_weight="1" android:layout_height="28dp" android:src="@drawable/ic_circle_plus_outline" app:tint="@color/primary"/>
            <ImageView android:layout_width="0dp" android:layout_weight="1" android:layout_height="28dp" android:src="@drawable/ic_calendar" app:tint="@color/primary"/>
            <ImageView android:layout_width="0dp" android:layout_weight="1" android:layout_height="28dp" android:src="@drawable/ic_face" app:tint="@color/primary"/>
        </LinearLayout>

        <!-- Vertical state -->
        <LinearLayout
            android:id="@+id/llVerticalList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp"
            android:visibility="gone">
            
            <LinearLayout android:id="@+id/llAddMedia" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_camera" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ảnh/Video" android:textColor="@color/primary" android:textSize="15sp" android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_circle_plus_outline" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nhạc" android:textColor="@color/primary" android:textSize="15sp" android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_account_outline" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gắn thẻ" android:textColor="@color/primary" android:textSize="15sp" android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/llAddProduct" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_bag" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gắn giỏ hàng sản phẩm" android:textColor="@color/primary" android:textSize="15sp" android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_account_location" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Check-in" android:textColor="@color/primary" android:textSize="15sp" android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gắn thẻ sự kiện" android:textColor="@color/primary" android:textSize="15sp" android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_face" app:tint="@color/primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cảm xúc" android:textColor="@color/primary" android:textSize="15sp" android:layout_marginStart="16dp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
    
    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/flLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary"/>
    </FrameLayout>
</FrameLayout>
