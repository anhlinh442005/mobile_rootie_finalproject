<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg_sheet"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/home_sheet_handle"
            android:backgroundTint="@color/neutral" />

        <!-- ===== BƯỚC 1: Nhập email ===== -->
        <LinearLayout
            android:id="@+id/fp_step1_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Quên mật khẩu?"
                android:textColor="@color/neutral"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Nhập email đã đăng ký, chúng tôi sẽ gửi mã OTP để xác minh"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:alpha="0.8" />

            <EditText
                android:id="@+id/fp_input_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/home_bg_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Địa chỉ email"
                android:importantForAutofill="no"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/primary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fp_btn_send_otp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Gửi mã OTP"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/fp_back_to_login_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Quay lại đăng nhập"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:alpha="0.8"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ===== BƯỚC 2: Nhập OTP ===== -->
        <LinearLayout
            android:id="@+id/fp_step2_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Kiểm tra hộp thư"
                android:textColor="@color/neutral"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/fp_otp_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mã OTP đã được gửi đến email của bạn. Mã có hiệu lực trong 5 phút."
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:alpha="0.8" />

            <!-- 6 ô OTP -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/fp_otp_1"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/home_bg_input"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/fp_otp_2"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/home_bg_input"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/fp_otp_3"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/home_bg_input"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/fp_otp_4"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/home_bg_input"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/fp_otp_5"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/home_bg_input"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/fp_otp_6"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/home_bg_input"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Countdown -->
            <TextView
                android:id="@+id/fp_otp_countdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Gửi lại mã sau 05:00"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:alpha="0.7"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fp_btn_verify_otp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Xác minh OTP"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/fp_back_to_login_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Quay lại đăng nhập"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:alpha="0.8"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ===== BƯỚC 3: Đặt mật khẩu mới ===== -->
        <LinearLayout
            android:id="@+id/fp_step3_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Đặt mật khẩu mới"
                android:textColor="@color/neutral"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mật khẩu mới phải có ít nhất 6 ký tự"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:alpha="0.8" />

            <!-- Mật khẩu mới -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/fp_input_new_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:hint="Mật khẩu mới"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Xác nhận mật khẩu -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:hintEnabled="false"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/fp_input_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:hint="Nhập lại mật khẩu mới"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fp_btn_reset_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Cập nhật mật khẩu"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

        </LinearLayout>

        <!-- ===== BƯỚC 4: Thành công ===== -->
        <LinearLayout
            android:id="@+id/fp_step4_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingVertical="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:text="✅"
                android:textSize="48sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Đổi mật khẩu thành công!"
                android:textColor="@color/neutral"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp"
                android:gravity="center"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Bạn có thể đăng nhập bằng mật khẩu mới ngay bây giờ"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:alpha="0.8" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fp_btn_go_login"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Đăng nhập ngay"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
