<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_forgot_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg_auth_sheet"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

        <LinearLayout
            android:id="@+id/home_forgot_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="28dp">

            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:alpha="0.75"
                android:background="@drawable/home_sheet_handle" />

            <!-- ===== BƯỚC 0: Chọn phương thức ===== -->
            <LinearLayout
                android:id="@+id/fp_step0_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Quên mật khẩu?"
                    android:textColor="@color/home_auth_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="28dp"
                    android:alpha="0.9"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Chọn phương thức để lấy lại mật khẩu"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fp_btn_choose_email"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/home_auth_button"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Khôi phục qua Email"
                    android:textColor="@color/home_auth_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fp_btn_choose_phone"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/neutral"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Khôi phục qua Số điện thoại"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/fp_back_to_login_0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:alpha="0.85"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Quay lại đăng nhập"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/home_forgot_mascot"
                    android:layout_width="208dp"
                    android:layout_height="208dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:adjustViewBounds="true"
                    android:alpha="0.92"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mascot_hello" />
            </LinearLayout>

            <!-- ===== BƯỚC 1: Nhập email/phone ===== -->
            <LinearLayout
                android:id="@+id/fp_step1_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Quên mật khẩu?"
                    android:textColor="@color/home_auth_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/fp_step1_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp"
                    android:alpha="0.9"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Nhập địa chỉ, chúng tôi sẽ gửi mã OTP để xác minh"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/fp_input_email"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/home_bg_auth_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Địa chỉ email / số điện thoại"
                    android:importantForAutofill="no"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/tertiary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fp_btn_send_otp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/home_auth_button"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Gửi mã OTP"
                    android:textColor="@color/home_auth_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <TextView
                    android:id="@+id/fp_back_to_login_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:alpha="0.85"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Quay lại đăng nhập"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- ===== BƯỚC 2: Nhập OTP ===== -->
            <LinearLayout
                android:id="@+id/fp_step2_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Kiểm tra hộp thư"
                    android:textColor="@color/home_auth_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/fp_otp_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp"
                    android:alpha="0.9"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Mã OTP đã được gửi đến email của bạn. Mã có hiệu lực trong 5 phút."
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/fp_otp_1"
                        android:layout_width="44dp"
                        android:layout_height="52dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/fp_otp_2"
                        android:layout_width="44dp"
                        android:layout_height="52dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/fp_otp_3"
                        android:layout_width="44dp"
                        android:layout_height="52dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/fp_otp_4"
                        android:layout_width="44dp"
                        android:layout_height="52dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/fp_otp_5"
                        android:layout_width="44dp"
                        android:layout_height="52dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/fp_otp_6"
                        android:layout_width="44dp"
                        android:layout_height="52dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/fp_otp_countdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.8"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Gửi lại mã sau 05:00"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fp_btn_verify_otp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/home_auth_button"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Xác minh OTP"
                    android:textColor="@color/home_auth_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <TextView
                    android:id="@+id/fp_back_to_login_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:alpha="0.85"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Quay lại đăng nhập"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- ===== BƯỚC 3: Đặt mật khẩu mới ===== -->
            <LinearLayout
                android:id="@+id/fp_step3_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Đặt mật khẩu mới"
                    android:textColor="@color/home_auth_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp"
                    android:alpha="0.9"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Mật khẩu mới phải có ít nhất 6 ký tự"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="none"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/gray_dark"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/fp_input_new_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:hint="Mật khẩu mới"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/primary"
                        android:textColorHint="@color/tertiary"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/gray_dark"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/fp_input_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/home_bg_auth_input"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:hint="Nhập lại mật khẩu mới"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/primary"
                        android:textColorHint="@color/tertiary"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fp_btn_reset_password"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@color/home_auth_button"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Cập nhật mật khẩu"
                    android:textColor="@color/home_auth_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

            </LinearLayout>

            <!-- ===== BƯỚC 4: Thành công ===== -->
            <LinearLayout
                android:id="@+id/fp_step4_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Đổi mật khẩu thành công!"
                    android:textColor="@color/home_auth_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="28dp"
                    android:alpha="0.9"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Bạn có thể đăng nhập bằng mật khẩu mới ngay bây giờ"
                    android:textColor="@color/home_auth_text_soft"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fp_btn_go_login"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/home_auth_button"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Đăng nhập ngay"
                    android:textColor="@color/home_auth_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
