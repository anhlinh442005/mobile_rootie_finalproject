<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/gray_dark"
            android:padding="12dp"
            android:layout_marginStart="-12dp" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp">

            <ImageView
                android:id="@+id/ivPartnerAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@color/gray_light" />

            <View
                android:id="@+id/vActiveDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="0dp"
                android:layout_marginEnd="0dp"
                android:background="@drawable/bg_circle_green"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/tvPartnerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:fontFamily="@font/be_vietnam_pro" />

                <ImageView
                    android:id="@+id/ivVerified"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    app:tint="#0095F6"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_arrow_next"
                    app:tint="@color/gray_dark" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang hoạt động"
                android:textSize="12sp"
                android:textColor="@color/gray_dark"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_phone"
            android:scaleType="fitCenter"
            app:tint="@color/basic_green"
            android:layout_marginEnd="16dp" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_video_call"
            app:tint="@color/basic_green"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintBottom_toTopOf="@+id/llInput" />

    <!-- Input Bar: Plus | Camera | Gallery | Mic | Input | Like -->
    <LinearLayout
        android:id="@+id/llInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/white"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/llInputActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivPlus"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_circle_plus"
                app:tint="@color/basic_green" />

            <ImageView
                android:id="@+id/ivCamera"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_camera"
                app:tint="@color/basic_green" />

            <ImageView
                android:id="@+id/ivGallery"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_gallery"
                app:tint="@color/basic_green" />

            <ImageView
                android:id="@+id/ivMic"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_micro"
                app:tint="@color/basic_green" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llMessageInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:background="@drawable/com_bg_chat_input"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Nhập tin nhắn..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_dark"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivLike"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="14dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_like"
            app:tint="@color/basic_green" />

        <!-- Send Button (Hidden by default) -->
        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_plane"
            android:visibility="gone"
            app:tint="@color/basic_green" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
