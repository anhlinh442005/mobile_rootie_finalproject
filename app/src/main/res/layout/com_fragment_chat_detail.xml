<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_back_thin"
            app:tint="@color/gray_dark"
            android:padding="2dp" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@color/gray_light" />

            <View
                android:id="@+id/vActiveDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="0dp"
                android:layout_marginEnd="0dp"
                android:background="@drawable/bg_circle_green"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:fontFamily="@font/be_vietnam_pro" />

                <ImageView
                    android:id="@+id/ivVerified"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    app:tint="#0095F6"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_chat_chevron_right"
                    app:tint="@color/gray_dark" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang hoạt động"
                android:textSize="12sp"
                android:textColor="@color/gray_dark"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chat_phone"
            app:tint="@color/gray_dark"
            android:layout_marginEnd="16dp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chat_video"
            app:tint="@color/gray_dark" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintBottom_toTopOf="@+id/llInput" />

    <!-- Input Bar -->
    <LinearLayout
        android:id="@+id/llInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Camera Button -->
        <ImageView
            android:id="@+id/ivCamera"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_green"
            android:backgroundTint="#758864"
            android:src="@drawable/ic_chat_camera"
            app:tint="@color/white"
            android:padding="6dp"
            android:layout_marginEnd="12dp" />

        <!-- Input Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/com_bg_chat_input"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Nhập tin nhắn..."
                android:textColorHint="@color/gray_dark"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>

        <!-- Right Icons Group -->
        <LinearLayout
            android:id="@+id/llRightIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp">

            <ImageView
                android:id="@+id/ivMic"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat_mic"
                app:tint="#758864"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/ivGallery"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat_gallery"
                app:tint="#758864"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/ivPlus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat_plus_circle"
                app:tint="#758864" />
        </LinearLayout>

        <!-- Send Button (Hidden by default) -->
        <ImageView
            android:id="@+id/ivSend"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_plane"
            app:tint="#758864"
            android:layout_marginStart="12dp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
