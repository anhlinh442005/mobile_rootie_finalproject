<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_service"
    android:layout_width="match_parent"
    android:layout_height="172dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/neutral"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="false">

    <FrameLayout
        android:id="@+id/container_service"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/skin_bg_booking_service_green"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iv_service_check"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:src="@drawable/ic_circle_checked"
            android:visibility="gone"
            app:tint="@color/status_level_green" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/icon_service_wrap"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/skin_bg_booking_service_icon_green">

                <ImageView
                    android:id="@+id/iv_service_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_skin_sparkle"
                    app:tint="@color/status_level_green" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_service_name"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="top"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:minLines="2"
                android:text="Soi da cơ bản"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/tertiary" />

                <TextView
                    android:id="@+id/tv_service_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="30 phút"
                    android:textColor="@color/tertiary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_service_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="@font/be_vietnam_pro"
                android:maxLines="1"
                android:text="Miễn phí"
                android:textColor="@color/secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>
