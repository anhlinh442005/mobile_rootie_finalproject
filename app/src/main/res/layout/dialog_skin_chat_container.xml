<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Horizontal Chat Bubbles (Tabs) at the top -->
    <LinearLayout
        android:id="@+id/layoutChatTabs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="4dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp">

        <!-- AI Tab Bubble -->
        <FrameLayout
            android:id="@+id/tab_bubble_ai"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_tab_ai"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@drawable/mascot_chat"
                    android:padding="5dp" />
            </androidx.cardview.widget.CardView>

            <!-- Unread badge for AI -->
            <View
                android:id="@+id/tab_badge_ai"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/badge_dot"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Human/Expert Tab Bubble -->
        <FrameLayout
            android:id="@+id/tab_bubble_human"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_tab_human"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@drawable/logo"
                    android:padding="6dp" />
            </androidx.cardview.widget.CardView>

            <!-- Unread badge for Human -->
            <View
                android:id="@+id/tab_badge_human"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/badge_dot"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Content Container for child Fragments -->
    <FrameLayout
        android:id="@+id/dialogContentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_chat_dialog"
        android:clipToOutline="true"
        app:layout_constraintTop_toBottomOf="@id/layoutChatTabs"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
