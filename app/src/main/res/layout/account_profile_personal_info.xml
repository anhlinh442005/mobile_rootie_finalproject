<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Header Panel (Fixed at top) -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_gradient_header"
        android:elevation="4dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thông tin cá nhân"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <ImageView
            android:id="@+id/btn_save"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_toStartOf="@id/layoutNotification"
            android:layout_centerVertical="true"
            android:padding="12dp"
            android:src="@drawable/ic_check"
            app:tint="@color/primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <include
            android:id="@+id/layoutNotification"
            layout="@layout/include_notification_bell"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header"
        android:layout_above="@id/bottom_nav"
        android:clipToPadding="false"
        android:descendantFocusability="beforeDescendants"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Warning Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFBEA"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="top">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_warning_outline"
                    app:tint="@color/selector_warning_tint" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Bạn vui lòng nhập chính xác thông tin CCCD để đơn hàng được thông quan theo quy định từ ngày 09/07. Thông tin sẽ được bảo mật theo chính sách bảo mật của Rootie."
                    android:textColor="#5C5C50"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.2"
                    android:fontFamily="@font/lexend" />
            </LinearLayout>

            <!-- Form Fields Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <!-- Field 1: Họ và tên -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Họ và tên"
                        android:textColor="#7E8A83"
                        android:textSize="12sp"
                        android:fontFamily="@font/lexend" />

                    <EditText
                        android:id="@+id/et_fullname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@null"
                        android:enabled="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:hint="Nhập họ và tên đầy đủ"
                        android:inputType="textPersonName"
                        android:paddingVertical="8dp"
                        android:textColor="#28362E"
                        android:textColorHint="#97A49C"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:background="#E2E4E1" />
                </LinearLayout>

                <!-- Field 2: Số CCCD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số CCCD"
                        android:textColor="#7E8A83"
                        android:textSize="12sp"
                        android:fontFamily="@font/lexend" />

                    <EditText
                        android:id="@+id/et_cccd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@null"
                        android:enabled="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:hint="Nhập số CCCD / CMND"
                        android:inputType="number"
                        android:maxLength="12"
                        android:paddingVertical="8dp"
                        android:textColor="#28362E"
                        android:textColorHint="#97A49C"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:background="#E2E4E1" />
                </LinearLayout>

                <!-- Field 3: Địa chỉ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Địa chỉ"
                            android:textColor="#7E8A83"
                            android:textSize="12sp"
                            android:fontFamily="@font/lexend" />

                        <TextView
                            android:id="@+id/tv_address_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0/200"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/lexend" />
                    </RelativeLayout>

                    <EditText
                        android:id="@+id/et_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@null"
                        android:enabled="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:gravity="top|start"
                        android:hint="Nhập địa chỉ nhận hàng"
                        android:inputType="textPostalAddress|textMultiLine"
                        android:maxLength="200"
                        android:minLines="2"
                        android:paddingVertical="8dp"
                        android:textColor="#28362E"
                        android:textColorHint="#97A49C"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:background="#E2E4E1" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Shared Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp" />

</RelativeLayout>
