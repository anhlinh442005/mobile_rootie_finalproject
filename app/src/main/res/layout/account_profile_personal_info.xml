<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="56dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Header Panel -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="66dp"
                android:background="@drawable/bg_points_card_gradient"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">

                <!-- Back button -->
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Header Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Thông tin cá nhân"
                    android:textColor="#28362E"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend" />

                <!-- Notification Icon -->
                <ImageView
                    android:id="@+id/btn_notification"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_bell"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <!-- Warning Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFBEA"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="top">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_warning_outline"
                    app:tint="@color/selector_warning_tint" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Bạn vui lòng nhập chính xác thông tin CCCD để đơn hàng được thông quan theo quy định từ ngày 09/07. Thông tin sẽ được bảo mật theo chính sách bảo mật của Rootie."
                    android:textColor="#5C5C50"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.2"
                    android:fontFamily="@font/lexend" />
            </LinearLayout>

            <!-- Form Fields Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <!-- Field 1: Họ và tên -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="Họ và tên"
                            android:textColor="#28362E"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <EditText
                            android:id="@+id/et_fullname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@null"
                            android:gravity="end"
                            android:text="S*** **** ***H"
                            android:textColor="#28362E"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend"
                            android:inputType="textPersonName" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />
                </LinearLayout>

                <!-- Field 2: Số CCCD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="Số CCCD"
                            android:textColor="#28362E"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <EditText
                            android:id="@+id/et_cccd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@null"
                            android:gravity="end"
                            android:text="*********9999"
                            android:textColor="#28362E"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend"
                            android:inputType="number" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />
                </LinearLayout>

                <!-- Field 3: Địa chỉ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Địa chỉ"
                            android:textColor="#28362E"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <TextView
                            android:id="@+id/tv_address_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="8/200"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/lexend" />
                    </RelativeLayout>

                    <EditText
                        android:id="@+id/et_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:paddingVertical="8dp"
                        android:text="********"
                        android:textColor="#28362E"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Shared Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp" />

</RelativeLayout>
