<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:background="@drawable/com_bg_post"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/grid_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Lỗ chân lông"
            android:textColor="@color/content"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/grid_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="7/10"
            android:textColor="@color/primary"
            android:textSize="22sp" />
    </LinearLayout>

    <View
        android:id="@+id/grid_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_dialog_btn_confirm" />

</FrameLayout>
