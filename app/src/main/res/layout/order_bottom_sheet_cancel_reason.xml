<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Lý do huỷ đơn"
        android:textColor="@color/primary"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/be_vietnam_pro_regular"
        android:text="Vui lòng chọn lý do phù hợp (bắt buộc)"
        android:textColor="@color/gray_dark"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <RadioGroup
        android:id="@+id/rgReasons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_white_rounded_corner_border"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <RadioButton
            android:id="@+id/rbReason1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Đặt nhầm sản phẩm"
            android:textColor="@color/primary"
            android:padding="12dp"
            android:buttonTint="@color/primary" />
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" android:layout_marginHorizontal="12dp" />

        <RadioButton
            android:id="@+id/rbReason2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Muốn thay đổi sản phẩm"
            android:textColor="@color/primary"
            android:padding="12dp"
            android:buttonTint="@color/primary" />
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" android:layout_marginHorizontal="12dp" />

        <RadioButton
            android:id="@+id/rbReason3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Muốn thay đổi địa chỉ giao hàng"
            android:textColor="@color/primary"
            android:padding="12dp"
            android:buttonTint="@color/primary" />
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" android:layout_marginHorizontal="12dp" />

        <RadioButton
            android:id="@+id/rbReason4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Giao hàng quá lâu"
            android:textColor="@color/primary"
            android:padding="12dp"
            android:buttonTint="@color/primary" />
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" android:layout_marginHorizontal="12dp" />

        <RadioButton
            android:id="@+id/rbReason5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Tìm thấy giá tốt hơn"
            android:textColor="@color/primary"
            android:padding="12dp"
            android:buttonTint="@color/primary" />
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" android:layout_marginHorizontal="12dp" />

        <RadioButton
            android:id="@+id/rbReason6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Không còn nhu cầu"
            android:textColor="@color/primary"
            android:padding="12dp"
            android:buttonTint="@color/primary" />
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" android:layout_marginHorizontal="12dp" />

        <RadioButton
            android:id="@+id/rbReason7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Lý do khác"
            android:textColor="@color/primary"
            android:padding="12dp"
            android:buttonTint="@color/primary" />

    </RadioGroup>

    <!-- Additional Description -->
    <LinearLayout
        android:id="@+id/llDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_white_rounded_corner_border"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/rgReasons">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Mô tả thêm (không bắt buộc)"
            android:textColor="@color/primary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edittext_outline"
            android:gravity="top|start"
            android:hint="Nhập mô tả thêm về lý do huỷ đơn..."
            android:padding="12dp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:textColor="@color/primary"
            android:textSize="14sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/primary"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Tiếp tục"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/llDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>
