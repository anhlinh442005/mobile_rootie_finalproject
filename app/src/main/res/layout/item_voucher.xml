<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_card_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_card_white">

    <!-- Top Part of the Voucher Card -->
    <RelativeLayout
        android:id="@+id/layout_top_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon container -->
        <FrameLayout
            android:id="@+id/iv_voucher_icon_bg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_rounded_green">

            <ImageView
                android:id="@+id/iv_voucher_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_voucher"
                app:tint="#02542D" />
        </FrameLayout>

        <!-- Details block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toStartOf="@id/dummy_anchor"
            android:layout_toEndOf="@id/iv_voucher_icon_bg"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_voucher_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:text="Giảm 50K Đơn từ 300K"
                android:textColor="#3E4D44"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_voucher_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/lexend"
                android:text="Áp dụng cho tất cả sản phẩm chăm sóc da mặt của Rootie. Không áp dụng cùng các..."
                android:textColor="#555555"
                android:textSize="12sp"
                android:ellipsize="end"
                android:maxLines="2" />

            <!-- Tags (Status + Expiry date) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_voucher_status_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_valid"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:fontFamily="@font/lexend"
                    android:text="Còn hạn"
                    android:textColor="#2E7D32"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_voucher_hsd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/lexend"
                    android:text="HSD: 31/12/2023"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Dummy anchor to reserve space for expiring badge or copy button layout right aligned -->
        <View
            android:id="@+id/dummy_anchor"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="80dp" />

    </RelativeLayout>

    <!-- Top-Right Ribbon/Badge overlay for Expiring Vouchers -->
    <TextView
        android:id="@+id/tv_voucher_expiring_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_badge_expiring"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:fontFamily="@font/lexend"
        android:text="Sắp hết hạn"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Top-Right Delete button for Expired Vouchers -->
    <ImageView
        android:id="@+id/btn_voucher_delete"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="6dp"
        android:src="@drawable/ic_close"
        app:tint="#888888"
        android:visibility="gone" />

    <!-- Dotted horizontal separator line -->
    <View
        android:id="@+id/dashed_line"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_below="@id/layout_top_section"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/dashed_line_horizontal"
        android:layerType="software" />

    <!-- Bottom Part containing Code and Copy/Action Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/dashed_line"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <TextView
            android:id="@+id/tv_voucher_code_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:fontFamily="@font/lexend"
            android:text="MÃ: RT50KDEC"
            android:textColor="#666666"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_voucher_action"
            android:layout_width="100dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_button_copy"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/lexend"
            android:text="Copy mã"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </RelativeLayout>

</RelativeLayout>
