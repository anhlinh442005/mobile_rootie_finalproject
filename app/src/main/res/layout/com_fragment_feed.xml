<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@color/neutral"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/ivHome"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_home"
            app:tint="@color/primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/ivMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu_sort"
            app:tint="@color/primary"
            app:layout_constraintStart_toEndOf="@id/ivHome"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:id="@+id/llLogoContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Rootie Logo PNG -->
            <ImageView
                android:layout_width="90dp"
                android:layout_height="32dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_name"
                app:tint="@color/primary" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_chevron_down"
                app:tint="@color/primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivPlus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_plus"
                app:tint="@color/primary" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_search"
                app:tint="@color/primary" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/home_ic_notification"
                app:tint="@color/primary" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nsvFeed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingTop="56dp"
            android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Stories List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/com_item_story" />

        <!-- Filters (Rounded border 5-6px) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tvFilterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_selected"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Dành cho bạn"
                    android:textColor="@color/white"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterRoutine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Routine"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Review"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterReels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Reels"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterKienThuc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Kiến thức"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterHoiDap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Hỏi đáp"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterDaDau"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Da dầu"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterMun"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Mụn"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterDaKho"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Da khô"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterThamMun"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Thâm mụn"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvFilterDiUng"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/com_bg_filter_normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Dị ứng"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Posts List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPosts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/com_item_post" />

    </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


    <include
        android:id="@+id/com_bottom_nav"
        layout="@layout/com_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start">
        
        <include layout="@layout/com_side_menu" />
        
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
