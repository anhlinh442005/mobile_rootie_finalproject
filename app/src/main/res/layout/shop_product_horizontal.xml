<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#FAF9F4">

        <ImageView
            android:id="@+id/ivProduct"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:color/darker_gray" />

        <TextView
            android:id="@+id/tvBadgeNew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FF5252"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="Mới"
            android:textColor="@android:color/white"
            android:textSize="9sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Gel tắm đường thốt nốt An Giang 500ml"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:textColor="#3e4d44"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="241.000đ"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:textColor="#B4202A"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="325.000đ"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:textColor="#807F7F"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
