<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- Header Panel -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="#02542D" />

        <!-- Header Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/lexend"
            android:text="Ví Voucher"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Notification Bell -->
        <ImageView
            android:id="@+id/btn_notification"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_notification" />
    </RelativeLayout>

    <!-- Content Area below Header and above Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav"
        android:layout_below="@id/layout_header"
        android:orientation="vertical">

        <!-- Warning Banner -->
        <LinearLayout
            android:id="@+id/banner_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_alert_red"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_warning_red" />

            <TextView
                android:id="@+id/tv_warning_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/lexend"
                android:text="1 voucher sắp hết hạn"
                android:textColor="#C62828"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Segmented Control / Filter Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <!-- Tab: Tất cả -->
            <TextView
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/tab_active_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/lexend"
                android:text="Tất cả"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Tab: Còn hạn -->
            <TextView
                android:id="@+id/tab_valid"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_inactive_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/lexend"
                android:text="Còn hạn"
                android:textColor="#3E4D44"
                android:textSize="13sp" />

            <!-- Tab: Hết hạn -->
            <TextView
                android:id="@+id/tab_expired"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_inactive_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/lexend"
                android:text="Hết hạn"
                android:textColor="#3E4D44"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- RecyclerView for Voucher cards -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_vouchers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:scrollbars="vertical" />
    </LinearLayout>

    <!-- Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
