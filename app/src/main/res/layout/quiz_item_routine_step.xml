<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:layout_marginBottom="16dp">

    <!-- Step number badge -->
    <TextView
        android:id="@+id/tv_step_number"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_circle_icon"
        android:backgroundTint="#DDDFC4"
        android:gravity="center"
        android:fontFamily="@font/lexend"
        android:text="1"
        android:textColor="#677559"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Step content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_step_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend"
            android:text="Tẩy trang dịu nhẹ"
            android:textColor="#3E4D44"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_step_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/lexend"
            android:text="Dùng nước tẩy trang micellar dịu nhẹ, không chứa cồn khô để làm sạch bụi bẩn và kem chống nắng."
            android:textColor="#677559"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.15" />
    </LinearLayout>
</LinearLayout>
