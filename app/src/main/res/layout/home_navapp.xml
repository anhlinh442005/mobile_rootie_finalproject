<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">
 
    <com.veganbeauty.app.ui.widget.BottomNavBackground
        android:id="@+id/nav_background"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/view_ai_skin_glow"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_nav_ai_skin_glow"
        android:alpha="0"
        android:translationY="-2dp"
        app:layout_constraintBottom_toTopOf="@id/nav_background"
        app:layout_constraintTop_toTopOf="@id/nav_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:weightSum="5"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
 
        <!-- 1. Trang chủ -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_home"
            android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_home" android:layout_width="48dp" android:layout_height="48dp"
                android:src="@drawable/ic_home" android:contentDescription="Trang chủ"
                android:scaleType="centerInside" android:padding="12dp" />
            <TextView android:id="@+id/tv_nav_home" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Trang chủ"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
        <!-- 2. Mua sắm -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_shop"
            android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_shop" android:layout_width="48dp" android:layout_height="48dp"
                android:src="@drawable/ic_shop" android:contentDescription="Mua sắm"
                android:scaleType="centerInside" android:padding="12dp" />
            <TextView android:id="@+id/tv_nav_shop" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mua sắm"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
        <!-- 3. My Skin — icon lồi lên trên, căn giữa viền tròn bump -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/nav_myskin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/vMySkinShadow"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/shape_nav_active_bg"
                android:translationY="2dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@id/ivMySkin"
                app:layout_constraintBottom_toBottomOf="@id/ivMySkin"
                app:layout_constraintStart_toStartOf="@id/ivMySkin"
                app:layout_constraintEnd_toEndOf="@id/ivMySkin" />

            <ImageView
                android:id="@+id/ivMySkin"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="AI Skin"
                android:src="@drawable/ic_skin_mainbar_nonactive"
                android:translationY="2dp"
                android:elevation="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="AI Skin"
                android:textColor="@color/nav_icon_color"
                android:textSize="10sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="11.5dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>
 
        <!-- 4. Cộng đồng -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_community"
            android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_community" android:layout_width="48dp" android:layout_height="48dp"
                android:src="@drawable/ic_community" android:contentDescription="Cộng đồng"
                android:scaleType="centerInside" android:padding="12dp" />
            <TextView android:id="@+id/tv_nav_community" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cộng đồng"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
        <!-- 5. Tài khoản -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_account"
            android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_account" android:layout_width="48dp" android:layout_height="48dp"
                android:src="@drawable/ic_account" android:contentDescription="Tài khoản"
                android:scaleType="centerInside" android:padding="12dp" />
            <TextView android:id="@+id/tv_nav_account" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tài khoản"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
    </LinearLayout>
 
</androidx.constraintlayout.widget.ConstraintLayout>
