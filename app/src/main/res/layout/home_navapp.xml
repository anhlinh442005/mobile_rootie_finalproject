<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">
 
    <com.veganbeauty.app.ui.widget.BottomNavBackground
        android:id="@+id/nav_background"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:weightSum="5"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
 
        <!-- 1. Trang chủ -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_home"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_home" android:contentDescription="Trang chủ" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="Trang chủ"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
        <!-- 2. Mua sắm -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_shop"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_shop" android:contentDescription="Mua sắm" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="Mua sắm"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
        <!-- 3. My Skin — icon lồi lên trên, căn giữa viền tròn bump -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/nav_myskin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivMySkin"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="My skin"
                android:src="@drawable/ic_myskin"
                android:translationY="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="My skin"
                android:textColor="@color/nav_icon_color"
                android:textSize="10sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="11.5dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>
 
        <!-- 4. Cộng đồng -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_community"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_community" android:contentDescription="Cộng đồng" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="Cộng đồng"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
        <!-- 5. Tài khoản -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:id="@+id/nav_account"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_account" android:contentDescription="Tài khoản" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="Tài khoản"
                android:textColor="@color/nav_icon_color" android:textSize="10sp"
                android:fontFamily="@font/be_vietnam_pro" />
        </LinearLayout>
 
    </LinearLayout>
 
</androidx.constraintlayout.widget.ConstraintLayout>
