<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_header_gradient"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp"
    android:elevation="8dp">

    <!-- Logo -->
    <ImageView
        android:id="@+id/home_header_logo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/imv_logo" />

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/home_header_search_bar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_weight="1"
        android:background="@drawable/home_bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/home_header_search_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_search"
            android:tint="@color/primary" />

        <TextView
            android:id="@+id/home_header_search_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/home_search_hint"
            android:textAppearance="@style/TextAppearance.Rootie.Content"
            android:textColor="@color/tertiary"
            android:textSize="18sp" />

     </LinearLayout>

    <!-- QR Button -->
    <FrameLayout
        android:id="@+id/home_header_qr_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_qrscan" />

    </FrameLayout>

    <!-- Cart Button -->
    <FrameLayout
        android:id="@+id/home_header_cart_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_cart"
            android:tint="@color/primary" />

        <!-- Badge -->
        <TextView
            android:id="@+id/home_header_cart_badge"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/home_bg_notification_badge"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="visible" />

    </FrameLayout>

</LinearLayout>