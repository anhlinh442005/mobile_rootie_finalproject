<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF4">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:id="@+id/skin_history_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/skin_history_btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:gravity="center"
            android:text="Lịch Sử Da"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:layout_marginEnd="44dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/skin_history_bottom_bar"
        app:layout_constraintTop_toBottomOf="@id/skin_history_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FILTERS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/skin_history_filter_all"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/skin_bg_btn_solid_dark"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Tất Cả"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/skin_history_filter_ai"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/skin_bg_card_outline"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Quét AI"
                    android:textColor="@color/content"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/skin_history_filter_offline"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/skin_bg_card_outline"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Soi Da Offline"
                    android:textColor="@color/content"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- CHART CONTAINER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/skin_bg_card_outline"
                android:backgroundTint="#FDFDF9"
                android:padding="16dp">

                <TextView
                    android:id="@+id/skin_history_chart_ylabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:text="Điểm Da Qua Thời Gian"
                    android:textColor="@color/content"
                    android:textSize="12sp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/skin_history_line_chart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_below="@id/skin_history_chart_ylabel"
                    android:layout_marginTop="4dp" />
            </RelativeLayout>

            <!-- LIST TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="Lịch Sử Kết Quả"
                android:textColor="@color/secondary"
                android:textSize="14sp" />

            <!-- LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/skin_history_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_card_outline"
                android:nestedScrollingEnabled="false"
                android:paddingVertical="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM BAR ===== -->
    <LinearLayout
        android:id="@+id/skin_history_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAF4"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/skin_history_btn_routine"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/skin_bg_btn_solid_dark"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:text="Gợi ý Routine"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
