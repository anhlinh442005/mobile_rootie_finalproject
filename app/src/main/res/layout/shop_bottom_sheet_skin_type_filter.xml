<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingTop="12dp">

    <!-- Drag Handle -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#6C757D"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title Section -->
    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Loại da"
        android:textColor="@color/primary"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dragHandle" />

    <View
        android:id="@+id/dividerTop"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/gray_light"
        app:layout_constraintTop_toBottomOf="@id/tvSheetTitle" />

    <!-- Content: Checkboxes -->
    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toBottomOf="@id/dividerTop"
        app:layout_constraintBottom_toTopOf="@id/layoutFooter">

        <CheckBox
            android:id="@+id/cbSkinNormal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Da thường"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:buttonTint="@color/primary"
            android:paddingVertical="6dp" />

        <CheckBox
            android:id="@+id/cbSkinDry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Da khô"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:buttonTint="@color/primary"
            android:paddingVertical="6dp" />

        <CheckBox
            android:id="@+id/cbSkinOily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Da dầu"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:buttonTint="@color/primary"
            android:paddingVertical="6dp" />

        <CheckBox
            android:id="@+id/cbSkinSensitive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Da nhạy cảm"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:buttonTint="@color/primary"
            android:paddingVertical="6dp" />

        <CheckBox
            android:id="@+id/cbSkinCombination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Da hỗn hợp"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:buttonTint="@color/primary"
            android:paddingVertical="6dp" />
    </LinearLayout>

    <!-- Footer: Buttons -->
    <LinearLayout
        android:id="@+id/layoutFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Thiết lập lại"
            android:textColor="@color/primary"
            android:fontFamily="@font/be_vietnam_pro_semibold"
            android:textAllCaps="false"
            app:strokeColor="@color/primary"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1.2"
            android:layout_marginStart="8dp"
            android:text="Xác nhận"
            android:textColor="@color/white"
            android:fontFamily="@font/be_vietnam_pro_semibold"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
