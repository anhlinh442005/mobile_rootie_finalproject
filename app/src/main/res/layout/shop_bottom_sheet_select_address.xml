<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingTop="12dp"
    android:paddingBottom="24dp"
    android:paddingHorizontal="16dp">

    <!-- Drag Handle -->
    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="60dp"
        android:layout_height="10dp"
        android:src="@drawable/ic_dash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/be_vietnam_pro_semibold"
        android:text="Chọn địa chỉ nhận hàng"
        android:textColor="@color/primary"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dragHandle" />

    <!-- Address List Container -->
    <LinearLayout
        android:id="@+id/llAddressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <!-- Address 1 Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clAddress1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp">

            <!-- Radio Indicator -->
            <ImageView
                android:id="@+id/ivRadioAddress1"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_cart_checked"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvEditAddress1"
                app:layout_constraintStart_toEndOf="@id/ivRadioAddress1"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvNamePhone1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend_medium"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    tools:text="Bảo Nguyên | 0123456789" />

                <TextView
                    android:id="@+id/tvAddressDetails1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/lexend_regular"
                    android:textColor="@color/gray_dark"
                    android:textSize="14sp"
                    tools:text="123 Lê Lợi, phường 5, quận 1, Hồ Chí Minh" />

                <TextView
                    android:id="@+id/tvTagDefault1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_cart_voucher_bar"
                    android:backgroundTint="#EDF3ED"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Mặc định"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

            <!-- Edit Action -->
            <TextView
                android:id="@+id/tvEditAddress1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:text="Sửa"
                android:textColor="@color/primary"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Divider -->
        <View
            android:id="@+id/dividerAddress"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_light" />

        <!-- Address 2 Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clAddress2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp">

            <!-- Radio Indicator -->
            <ImageView
                android:id="@+id/ivRadioAddress2"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_cart_unchecked"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvEditAddress2"
                app:layout_constraintStart_toEndOf="@id/ivRadioAddress2"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvNamePhone2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend_medium"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    tools:text="Nguyên Bảo | 0987654321" />

                <TextView
                    android:id="@+id/tvAddressDetails2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/lexend_regular"
                    android:textColor="@color/gray_dark"
                    android:textSize="14sp"
                    tools:text="321 Lê Lợi, phường 5, quận 1, Hồ Chí Minh" />

                <TextView
                    android:id="@+id/tvTagDefault2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_cart_voucher_bar"
                    android:backgroundTint="#EDF3ED"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Mặc định"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Edit Action -->
            <TextView
                android:id="@+id/tvEditAddress2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:text="Sửa"
                android:textColor="@color/primary"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/llBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/llAddressContainer">

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmAddress"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="@color/primary"
            android:fontFamily="@font/be_vietnam_pro_semibold"
            android:text="Xác nhận"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="10dp" />

        <!-- Add Address Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddAddress"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/be_vietnam_pro_semibold"
            android:text="Thêm địa chỉ"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/primary" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
