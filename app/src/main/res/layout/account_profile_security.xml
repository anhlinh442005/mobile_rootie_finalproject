<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Panel matching CSS spec -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="66dp"
                android:background="@drawable/bg_header_security_gradient"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <!-- Back button -->
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="#02542D" />

                <!-- Header Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="@font/lexend"
                    android:text="Tài khoản &amp; Bảo mật"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Notification Bell -->
                <ImageView
                    android:id="@+id/btn_notification"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="6dp"
                    android:src="@drawable/home_ic_notification"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <!-- SECTION 1: TÀI KHOẢN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:background="#F5F5F5"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Tài Khoản"
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:fontFamily="@font/lexend" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- 1. Hồ sơ của tôi -->
                <RelativeLayout
                    android:id="@+id/btn_my_profile"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Hồ sơ của tôi"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <ImageView
                        android:id="@+id/iv_chevron_profile"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 2. Tên người dùng -->
                <RelativeLayout
                    android:id="@+id/btn_username"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Tên người dùng"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <ImageView
                        android:id="@+id/iv_chevron_username"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />

                    <TextView
                        android:id="@+id/tv_username_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:layout_toStartOf="@id/iv_chevron_username"
                        android:text="mrbeanintheworld"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 3. Điện thoại -->
                <RelativeLayout
                    android:id="@+id/btn_phone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Điện thoại"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <ImageView
                        android:id="@+id/iv_chevron_phone"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />

                    <TextView
                        android:id="@+id/tv_phone_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:layout_toStartOf="@id/iv_chevron_phone"
                        android:text="******48"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 4. Email nhận hóa đơn -->
                <RelativeLayout
                    android:id="@+id/btn_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Email nhận hóa đơn"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <ImageView
                        android:id="@+id/iv_chevron_email"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />

                    <TextView
                        android:id="@+id/tv_email_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:layout_toStartOf="@id/iv_chevron_email"
                        android:text="b********1@uel.edu.vn"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 5. Tài khoản mạng xã hội -->
                <RelativeLayout
                    android:id="@+id/btn_social"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Tài khoản mạng xã hội"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 6. Đổi mật khẩu -->
                <RelativeLayout
                    android:id="@+id/btn_change_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Đổi mật khẩu"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 7. Passkey -->
                <RelativeLayout
                    android:id="@+id/btn_passkey"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Passkey"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />

                    <ImageView
                        android:id="@+id/iv_chevron_passkey"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:layout_toStartOf="@id/iv_chevron_passkey"
                        android:text="Thiết lập ngay"
                        android:textColor="#02542D"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 8. Đăng nhập nhanh (Toggle Switch) -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/switch_fast_login_container"
                        android:layout_alignParentStart="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đăng nhập nhanh"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Cho phép đăng nhập nhanh trên thiết bị này"
                            android:textColor="#AEAEB2"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/switch_fast_login_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_fast_login_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_switch_thumb" />
                    </FrameLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- SECTION 2: BẢO MẬT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:background="#F5F5F5"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Bảo Mật"
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:fontFamily="@font/lexend" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- 1. Kiểm tra hoạt động của tài khoản -->
                <RelativeLayout
                    android:id="@+id/btn_check_activity"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/iv_chevron_activity"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kiểm tra hoạt động của tài khoản"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Kiểm tra những lần đăng nhập và thay đổi tài khoản trong 30 ngày gần nhất"
                            android:textColor="#AEAEB2"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_chevron_activity"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9" />

                <!-- 2. Quản lý thiết bị đăng nhập -->
                <RelativeLayout
                    android:id="@+id/btn_manage_devices"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/iv_chevron_devices"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quản lý thiết bị đăng nhập"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Quản lý các thiết bị đã đăng nhập vào tài khoản Rootie"
                            android:textColor="#AEAEB2"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_chevron_devices"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#C3C8C2" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Shared Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
