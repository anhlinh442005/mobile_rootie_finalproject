<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="56dp"
        android:paddingBottom="@dimen/home_nav_bar_height"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- SECTION 1: TÀI KHOẢN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="6dp"
                    android:text="THÔNG TIN TÀI KHOẢN"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <!-- 1. Hồ sơ của tôi -->
                    <RelativeLayout
                        android:id="@+id/btn_my_profile"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Hồ sơ của tôi"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:id="@+id/iv_chevron_profile"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 2. Tên người dùng -->
                    <RelativeLayout
                        android:id="@+id/btn_username"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Tên người dùng"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:id="@+id/iv_chevron_username"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />

                        <TextView
                            android:id="@+id/tv_username_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="8dp"
                            android:layout_toStartOf="@id/iv_chevron_username"
                            android:text="mrbeanintheworld"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 3. Điện thoại -->
                    <RelativeLayout
                        android:id="@+id/btn_phone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Điện thoại"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:id="@+id/iv_chevron_phone"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />

                        <TextView
                            android:id="@+id/tv_phone_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="8dp"
                            android:layout_toStartOf="@id/iv_chevron_phone"
                            android:text="******48"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 4. Email nhận hóa đơn -->
                    <RelativeLayout
                        android:id="@+id/btn_email"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Email nhận hóa đơn"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:id="@+id/iv_chevron_email"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />

                        <TextView
                            android:id="@+id/tv_email_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="8dp"
                            android:layout_toStartOf="@id/iv_chevron_email"
                            android:text="b********1@uel.edu.vn"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 5. Tài khoản mạng xã hội -->
                    <RelativeLayout
                        android:id="@+id/btn_social"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Tài khoản mạng xã hội"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 6. Đổi mật khẩu -->
                    <RelativeLayout
                        android:id="@+id/btn_change_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Đổi mật khẩu"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 7. Passkey -->
                    <RelativeLayout
                        android:id="@+id/btn_passkey"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Passkey"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:id="@+id/iv_chevron_passkey"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="8dp"
                            android:layout_toStartOf="@id/iv_chevron_passkey"
                            android:text="Thiết lập ngay"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 8. Đăng nhập nhanh (Switch trực tiếp) -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@id/switch_fast_login_container"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đăng nhập nhanh"
                                android:textColor="@color/primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Cho phép đăng nhập nhanh trên thiết bị này"
                                android:textColor="@color/gray_dark"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/switch_fast_login_container"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switch_fast_login_thumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_white_rounded_corner_border" />
                        </FrameLayout>
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 9. Trợ lý AI (Switch trực tiếp) -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@id/switch_floating_chat_container"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trợ lý Rootie AI (Nút nổi)"
                                android:textColor="@color/primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Hiển thị biểu tượng chat nổi trên màn hình"
                                android:textColor="@color/gray_dark"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/switch_floating_chat_container"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switch_floating_chat_thumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_white_rounded_corner_border" />
                        </FrameLayout>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- SECTION 2: BẢO MẬT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="6dp"
                    android:text="BẢO MẬT TÀI KHOẢN"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <!-- 1. Kiểm tra hoạt động của tài khoản -->
                    <RelativeLayout
                        android:id="@+id/btn_check_activity"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="8dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@id/iv_chevron_activity"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kiểm tra hoạt động của tài khoản"
                                android:textColor="@color/primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Kiểm tra những lần đăng nhập và thay đổi tài khoản trong 30 ngày gần nhất"
                                android:textColor="@color/gray_dark"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_chevron_activity"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- 2. Quản lý thiết bị đăng nhập -->
                    <RelativeLayout
                        android:id="@+id/btn_manage_devices"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="8dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@id/iv_chevron_devices"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quản lý thiết bị đăng nhập"
                                android:textColor="@color/primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Quản lý các thiết bị đã đăng nhập vào tài khoản Rootie"
                                android:textColor="@color/gray_dark"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_chevron_devices"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="#7E8A83" />
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Shared Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp" />

    <!-- Top Header (overlay) -->
    <RelativeLayout
        android:id="@+id/rl_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_gradient_header"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="56dp"
            android:ellipsize="end"
            android:fontFamily="@font/be_vietnam_pro"
            android:maxLines="1"
            android:text="Tài khoản &amp; Bảo mật"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/layoutNotification"
            layout="@layout/include_notification_bell"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp" />
    </RelativeLayout>

</RelativeLayout>
