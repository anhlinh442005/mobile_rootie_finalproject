<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp"
    android:weightSum="2">

    <!-- Left Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLeft"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_margin="4dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/gray_light"
        app:cardBackgroundColor="@color/primary">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="114dp"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivLeftIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/com_bg_post"
                android:backgroundTint="#4E5C53"
                android:padding="6dp"
                android:src="@drawable/ic_gift"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvLeftTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintTop_toBottomOf="@id/ivLeftIcon"
                android:text="Tích điểm đổi quà" />

            <TextView
                android:id="@+id/tvLeftValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:textColor="#E0E6E3"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                app:layout_constraintTop_toBottomOf="@id/tvLeftTitle"
                android:text="Mỗi 100 điểm tương ứng với 10.000đ" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Right Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_margin="4dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/gray_light"
        app:cardBackgroundColor="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="114dp"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivRightIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/com_bg_post"
                android:backgroundTint="@color/status_pending_bg"
                android:padding="6dp"
                android:src="@drawable/ic_ribbon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/status_pending_text" />

            <TextView
                android:id="@+id/tvRightTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintTop_toBottomOf="@id/ivRightIcon"
                android:text="Thành viên Bạc" />

            <TextView
                android:id="@+id/tvRightValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/gray_dark"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                app:layout_constraintTop_toBottomOf="@id/tvRightTitle"
                android:text="250 điểm để lên Vàng" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
