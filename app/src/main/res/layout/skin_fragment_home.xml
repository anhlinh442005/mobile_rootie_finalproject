<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Wrapper chứa header + scroll content -->
    <LinearLayout
        android:id="@+id/skin_main_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/neutral"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/skin_bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <!-- Header -->
    <include
        android:id="@+id/skin_header"
        layout="@layout/home_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Nội dung cuộn -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/skin_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Phần chào người dùng -->
            <LinearLayout
                android:id="@+id/skin_greeting_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/skin_greeting_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Xin chào, Xuân"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/skin_greeting_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Cùng Rootie hiểu là da của bạn mỗi ngày"
                    android:textColor="@color/content"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Banner AI Skin Scanner — chỉ ảnh, không overlay -->
            <FrameLayout
                android:id="@+id/skin_banner_container"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/skin_bg_banner"
                android:clipToOutline="true"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/skin_banner_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:src="@drawable/imv_skin" />

            </FrameLayout>

            <!-- Danh sách tính năng nhanh (shortcut icons) -->
            <LinearLayout
                android:id="@+id/skin_shortcut_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="5">

                <!-- Item 1: Quét da AI -->
                <LinearLayout
                    android:id="@+id/skin_shortcut_scan_ai"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/skin_bg_shortcut_item"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_camera"
                            android:tint="@color/primary" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:text="Quét da\nAI"
                        android:textColor="@color/primary"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Item 2: Hồ sơ da và dị ứng -->
                <LinearLayout
                    android:id="@+id/skin_shortcut_profile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/skin_bg_shortcut_item"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_face"
                            android:tint="@color/primary" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:text="Hồ sơ da\nvà dị ứng"
                        android:textColor="@color/primary"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Item 3: Routine chăm da -->
                <LinearLayout
                    android:id="@+id/skin_shortcut_routine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/skin_bg_shortcut_item"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_checklist"
                            android:tint="@color/primary" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:text="Routine\nchăm da"
                        android:textColor="@color/primary"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Item 4: Nhắc lịch chăm da -->
                <LinearLayout
                    android:id="@+id/skin_shortcut_reminder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/skin_bg_shortcut_item"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_bell"
                            android:tint="@color/primary" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:text="Nhắc lịch\nchăm da"
                        android:textColor="@color/primary"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Item 5: Skin Weather -->
                <LinearLayout
                    android:id="@+id/skin_shortcut_weather"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/skin_bg_shortcut_item"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_water_drop"
                            android:tint="@color/primary" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:text="Skin\nWeather"
                        android:textColor="@color/primary"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Section Đặt lịch soi da -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <!-- Nút Lịch sử lịch đặt -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/skin_btn_booking_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/skin_bg_store_card"
                    android:layout_marginBottom="24dp"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:id="@+id/skin_booking_history_icon_container"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintTop_toTopOf="@id/skin_booking_history_text_container"
                        app:layout_constraintBottom_toBottomOf="@id/skin_booking_history_text_container"
                        app:layout_constraintStart_toStartOf="parent"
                        android:background="@drawable/skin_bg_shortcut_item"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_calendar_outline"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/skin_booking_history_text_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/skin_booking_history_icon_container"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/skin_booking_history_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lịch sử lịch đặt"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro" />

                        <TextView
                            android:id="@+id/skin_booking_history_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Theo dõi toàn bộ lịch hẹn soi da đã đặt"
                            android:textColor="@color/content"
                            android:textSize="10sp"
                            android:fontFamily="@font/be_vietnam_pro" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Tiêu đề section + xem tất cả -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/skin_store_section_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Đặt lịch soi da tại cửa hàng"
                        android:textColor="@color/primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/skin_store_see_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Xem tất cả ›"
                        android:textColor="@color/content"
                        android:textSize="13sp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_skin_stores"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/skin_bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
