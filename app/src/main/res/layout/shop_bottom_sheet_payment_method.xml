<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Bottom Sheet Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_pill_grey" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Chọn phương thức thanh toán"
        android:textColor="@color/primary"
        android:textSize="18sp" />

    <!-- Option 1: Cash -->
    <LinearLayout
        android:id="@+id/llOptionCash"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/ivRadioCash"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_cart_unchecked"
            />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_cash"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Thanh toán tiền mặt khi nhận hàng"
            android:textColor="@color/primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Option 2: ATM/Internet Banking -->
    <LinearLayout
        android:id="@+id/llOptionATM"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/ivRadioATM"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_cart_unchecked"
            />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_card"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Thẻ ATM nội địa/Internet Banking"
            android:textColor="@color/primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Option 3: MoMo -->
    <LinearLayout
        android:id="@+id/llOptionMoMo"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/ivRadioMoMo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_cart_unchecked"
            />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_momo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Thanh toán trực tuyến MoMo"
            android:textColor="@color/primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Option 4: VNPay -->
    <LinearLayout
        android:id="@+id/llOptionVNPay"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/ivRadioVNPay"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_cart_unchecked"
            />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_vnpay" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Thanh toán trực tuyến VNPay"
            android:textColor="@color/primary"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>
