<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/com_bg_post"
    android:paddingTop="12dp">

    <!-- Drag Handle -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#6C757D"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/dragHandle">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Giỏ hàng"
            android:textColor="@color/primary"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/llSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:padding="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivSelectAll"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_circle" />

            <TextView
                android:id="@+id/tvSelectAllLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:textColor="@color/primary"
                android:textSize="14sp"
                tools:text="Chọn tất cả (3)" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Cart Items RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCartItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="350dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/clHeader"
        app:layout_constraintBottom_toTopOf="@id/divider"
        tools:listitem="@layout/shop_item_cart" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_light"
        app:layout_constraintBottom_toTopOf="@id/clSummary" />

    <!-- Summary & Checkout Section -->
    <LinearLayout
        android:id="@+id/clSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="#FFFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Voucher Row -->
        <LinearLayout
            android:id="@+id/llVoucherRow"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_cart_voucher_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:backgroundTint="#EDF3ED">

            <TextView
                android:id="@+id/tvVoucherDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:text="Áp dụng ưu đãi để được giảm giá"
                android:textColor="@color/primary"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_next"
                app:tint="@color/primary" />
        </LinearLayout>

        <!-- Points Redemption Row -->
        <LinearLayout
            android:id="@+id/llPointsRow"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_coin" />

            <TextView
                android:id="@+id/tvPointsText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:text="Bạn có 0 xu"
                android:textColor="@color/primary"
                android:textSize="14sp" />

            <FrameLayout
                android:id="@+id/switchPoints"
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:background="@drawable/ic_switch_track_off"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/switchPointsThumb"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/bg_white_rounded_corner_border" />
            </FrameLayout>
        </LinearLayout>

        <!-- Price Details Section (Collapsible) -->
        <LinearLayout
            android:id="@+id/llPriceDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <!-- Tổng tiền row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/be_vietnam_pro_regular"
                    android:text="Tổng tiền"
                    android:textColor="@color/primary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvDetailSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    tools:text="325.000đ" />
            </LinearLayout>

            <!-- Giảm giá trực tiếp row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/be_vietnam_pro_regular"
                    android:text="Giảm giá trực tiếp"
                    android:textColor="@color/primary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvDetailDirectDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    tools:text="-81.000đ" />
            </LinearLayout>

            <!-- Giảm giá voucher row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/be_vietnam_pro_regular"
                    android:text="Giảm giá voucher"
                    android:textColor="@color/primary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvDetailVoucherDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:text="0đ" />
            </LinearLayout>
        </LinearLayout>

        <!-- Pricing and Button Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Thành tiền Label -->
            <TextView
                android:id="@+id/tvTotalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="Thành tiền"
                android:textColor="@color/primary"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Original price (Strikethrough) and Final Price -->
            <LinearLayout
                android:id="@+id/llPrices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvOriginalTotalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_regular"
                    android:textColor="@color/gray_dark"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    tools:text="325.000đ" />

                <TextView
                    android:id="@+id/tvTotalValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:textColor="#B4202A"
                    android:textSize="18sp"
                    tools:text="241.000đ" />

                <ImageView
                    android:id="@+id/ivPriceToggleArrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_next"
                    android:rotation="270"
                    android:layout_marginStart="4dp"
                    app:tint="@color/primary" />
            </LinearLayout>

            <!-- Tiết kiệm được Label -->
            <TextView
                android:id="@+id/tvSavingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:text="Tiết kiệm được"
                android:textColor="@color/gray_dark"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTotalLabel" />

            <!-- Savings Value -->
            <TextView
                android:id="@+id/tvSavingsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:textColor="@color/primary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSavingsLabel"
                tools:text="81.000đ" />

            <!-- Mua hàng button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckout"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro_semibold"
                android:text="Mua hàng"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llPrices" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
