<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:orientation="horizontal"
    android:weightSum="5"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@drawable/com_bg_navbar"
    android:elevation="8dp">

    <!-- 1. Feed (Active) -->
    <LinearLayout
        android:id="@+id/nav_com_feed"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_com_feed"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Feed"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <!-- 2. Beauty Hub -->
    <LinearLayout
        android:id="@+id/nav_com_hub"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_com_hub"
            app:tint="@color/tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Beauty Hub"
            android:textSize="10sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <!-- 3. Khám phá -->
    <LinearLayout
        android:id="@+id/nav_com_explore"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_com_explore"
            app:tint="@color/tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Khám phá"
            android:textSize="10sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <!-- 4. Tin nhắn -->
    <LinearLayout
        android:id="@+id/nav_com_chat"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_com_chat"
            app:tint="@color/tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Tin nhắn"
            android:textSize="10sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <!-- 5. Trang cá nhân -->
    <LinearLayout
        android:id="@+id/nav_com_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_com_profile"
            app:tint="@color/tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Trang cá nhân"
            android:textSize="10sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

</LinearLayout>
