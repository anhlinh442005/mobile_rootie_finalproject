<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="5"
    android:paddingTop="@dimen/com_navbar_padding_vertical"
    android:paddingBottom="@dimen/com_navbar_padding_vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@drawable/com_bg_navbar"
    android:elevation="8dp"
    android:minHeight="@dimen/com_navbar_min_height">

    <LinearLayout
        android:id="@+id/nav_com_feed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clipChildren="false">

            <View
                android:id="@+id/view_glow_com_feed"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_com_nav_tab_glow"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/iv_nav_com_feed"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_com_feed"
                app:tint="@color/primary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_nav_com_feed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Feed"
            android:textSize="9sp"
            android:textColor="@color/primary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_com_hub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clipChildren="false">

            <View
                android:id="@+id/view_glow_com_hub"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_com_nav_tab_glow"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/iv_nav_com_hub"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_com_hub"
                app:tint="@color/tertiary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_nav_com_hub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Beauty Hub"
            android:textSize="9sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_com_explore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clipChildren="false">

            <View
                android:id="@+id/view_glow_com_explore"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_com_nav_tab_glow"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/iv_nav_com_explore"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_com_explore"
                app:tint="@color/tertiary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_nav_com_explore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Khám phá"
            android:textSize="9sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_com_chat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clipChildren="false">

            <View
                android:id="@+id/view_glow_com_chat"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_com_nav_tab_glow"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/iv_nav_com_chat"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_com_chat"
                app:tint="@color/tertiary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_nav_com_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Tin nhắn"
            android:textSize="9sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_com_profile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clipChildren="false">

            <View
                android:id="@+id/view_glow_com_profile"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_com_nav_tab_glow"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/iv_nav_com_profile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_com_profile"
                app:tint="@color/tertiary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_nav_com_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Trang cá nhân"
            android:textSize="9sp"
            android:textColor="@color/tertiary"
            android:fontFamily="@font/be_vietnam_pro" />
    </LinearLayout>

</LinearLayout>
