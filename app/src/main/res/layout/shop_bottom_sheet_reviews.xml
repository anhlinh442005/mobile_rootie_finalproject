<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:backgroundTint="@color/neutral"
    android:padding="16dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#CCCCCC"
        android:backgroundTint="#CCCCCC"
        android:layout_marginBottom="16dp"/>

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đánh giá từ khách hàng"
        android:textColor="@color/primary"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Rating Summary Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_chip_normal"
        android:backgroundTint="@color/white"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvAverageRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.8"
                android:textColor="@color/primary"
                android:textSize="36sp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTotalRatingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="124 reviews"
                android:textColor="@color/gray_dark"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro_regular"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:background="#EAEAEA"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <!-- 5 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar5"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="80"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 4 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar4"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="15"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 3 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar3"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="5"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 2 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar2"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="0"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 1 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar1"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="0"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Review List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBottomSheetReviews"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/shop_item_review"
        tools:itemCount="5"/>
</LinearLayout>
