<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/com_bg_post"
    android:backgroundTint="@color/neutral"
    android:padding="16dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#CCCCCC"
        android:backgroundTint="#CCCCCC"
        android:layout_marginBottom="16dp"/>

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đánh giá từ khách hàng"
        android:textColor="@color/primary"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Rating Summary Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_chip_normal"
        android:backgroundTint="@color/white"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvAverageRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.8"
                android:textColor="@color/primary"
                android:textSize="36sp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTotalRatingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="124 reviews"
                android:textColor="@color/gray_dark"
                android:textSize="12sp"
                android:fontFamily="@font/be_vietnam_pro_regular"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:background="#EAEAEA"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <!-- 5 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar5"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="80"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 4 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar4"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="15"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 3 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar3"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="5"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 2 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar2"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="0"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>

            <!-- 1 Star Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="11sp"
                    android:textColor="@color/gray_dark"/>
                <ProgressBar
                    android:id="@+id/pbStar1"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:progress="0"
                    android:progressTint="#FFC107"
                    android:progressBackgroundTint="#EAEAEA"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Star Filter TabLayout (Fixed/Sticky at top) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutStarFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@android:color/transparent"
        app:tabMode="scrollable"
        app:tabIndicatorColor="@color/primary"
        app:tabSelectedTextColor="@color/primary"
        app:tabTextColor="@color/gray_dark">
        <com.google.android.material.tabs.TabItem android:text="Tất cả" />
        <com.google.android.material.tabs.TabItem android:text="5 Sao" />
        <com.google.android.material.tabs.TabItem android:text="4 Sao" />
        <com.google.android.material.tabs.TabItem android:text="3 Sao" />
        <com.google.android.material.tabs.TabItem android:text="2 Sao" />
        <com.google.android.material.tabs.TabItem android:text="1 Sao" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Scrollable container for reviews list and Xem thêm link -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Empty State TextView -->
            <TextView
                android:id="@+id/tvEmptyReviews"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="center"
                android:text="Chưa có đánh giá nào cho mức sao này."
                android:textColor="@color/gray_dark"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Review List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBottomSheetReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/shop_item_review"
                tools:itemCount="5"/>

            <!-- Load More Link (Text View) -->
            <TextView
                android:id="@+id/btnLoadMoreReviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:text="Xem thêm đánh giá >>"
                android:textColor="@color/secondary"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:padding="8dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
