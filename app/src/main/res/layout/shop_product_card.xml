<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:id="@+id/ivProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:color/darker_gray" />

            <TextView
                android:id="@+id/tvBadgeNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FF5252"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Mới"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:minLines="2"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Tên sản phẩm"
            android:textColor="#3e4d44"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="241.000đ"
                android:fontFamily="@font/be_vietnam_pro_semibold"
                android:textColor="#B4202A"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="325.000đ"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:textColor="#807F7F"
                android:textSize="10sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnAddToCart"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#3E4D44"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Chọn mua"
            android:fontFamily="@font/be_vietnam_pro_semibold"
            android:textAllCaps="false"
            android:textSize="12sp"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
