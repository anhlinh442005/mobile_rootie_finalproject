<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/com_bg_popup_menu"
    android:orientation="vertical"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dialog_review_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Chỉnh sửa đánh giá"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/dialog_review_btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Đóng"
            android:padding="6dp"
            android:src="@drawable/ic_cancel"
            app:tint="@color/content" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/skin_bg_btn_book_light"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Chạm vào sao để chọn điểm"
            android:textColor="@color/tertiary"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/dialog_review_star_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/dialog_review_star_1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="1 sao"
                android:focusable="true"
                android:padding="4dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dialog_review_star_2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="2 sao"
                android:focusable="true"
                android:padding="4dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dialog_review_star_3"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="3 sao"
                android:focusable="true"
                android:padding="4dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dialog_review_star_4"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="4 sao"
                android:focusable="true"
                android:padding="4dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dialog_review_star_5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="5 sao"
                android:focusable="true"
                android:padding="4dp"
                android:src="@drawable/ic_star" />
        </LinearLayout>

        <TextView
            android:id="@+id/dialog_review_rating_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="5,0"
            android:textColor="@color/primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialog_review_rating_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Tuyệt vời!"
            android:textColor="@color/content"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Nhận xét của bạn"
        android:textColor="@color/primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/dialog_review_comment"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/skin_bg_outline"
        android:fontFamily="@font/be_vietnam_pro"
        android:gravity="top|start"
        android:hint="Chia sẻ trải nghiệm của bạn tại spa..."
        android:inputType="textMultiLine|textCapSentences"
        android:maxLength="500"
        android:padding="14dp"
        android:scrollbars="vertical"
        android:textColor="@color/primary"
        android:textColorHint="@color/tertiary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/dialog_review_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:gravity="end"
        android:text="0/500"
        android:textColor="@color/tertiary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/skin_bg_outline"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_clock"
            app:tint="@color/tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Đánh giá ngày"
            android:textColor="@color/tertiary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/dialog_review_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:gravity="end"
            android:text="20/05/2024"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/skin_bg_btn_book_light"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_circle_checked"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:lineSpacingExtra="2dp"
            android:text="Đánh giá của bạn giúp Rootie cải thiện chất lượng dịch vụ tốt hơn mỗi ngày."
            android:textColor="@color/content"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/dialog_review_btn_submit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/com_bg_tab_active"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:gravity="center"
        android:text="Gửi đánh giá"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
