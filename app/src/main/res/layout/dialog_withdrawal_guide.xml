<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/com_bg_post"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="Hướng dẫn rút tiền"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="1. Số dư khả dụng tối thiểu để rút là 100.000đ.\n\n2. Thời gian xử lý yêu cầu rút tiền thường từ 1-3 ngày làm việc.\n\n3. Đảm bảo thông tin tài khoản ngân hàng của bạn là chính xác để tránh giao dịch bị từ chối.\n\n4. Mọi thắc mắc vui lòng liên hệ bộ phận CSKH."
        android:textColor="@color/gray_dark"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp" />

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/com_bg_btn_follow"
        android:backgroundTint="#56694E"
        android:fontFamily="@font/be_vietnam_pro"
        android:gravity="center"
        android:text="Đã hiểu"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
