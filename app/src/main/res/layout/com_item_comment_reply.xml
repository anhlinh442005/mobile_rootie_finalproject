<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp">
        <ImageView
            android:id="@+id/ivReplyAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img_avatar" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvReplyUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="mei_anh"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="#888888"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvReplyTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 tuần"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvReplyContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="thiệt hông bà mai tui mua về xài luôn nè"
            android:textColor="@color/primary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal|top"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp">

        <ImageView
            android:id="@+id/ivReplyLike"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_heart"
            app:tint="@color/secondary" />

        <TextView
            android:id="@+id/tvReplyLikesCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
