<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/neutral"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/gallery_btn_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_cancel"
            android:contentDescription="Đóng"
            android:tint="@color/primary" />

        <TextView
            android:id="@+id/gallery_page_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1/2"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/be_vietnam_pro" />

        <ImageView
            android:id="@+id/gallery_btn_download"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_dowload"
            android:contentDescription="Lưu ảnh"
            android:tint="@color/primary" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/gallery_view_pager"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginHorizontal="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/gallery_thumb_list"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Vuốt ngang để xem ảnh"
        android:textColor="@color/content"
        android:textSize="13sp"
        android:fontFamily="@font/be_vietnam_pro" />

</LinearLayout>
