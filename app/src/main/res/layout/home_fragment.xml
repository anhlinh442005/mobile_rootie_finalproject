<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF4"
    android:clipChildren="false"
    android:clipToPadding="false">

    <include
        android:id="@+id/home_header"
        layout="@layout/home_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/home_header"
        android:layout_alignParentBottom="true"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingBottom="@dimen/home_nav_content_height"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingTop="@dimen/home_section_spacing">

            <!-- Hero Banner Carousel -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpBanner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="true"
                        android:clipToPadding="true"
                        />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/llBannerDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal" />
            </FrameLayout>

            <!-- Skincare streak + quiz reminder list -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/cardHomeRoutineWidget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_streak_card_gradient"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_home_streak_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chuỗi chăm da của bạn: 0 ngày 🔥"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_home_streak_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Sáng nay bạn chưa hoàn thành Routine, bấm để bắt đầu!"
                            android:textColor="#DDDFC4"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="8dp"
                        android:contentDescription="@null"
                        android:scaleX="-1"
                        android:src="@drawable/ic_arrow_back_thin"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <include
                    android:id="@+id/quiz_test_weekly_reminder_layout"
                    layout="@layout/quiz_test_weekly_reminder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Featured Sunscreen Promo -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:background="#EFEFE8"
                android:paddingBottom="16dp">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelinePromoSplit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_begin="214dp" />

                <!-- Badge (trái) -->
                <LinearLayout
                    android:id="@+id/llPromoBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="@dimen/home_section_spacing"
                    android:background="@drawable/bg_pill_dark_olive"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_shield_verified"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="CHỐNG NẮNG PHỔ RỘNG"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Tiêu đề (phải, trên video) -->
                <TextView
                    android:id="@+id/tvPromoTitle1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="2"
                    android:text="Sữa chống nắng"
                    android:textAlignment="viewEnd"
                    android:textColor="#1B3E2D"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/guidelinePromoSplit"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvPromoTitle2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="-2dp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="2dp"
                    android:fontFamily="@font/mightype"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="bí đao"
                    android:textAlignment="viewEnd"
                    android:textColor="#3D684C"
                    android:textSize="26sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/guidelinePromoSplit"
                    app:layout_constraintTop_toBottomOf="@id/tvPromoTitle1" />

                <!-- Cột phải: video + nút, cao bằng 4 khung trái -->
                <LinearLayout
                    android:id="@+id/llPromoRightMedia"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="10dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/llPromoFeatures"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/guidelinePromoSplit"
                    app:layout_constraintTop_toBottomOf="@id/tvPromoTitle2">

                    <FrameLayout
                        android:id="@+id/flVideoContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">

                        <VideoView
                            android:id="@+id/vvPromoSunscreen"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/btnPromoSunscreen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_pill_dark_olive"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="7dp"
                        android:text="BẢO VỆ DA – TỰ TIN TỎA SÁNG"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 4 mục tính năng (trái) -->
                <LinearLayout
                    android:id="@+id/llPromoFeatures"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@id/guidelinePromoSplit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/llPromoRightMedia">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="7dp"
                        android:background="@drawable/bg_home_promo_sunscreen"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="9dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_shield_verified"
                            app:tint="#1B3E2D" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:text="Chống nắng phổ rộng"
                                android:textColor="#1B3E2D"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:lineSpacingExtra="2dp"
                                android:text="Bảo vệ da khỏi UVA/UVB &amp; ánh sáng xanh"
                                android:textColor="#4A564A"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="7dp"
                        android:background="@drawable/bg_home_promo_sunscreen"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="9dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_water_drop_outline"
                            app:tint="#1B3E2D" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:text="Chiết xuất bí đao thiên nhiên"
                                android:textColor="#1B3E2D"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:lineSpacingExtra="2dp"
                                android:text="Dịu mát, cấp ẩm &amp; hỗ trợ kiềm dầu"
                                android:textColor="#4A564A"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="7dp"
                        android:background="@drawable/bg_home_promo_sunscreen"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="9dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_circle_checked"
                            app:tint="#1B3E2D" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:text="Kết cấu nhẹ tênh – Không bết dính"
                                android:textColor="#1B3E2D"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:lineSpacingExtra="2dp"
                                android:text="Thấm nhanh, nâng tone tự nhiên"
                                android:textColor="#4A564A"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_promo_sunscreen"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="9dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_star"
                            app:tint="#1B3E2D" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:text="An toàn cho mọi loại da"
                                android:textColor="#1B3E2D"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:includeFontPadding="false"
                                android:lineSpacingExtra="2dp"
                                android:text="Kể cả da nhạy cảm"
                                android:textColor="#4A564A"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Công cụ ROOTIE Affiliate -->
            <LinearLayout
                android:id="@+id/sectionToolkit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:background="@drawable/home_bg_toolkit_section"
                android:elevation="1dp"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="14dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:id="@+id/btnToolkitHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:includeFontPadding="false"
                        android:text="@string/home_toolkit_title"
                        android:textColor="@color/primary"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="14dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_skin_chevron_right"
                        app:tint="@color/secondary" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvToolkit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHomeSloganMarquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:ellipsize="marquee"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:freezesText="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:text="@string/home_slogan_marquee"
                android:textColor="#3E4D44"
                android:textSize="30sp"
                android:textStyle="italic" />

            <!-- Shortcut Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:gravity="center_horizontal">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvShortcuts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />

                <ImageView
                    android:id="@+id/ivExpandShortcuts"
                    android:layout_width="48dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="@dimen/home_section_spacing"
                    android:src="@drawable/ic_arrow_doubledown"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <!-- Voucher Promo Section -->
            <LinearLayout
                android:id="@+id/sectionVouchers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="Ưu đãi mã giảm giá"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/home_section_title_size" />

                    <TextView
                        android:id="@+id/tvVoucherSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/be_vietnam_pro_regular"
                        android:text="Xem tất cả >"
                        android:textColor="#7A8B7B"
                        android:textSize="12sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvVoucherCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvVouchers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="16dp" />
            </LinearLayout>

            <!-- Recent Activity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:background="@drawable/bg_ombre_recent_activity"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_recent_activity"
                        android:textColor="#1B3E2D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRecentSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Xem tất cả ❯"
                        android:textColor="#4A5D4E"
                        android:textSize="12sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentActivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp" />
            </LinearLayout>

            <!-- Flash Sale V2 — flexible layout (no fixed bg image) -->
            <include
                android:id="@+id/flashsale_v2_section"
                layout="@layout/home_flashsale_v2_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:clipChildren="false"
                android:clipToPadding="false" />

            <!-- Lotus Essence Promo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvPromoLotus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/home_section_spacing"
                app:cardBackgroundColor="@color/neutral"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center"
                    android:baselineAligned="false">

                    <TextView
                        android:id="@+id/tvPromoLotusLeft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Tinh chất xịt dưỡng Sen Hậu Giang"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Center Images Stack -->
                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="180dp"
                            android:layout_weight="1.2">

                        <ImageView
                            android:id="@+id/ivPromoLotus3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen3"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/ivPromoLotus2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen2"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/ivPromoLotus1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen1"
                            android:scaleType="fitCenter" />
                    </FrameLayout>

                    <!-- Right Text -->
                    <LinearLayout
                        android:id="@+id/llPromoLotusRight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.7"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="Sản phẩm có kết cấu hai tầng dầu dưỡng và tinh chất hòa quyện, tạo nên những tia sương mịn nhẹ trên da. công thức kết hợp chiết xuất sen hữu cơ hậu giang, phức hợp prebiotics, squalane và các hoạt chất làm dịu giúp cấp ẩm sâu, tăng cường độ bóng khỏe tự nhiên, giúp bảo vệ hàng rào độ ẩm, ngăn ngừa và giảm thiểu tình trạng thoát nước qua da, hỗ trợ cân bằng hệ vi sinh cho da rất nhạy cảm."
                            android:textColor="@color/tertiary"
                            android:textSize="12sp"
                            android:textStyle="normal"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:id="@+id/btnPromoLotus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="MUA NGAY \u2192"
                            android:textColor="@color/primary"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Categories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_categories"
                    android:textColor="#1B3E2D"
                    android:textSize="17sp"
                    android:fontFamily="@font/be_vietnam_pro_bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <!-- Bestsellers & Top Search -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="4dp"
                    android:elevation="4dp"
                    android:background="@drawable/bg_home_bestseller_card"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/home_bestsellers"
                        android:textColor="#1B3E2D"
                        android:textSize="17sp"
                        android:fontFamily="@font/be_vietnam_pro_bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBestsellers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:background="@android:color/transparent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="4dp"
                    android:elevation="4dp"
                    android:background="@drawable/bg_home_bestseller_card"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/home_top_search"
                        android:textColor="#4A564A"
                        android:textSize="14sp"
                        android:fontFamily="@font/be_vietnam_pro_bolditalic" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTopSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- About Us Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/home_section_spacing"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:src="@drawable/about_us_home" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Về chúng tôi"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:lineSpacingExtra="4dp"
                        android:text="Tìm hiểu hành trình và giá trị\nmà chúng tôi theo đuổi."
                        android:textColor="@color/tertiary"
                        android:textSize="13sp"
                        android:textStyle="italic" />

                    <LinearLayout
                        android:id="@+id/btn_discover_about_us"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/home_section_spacing"
                        android:background="@drawable/bg_pill_dark_olive"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:includeFontPadding="false"
                            android:text="Tìm hiểu ngay"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginStart="6dp"
                            android:contentDescription="@null"
                            android:scaleX="-1"
                            android:src="@drawable/ic_arrow_back_thin"
                            app:tint="@color/white" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recommendations -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_recommendations"
                    android:textColor="#28362E"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="10dp" />

            <!-- Load More Button -->
            <LinearLayout
                android:id="@+id/btnLoadMoreRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="0dp"
                android:background="@drawable/bg_pill_green"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tiếp sản phẩm"
                    android:textColor="#02542D"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="#02542D" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp" />

</RelativeLayout>
