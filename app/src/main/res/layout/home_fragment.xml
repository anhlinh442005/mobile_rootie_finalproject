<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF4">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                layout="@layout/home_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Hero Banner Carousel -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpBanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipChildren="true"
                        android:clipToPadding="true"
                        />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/llBannerDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal" />
            </FrameLayout>

            <!-- Skincare Routine Banner Widget -->
            <LinearLayout
                android:id="@+id/cardHomeRoutineWidget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_streak_card_gradient"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_home_streak_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chuỗi chăm da của bạn: 0 ngày 🔥"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_home_streak_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sáng nay bạn chưa hoàn thành Routine, bấm để bắt đầu!"
                        android:textColor="#DDDFC4"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFFFFF"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <include
                android:id="@+id/quiz_test_weekly_reminder_layout"
                layout="@layout/quiz_test_weekly_reminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Featured Sunscreen Promo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="16dp"
                android:background="#E6ECE2"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_promo_sunscreen_subtitle"
                        android:textAllCaps="true"
                        android:textColor="#4D6A4F"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/home_promo_sunscreen_title"
                        android:textColor="#4D6A4F"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/home_promo_sunscreen_desc"
                        android:textColor="#4D6A4F"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/btnPromoSunscreen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_pill_green"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:text="@string/home_view_now"
                        android:textColor="#02542D"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <VideoView
                    android:id="@+id/vvPromoSunscreen"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:paddingEnd="10dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvHomeSloganMarquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:freezesText="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingVertical="16dp"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:text="@string/home_slogan_marquee"
                android:textColor="#3E4D44"
                android:textSize="30sp"
                android:textStyle="italic" />

            <!-- Shortcut Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:gravity="center_horizontal">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvShortcuts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />

                <ImageView
                    android:id="@+id/ivExpandShortcuts"
                    android:layout_width="48dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/ic_double_chevron_down"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <!-- Recent Activity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_ombre_recent_activity"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_recent_activity"
                        android:textColor="#28362E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRecentSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Xem tất cả ❯"
                        android:textColor="#4A5D4E"
                        android:textSize="12sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentActivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp" />
            </LinearLayout>

            <!-- Flash Sale Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/flFlashSaleContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivFlashsaleBg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:src="@drawable/homepage_flashsale_bg"/>

                <!-- The cards container -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintWidth_percent="0.85"
                    app:layout_constraintHeight_percent="0.51"
                    app:layout_constraintVertical_bias="0.59"
                    android:layout_marginTop="85dp"
                    android:layout_marginRight="4dp"
                    android:layout_gravity="center_horizontal"
                    app:layout_constraintTop_toTopOf="@id/ivFlashsaleBg"
                    app:layout_constraintBottom_toBottomOf="@id/ivFlashsaleBg"
                    app:layout_constraintStart_toStartOf="@id/ivFlashsaleBg"
                    app:layout_constraintEnd_toEndOf="@id/ivFlashsaleBg"
                    android:clipChildren="false">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFlashSale"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp" />
                </FrameLayout>

                <!-- Countdown and text -->
                <LinearLayout
                    android:id="@+id/llFlashSaleFooter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintVertical_bias="0.93"
                    app:layout_constraintTop_toTopOf="@id/ivFlashsaleBg"
                    app:layout_constraintBottom_toBottomOf="@id/ivFlashsaleBg"
                    app:layout_constraintStart_toStartOf="@id/ivFlashsaleBg"
                    app:layout_constraintEnd_toEndOf="@id/ivFlashsaleBg"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Timer boxes -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFlashHour"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_white_rounded_4dp"
                                android:fontFamily="@font/be_vietnam_pro_bold"
                                android:gravity="center"
                                android:text="00"
                                android:textColor="#3E4D44"
                                android:textSize="7sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro_regular"
                                android:text="Giờ"
                                android:textColor="@color/white"
                                android:textSize="7sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="2dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/be_vietnam_pro_bold"
                            android:text=":"
                            android:textColor="@color/white"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFlashMinute"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_white_rounded_4dp"
                                android:fontFamily="@font/be_vietnam_pro_bold"
                                android:gravity="center"
                                android:text="00"
                                android:textColor="#3E4D44"
                                android:textSize="7sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="0dp"
                                android:fontFamily="@font/be_vietnam_pro_regular"
                                android:text="Phút"
                                android:textColor="@color/white"
                                android:textSize="7sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="2dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/be_vietnam_pro_bold"
                            android:text=":"
                            android:textColor="@color/white"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFlashSecond"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_white_rounded_4dp"
                                android:fontFamily="@font/be_vietnam_pro_bold"
                                android:gravity="center"
                                android:text="00"
                                android:textColor="#3E4D44"
                                android:textSize="7sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro_regular"
                                android:text="Giây"
                                android:textColor="@color/white"
                                android:textSize="7sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Lotus Essence Promo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvPromoLotus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/neutral"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="26dp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <!-- Left Text -->
                    <TextView
                        android:id="@+id/tvPromoLotusLeft"
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.1"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Tinh chất\nxịt dưỡng\nSen Hậu Giang"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Center Images Stack -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="180dp"
                        android:layout_weight="1.2">

                        <ImageView
                            android:id="@+id/ivPromoLotus3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen3"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/ivPromoLotus2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen2"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/ivPromoLotus1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen1"
                            android:scaleType="fitCenter" />
                    </FrameLayout>

                    <!-- Right Text -->
                    <LinearLayout
                        android:id="@+id/llPromoLotusRight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.7"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="Sản phẩm có kết cấu hai tầng dầu dưỡng và tinh chất hòa quyện, tạo nên những tia sương mịn nhẹ trên da. công thức kết hợp chiết xuất sen hữu cơ hậu giang, phức hợp prebiotics, squalane và các hoạt chất làm dịu giúp cấp ẩm sâu, tăng cường độ bóng khỏe tự nhiên, giúp bảo vệ hàng rào độ ẩm, ngăn ngừa và giảm thiểu tình trạng thoát nước qua da, hỗ trợ cân bằng hệ vi sinh cho da rất nhạy cảm."
                            android:textColor="@color/tertiary"
                            android:textSize="7sp"
                            android:textStyle="normal"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:id="@+id/btnPromoLotus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="MUA NGAY \u2192"
                            android:textColor="@color/primary"
                            android:textSize="8sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Categories -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="@string/home_categories"
                    android:textColor="#28362E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategoriesSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/home_see_all"
                    android:textColor="@color/secondary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Bestsellers & Top Search -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="4dp"
                    android:elevation="4dp"
                    android:background="@drawable/bg_home_bestseller_card"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_bestsellers"
                            android:textColor="#4A564A"
                            android:textSize="10sp"
                            android:fontFamily="@font/be_vietnam_pro_bolditalic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Xem tất cả >"
                            android:textColor="#7A8B7B"
                            android:textSize="8sp"
                            android:fontFamily="@font/be_vietnam_pro_regular" />
                    </RelativeLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBestsellers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="4dp"
                    android:elevation="4dp"
                    android:background="@drawable/bg_home_bestseller_card"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_top_search"
                            android:textColor="#4A564A"
                            android:textSize="10sp"
                            android:fontFamily="@font/be_vietnam_pro_bolditalic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Xem tất cả >"
                            android:textColor="#7A8B7B"
                            android:textSize="8sp"
                            android:fontFamily="@font/be_vietnam_pro_regular" />
                    </RelativeLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTopSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- Recommendations -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_recommendations"
                    android:textColor="#28362E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRecommendationsSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/home_see_all"
                    android:textColor="@color/secondary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="16dp"
                android:paddingEnd="8dp" />

            <!-- About Us Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/about_us_home" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Về chúng tôi"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Tìm hiểu hành trình và giá trị\nmà chúng tôi theo đuổi."
                        android:textColor="@color/tertiary"
                        android:textSize="13sp"
                        android:textStyle="italic|normal"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:lineSpacingExtra="4dp" />

