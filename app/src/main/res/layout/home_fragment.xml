<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF4">

    <include
        android:id="@+id/home_header"
        layout="@layout/home_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/home_header"
        android:layout_above="@id/bottom_nav"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Banner Carousel -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpBanner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="true"
                        android:clipToPadding="true"
                        />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/llBannerDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal" />
            </FrameLayout>

            <!-- Skincare Routine Banner Widget -->
            <LinearLayout
                android:id="@+id/cardHomeRoutineWidget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_streak_card_gradient"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_home_streak_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chuỗi chăm da của bạn: 0 ngày 🔥"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_home_streak_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sáng nay bạn chưa hoàn thành Routine, bấm để bắt đầu!"
                        android:textColor="#DDDFC4"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFFFFF"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <include
                android:id="@+id/quiz_test_weekly_reminder_layout"
                layout="@layout/quiz_test_weekly_reminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Featured Sunscreen Promo -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#EFEFE8">

                <!-- Left Text Section -->
                <!-- Badge -->
                <LinearLayout
                    android:id="@+id/llPromoBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_dark_olive"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:gravity="center_vertical"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_shield_verified"
                        app:tint="#FFFFFF"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="CHỐNG NẮNG PHỔ RỘNG"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Titles -->
                <TextView
                    android:id="@+id/tvPromoTitle1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="16dp"
                    android:text="Sữa chống nắng"
                    android:textColor="#1B3E2D"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/flVideoContainer"
                    app:layout_constraintTop_toBottomOf="@id/llPromoBadge" />

                <TextView
                    android:id="@+id/tvPromoTitle2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="bí đao"
                    android:textColor="#3D684C"
                    android:textSize="44sp"
                    android:fontFamily="@font/mightype"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/flVideoContainer"
                    app:layout_constraintTop_toBottomOf="@id/tvPromoTitle1"
                    android:layout_marginTop="-16dp" />

                <TextView
                    android:id="@+id/tvPromoSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="16dp"
                    android:text="Bảo vệ da toàn diện – Thanh mát, nhẹ thoáng mỗi ngày"
                    android:textColor="#28362E"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/flVideoContainer"
                    app:layout_constraintTop_toBottomOf="@id/tvPromoTitle2"
                    android:layout_marginTop="-4dp" />

                <!-- Features -->
                <LinearLayout
                    android:id="@+id/llPromoFeatures"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/flVideoContainer"
                    app:layout_constraintTop_toBottomOf="@id/tvPromoSubtitle">

                    <!-- Feature 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_shield_verified"
                            app:tint="#1B3E2D"
                            android:contentDescription="@null" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chống nắng phổ rộng"
                                android:textColor="#1B3E2D"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bảo vệ da khỏi tia UVA/UVB &amp; ánh sáng xanh"
                                android:textColor="#4A564A"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Feature 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_water_drop_outline"
                            app:tint="#1B3E2D" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chiết xuất bí đao thiên nhiên"
                                android:textColor="#1B3E2D"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dịu mát, cấp ẩm &amp; hỗ trợ kiềm dầu"
                                android:textColor="#4A564A"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Feature 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_leaf"
                            app:tint="#1B3E2D" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kết cấu nhẹ tênh – Không bết dính"
                                android:textColor="#1B3E2D"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thấm nhanh, nâng tone tự nhiên"
                                android:textColor="#4A564A"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Feature 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_weather_sparkles"
                            app:tint="#1B3E2D" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="An toàn cho mọi loại da"
                                android:textColor="#1B3E2D"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kể cả da nhạy cảm"
                                android:textColor="#4A564A"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Button -->
                <TextView
                    android:id="@+id/btnPromoSunscreen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_pill_dark_olive"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:text="BẢO VỆ DA – TỰ TIN TỎA SÁNG ❯"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/llPromoFeatures"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <!-- Right Video Section -->
                <FrameLayout
                    android:id="@+id/flVideoContainer"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintWidth_percent="0.45"
                    app:layout_constraintDimensionRatio="H,9:16"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintVertical_bias="0.5">

                    <VideoView
                        android:id="@+id/vvPromoSunscreen"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tvHomeSloganMarquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:freezesText="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingVertical="16dp"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:text="@string/home_slogan_marquee"
                android:textColor="#3E4D44"
                android:textSize="30sp"
                android:textStyle="italic" />

            <!-- Shortcut Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:gravity="center_horizontal">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvShortcuts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />

                <ImageView
                    android:id="@+id/ivExpandShortcuts"
                    android:layout_width="48dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/ic_double_chevron_down"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <!-- Recent Activity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_ombre_recent_activity"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_recent_activity"
                        android:textColor="#28362E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRecentSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Xem tất cả ❯"
                        android:textColor="#4A5D4E"
                        android:textSize="12sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentActivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp" />
            </LinearLayout>

            <!-- Flash Sale Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/flFlashSaleContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivFlashsaleBg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:src="@drawable/homepage_flashsale_bg"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:contentDescription="@null" />

                <!-- The cards container -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintWidth_percent="0.85"
                    app:layout_constraintHeight_percent="0.51"
                    app:layout_constraintVertical_bias="0.59"
                    android:layout_marginTop="85dp"
                    android:layout_marginRight="4dp"
                    android:layout_gravity="center_horizontal"
                    app:layout_constraintTop_toTopOf="@id/ivFlashsaleBg"
                    app:layout_constraintBottom_toBottomOf="@id/ivFlashsaleBg"
                    app:layout_constraintStart_toStartOf="@id/ivFlashsaleBg"
                    app:layout_constraintEnd_toEndOf="@id/ivFlashsaleBg"
                    android:clipChildren="false">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFlashSale"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp" />
                </FrameLayout>

                <!-- Countdown and text -->
                <LinearLayout
                    android:id="@+id/llFlashSaleFooter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintVertical_bias="0.93"
                    app:layout_constraintTop_toTopOf="@id/ivFlashsaleBg"
                    app:layout_constraintBottom_toBottomOf="@id/ivFlashsaleBg"
                    app:layout_constraintStart_toStartOf="@id/ivFlashsaleBg"
                    app:layout_constraintEnd_toEndOf="@id/ivFlashsaleBg"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Timer boxes -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFlashHour"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_white_rounded_4dp"
                                android:fontFamily="@font/be_vietnam_pro_bold"
                                android:gravity="center"
                                android:text="00"
                                android:textColor="#3E4D44"
                                android:textSize="10sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro_regular"
                                android:text="Giờ"
                                android:textColor="@color/white"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="2dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/be_vietnam_pro_bold"
                            android:text=":"
                            android:textColor="@color/white"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFlashMinute"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_white_rounded_4dp"
                                android:fontFamily="@font/be_vietnam_pro_bold"
                                android:gravity="center"
                                android:text="00"
                                android:textColor="#3E4D44"
                                android:textSize="10sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="0dp"
                                android:fontFamily="@font/be_vietnam_pro_regular"
                                android:text="Phút"
                                android:textColor="@color/white"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="2dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/be_vietnam_pro_bold"
                            android:text=":"
                            android:textColor="@color/white"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFlashSecond"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_white_rounded_4dp"
                                android:fontFamily="@font/be_vietnam_pro_bold"
                                android:gravity="center"
                                android:text="00"
                                android:textColor="#3E4D44"
                                android:textSize="10sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/be_vietnam_pro_regular"
                                android:text="Giây"
                                android:textColor="@color/white"
                                android:textSize="10sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Lotus Essence Promo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvPromoLotus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/neutral"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="26dp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center"
                    android:baselineAligned="false">

                    <TextView
                        android:id="@+id/tvPromoLotusLeft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Tinh chất xịt dưỡng Sen Hậu Giang"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Center Images Stack -->
                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="180dp"
                            android:layout_weight="1.2">

                        <ImageView
                            android:id="@+id/ivPromoLotus3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen3"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/ivPromoLotus2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen2"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/ivPromoLotus1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/homepage_sen1"
                            android:scaleType="fitCenter" />
                    </FrameLayout>

                    <!-- Right Text -->
                    <LinearLayout
                        android:id="@+id/llPromoLotusRight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.7"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="Sản phẩm có kết cấu hai tầng dầu dưỡng và tinh chất hòa quyện, tạo nên những tia sương mịn nhẹ trên da. công thức kết hợp chiết xuất sen hữu cơ hậu giang, phức hợp prebiotics, squalane và các hoạt chất làm dịu giúp cấp ẩm sâu, tăng cường độ bóng khỏe tự nhiên, giúp bảo vệ hàng rào độ ẩm, ngăn ngừa và giảm thiểu tình trạng thoát nước qua da, hỗ trợ cân bằng hệ vi sinh cho da rất nhạy cảm."
                            android:textColor="@color/tertiary"
                            android:textSize="12sp"
                            android:textStyle="normal"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:id="@+id/btnPromoLotus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="MUA NGAY \u2192"
                            android:textColor="@color/primary"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Categories -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="@string/home_categories"
                    android:textColor="#28362E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategoriesSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/home_see_all"
                    android:textColor="@color/secondary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Bestsellers & Top Search -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="4dp"
                    android:elevation="4dp"
                    android:background="@drawable/bg_home_bestseller_card"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_bestsellers"
                            android:textColor="#4A564A"
                            android:textSize="14sp"
                            android:fontFamily="@font/be_vietnam_pro_bolditalic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Xem tất cả >"
                            android:textColor="#7A8B7B"
                            android:textSize="12sp"
                            android:fontFamily="@font/be_vietnam_pro_regular" />
                    </RelativeLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBestsellers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:background="@android:color/transparent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="4dp"
                    android:elevation="4dp"
                    android:background="@drawable/bg_home_bestseller_card"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_top_search"
                            android:textColor="#4A564A"
                            android:textSize="14sp"
                            android:fontFamily="@font/be_vietnam_pro_bolditalic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Xem tất cả >"
                            android:textColor="#7A8B7B"
                            android:textSize="12sp"
                            android:fontFamily="@font/be_vietnam_pro_regular" />
                    </RelativeLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTopSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- About Us Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/about_us_home" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Về chúng tôi"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro" />

                    <TextView
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Tìm hiểu hành trình và giá trị\nmà chúng tôi theo đuổi."
                        android:textColor="@color/tertiary"
                        android:textSize="13sp"
                        android:textStyle="italic|normal"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:lineSpacingExtra="4dp" />

                    <TextView
                        android:id="@+id/btn_discover_about_us"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_pill_dark_olive"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="10dp"
                        android:text="Khám phá ngay  "
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="@color/white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recommendations -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_recommendations"
                    android:textColor="#28362E"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="10dp" />

            <!-- Load More Button -->
            <LinearLayout
                android:id="@+id/btnLoadMoreRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_pill_green"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tiếp sản phẩm"
                    android:textColor="#02542D"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_chevron_down"
                    app:tint="#02542D" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
