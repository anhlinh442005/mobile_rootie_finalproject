<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/viewClickZone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay Gradient to make text readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@drawable/com_bg_gradient_bottom"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Big Heart for Double Tap Animation -->
    <ImageView
        android:id="@+id/ivBigHeart"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_heart_filled"
        app:tint="#E53935"
        android:visibility="invisible"
        android:layout_marginBottom="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Left Content: User and Caption -->
    <LinearLayout
        android:id="@+id/llLeftContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/llRightIcons"
        android:layout_marginBottom="76dp"> <!-- Leave space for bottom nav -->

        <TextView
            android:id="@+id/tvAuthorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:fontFamily="@font/be_vietnam_pro"
            android:textStyle="bold"
            tools:text="@Quynhthi_0503" />

        <TextView
            android:id="@+id/tvCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro"
            android:ellipsize="end"
            android:maxLines="3"
            tools:text="Cùng Thi skincare 7 bước cho da mặt nhạy cảm nhé..." />

        <TextView
            android:id="@+id/tvReadMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xem thêm"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Right Content: Icons -->
    <LinearLayout
        android:id="@+id/llRightIcons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingEnd="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="76dp">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|top"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">

                <ImageView
                    android:id="@+id/ivAuthorAvatarRight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:color/darker_gray" />
            </androidx.cardview.widget.CardView>

            <ImageView
                android:id="@+id/ivAddFollow"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="start|bottom"
                android:layout_marginStart="10dp"
                android:layout_marginBottom="9dp"
                android:src="@drawable/ic_plus"
                app:tint="@android:color/white"
                android:background="@drawable/com_bg_add_circle"
                android:padding="3dp" />
        </FrameLayout>

        <!-- Like -->
        <ImageView
            android:id="@+id/ivLike"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_heart_outline"
            app:tint="@android:color/white" />
        <TextView
            android:id="@+id/tvLikesCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            tools:text="100" />

        <!-- Comment -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_comment"
            app:tint="@android:color/white" />
        <TextView
            android:id="@+id/tvCommentsCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            tools:text="100" />

        <!-- Bookmark -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_bookmark"
            app:tint="@android:color/white" />
        <TextView
            android:id="@+id/tvBookmarkCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            tools:text="100" />

        <!-- Share -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_plane"
            app:tint="@android:color/white" />
        <TextView
            android:id="@+id/tvShareCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            tools:text="100" />

        <!-- Rotating Disc -->
        <androidx.cardview.widget.CardView
            android:id="@+id/ivDiscContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/nav_icon_color"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivDisc"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="8dp"
                android:scaleType="centerCrop"
                app:tint="@color/primary"
                android:src="@drawable/logo" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
