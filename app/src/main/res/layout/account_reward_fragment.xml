<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF4">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FAFAF4"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Đổi quà"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnNotification"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Thông báo"
            android:src="@drawable/ic_notification"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Accumulation Points Progress Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_points_card_gradient"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvPointsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Điểm tích lũy"
                        android:textColor="#DDDFC4"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Star Icon before Points Label (based on screenshot 1) -->
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:src="@drawable/ic_star_gold"
                        app:layout_constraintBottom_toBottomOf="@id/tvPointsLabel"
                        app:layout_constraintEnd_toStartOf="@id/tvPointsLabel"
                        app:layout_constraintTop_toTopOf="@id/tvPointsLabel"
                        app:tint="#DDDFC4" />

                    <TextView
                        android:id="@+id/tvCurrentPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPointsLabel"
                        tools:text="8,500" />

                    <TextView
                        android:id="@+id/tvPointsSuffix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="sans-serif"
                        android:text="Rootie"
                        android:textColor="#DDDFC4"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="@id/tvCurrentPoints"
                        app:layout_constraintStart_toEndOf="@id/tvCurrentPoints" />

                    <!-- Check-in Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckIn"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Điểm danh ›"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="12dp"
                        app:backgroundTint="#40000000"
                        app:cornerRadius="12dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Rank Labels -->
                    <TextView
                        android:id="@+id/tvCurrentRank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Hạng Bạc"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvCurrentPoints" />

                    <TextView
                        android:id="@+id/tvNextRankHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="56% đến Vàng"
                        android:textColor="#DDDFC4"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@id/tvCurrentRank"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/pbRankProgress"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="56"
                        android:progressDrawable="@drawable/bg_progress_white"
                        app:layout_constraintTop_toBottomOf="@id/tvCurrentRank" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Alert Warning Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_alert_warning"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_warning_red"
                    app:tint="#D97706" />

                <!-- Rich styling for bold "500 điểm" text is handled dynamically in Kotlin -->
                <TextView
                    android:id="@+id/tvAlertWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif"
                    android:text="Bạn có 500 điểm sắp hết hạn vào 30/11."
                    android:textColor="#B45309"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Tab Headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <!-- Tab Exchange (Đổi quà) -->
                <LinearLayout
                    android:id="@+id/btnTabExchange"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tabExchange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:text="Đổi quà"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/indicatorExchange"
                        android:layout_width="match_parent"
                        android:layout_height="2.5dp"
                        android:background="@color/primary"
                        android:visibility="visible" />
                </LinearLayout>

                <!-- Tab My Gifts (Quà của tôi) -->
                <LinearLayout
                    android:id="@+id/btnTabMyGifts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tabMyGifts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:text="Quà của tôi"
                        android:textColor="@color/gray_dark"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <View
                        android:id="@+id/indicatorMyGifts"
                        android:layout_width="match_parent"
                        android:layout_height="2.5dp"
                        android:background="@color/primary"
                        android:visibility="invisible" />
                </LinearLayout>

                <!-- Tab History (Lịch sử) -->
                <LinearLayout
                    android:id="@+id/btnTabHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tabHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="10dp"
                        android:text="Lịch sử"
                        android:textColor="@color/gray_dark"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <View
                        android:id="@+id/indicatorHistory"
                        android:layout_width="match_parent"
                        android:layout_height="2.5dp"
                        android:background="@color/primary"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <!-- TAB 1: Đổi quà layout -->
            <LinearLayout
                android:id="@+id/layoutExchangeTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Category Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <TextView
                            android:id="@+id/chipAllExchange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/tab_active_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp"
                            android:text="Tất cả"
                            android:textColor="@color/white"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipVoucherExchange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/tab_inactive_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp"
                            android:text="Voucher giảm giá"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipProductExchange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/tab_inactive_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp"
                            android:text="Sản phẩm"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipGiftExchange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/tab_inactive_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp"
                            android:text="Quà tặng"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Exchangeable Gifts Flat List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvExchangeGifts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_reward_gift" />

                <!-- Tip Banner at Bottom -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    app:cardBackgroundColor="#F7F9FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_location"
                            app:tint="#718096" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:fontFamily="sans-serif"
                            android:text="Mẹo: Điểm của bạn sẽ tự động cộng dồn và có hạn sử dụng 12 tháng kể từ ngày phát sinh giao dịch gần nhất."
                            android:textColor="#718096"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TAB 2: Quà của tôi layout -->
            <LinearLayout
                android:id="@+id/layoutMyGiftsTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Filter Chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/tab_active_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Tất cả"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipValid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/tab_inactive_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Còn hạn"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipExpired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tab_inactive_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Hết hạn"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Owned Gifts list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMyGifts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_reward_gift" />
            </LinearLayout>

            <!-- TAB 3: Lịch sử layout -->
            <LinearLayout
                android:id="@+id/layoutHistoryTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
