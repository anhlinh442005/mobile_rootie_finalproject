<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_step_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="top">

        <!-- Checkbox image (manual state toggle) -->
        <ImageView
            android:id="@+id/iv_step_checkbox"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="top"
            android:layout_marginTop="2dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_checkbox_checked"
            app:tint="@color/primary" />

        <!-- Step content container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <!-- Title & Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- Step number badge -->
                <TextView
                    android:id="@+id/tv_step_index"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_circle_icon"
                    android:backgroundTint="#DDDFC4"
                    android:gravity="center"
                    android:fontFamily="@font/lexend"
                    android:text="1"
                    android:textColor="#677559"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_step_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Sữa rửa mặt"
                    android:textColor="#3E4D44"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Product name -->
            <TextView
                android:id="@+id/tv_recommended_product"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:text="Sữa Rửa Mặt Sen Hậu Giang"
                android:textColor="#677559"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- AI Reason -->
            <TextView
                android:id="@+id/tv_ai_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:text="Tại sao phù hợp: Giúp làm sạch sâu bã nhờn vùng chữ T dịu nhẹ mà không gây kích ứng cho làn da dầu nhạy cảm của bạn."
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.2" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
