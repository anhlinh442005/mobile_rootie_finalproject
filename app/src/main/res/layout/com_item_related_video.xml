<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal"
    android:padding="4dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="140dp"
        android:layout_height="80dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivRelatedThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/tvRelatedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Title"
            android:textColor="#3E4D44"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRelatedChannel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Channel"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvRelatedStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="12,8k lượt xem • 3 tháng trước"
            android:textColor="#888888"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
