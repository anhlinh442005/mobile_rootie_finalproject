<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFCFA"
    android:focusableInTouchMode="true">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/llTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:background="#FCFCFA">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#3E4D44" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_white_rounded_corner_border"
            android:hint="Tìm kiếm cẩm nang, chăm da..."
            android:paddingHorizontal="12dp"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:textColorHint="#888888"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro"
            android:imeOptions="actionSearch"
            android:inputType="text"/>
            
        <TextView
            android:id="@+id/tvSearchBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tìm kiếm"
            android:textColor="#3E4D44"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:textSize="14sp"
            android:fontFamily="@font/be_vietnam_pro"/>
    </LinearLayout>

    <!-- State 1: Search Suggestions -->
    <ScrollView
        android:id="@+id/svSuggestions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/llTopBar"
        android:layout_above="@id/comBottomNav"
        android:paddingHorizontal="16dp"
        android:visibility="visible">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bạn có thể thích"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3E4D44"
                    android:fontFamily="@font/be_vietnam_pro"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↻ Làm mới"
                    android:layout_alignParentEnd="true"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:fontFamily="@font/be_vietnam_pro"/>
            </RelativeLayout>
            
            <!-- Trending Keywords List -->
            <LinearLayout
                android:id="@+id/llTrendingKeywords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- State 2: Search Results -->
    <LinearLayout
        android:id="@+id/llResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/llTopBar"
        android:layout_above="@id/comBottomNav"
        android:orientation="vertical"
        android:visibility="gone">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="16dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#3E4D44"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Xu hướng"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#EAF0E6"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Routine"
                        android:textColor="#677559"
                        android:textSize="12sp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"/>
                </com.google.android.material.card.MaterialCardView>
                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#EAF0E6"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Review"
                        android:textColor="#677559"
                        android:textSize="12sp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#EAF0E6"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Da dầu mụn"
                        android:textColor="#677559"
                        android:textSize="12sp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvExploreGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:clipToPadding="false"/>
    </LinearLayout>

    <!-- Bottom Navigation Component -->
    <include
        android:id="@+id/comBottomNav"
        layout="@layout/com_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />
</RelativeLayout>
