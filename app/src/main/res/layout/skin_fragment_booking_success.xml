<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Back Button -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="10dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Trở về" />

    <!-- Success Icon Container -->
    <FrameLayout
        android:id="@+id/success_icon_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_circle_grey"
        android:backgroundTint="@color/secondary"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            app:tint="@color/neutral" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/success_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Đã lưu lịch hẹn soi da"
        android:textColor="@color/secondary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/be_vietnam_pro"
        app:layout_constraintTop_toBottomOf="@id/success_icon_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/success_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:text="Lịch hẹn đã tạo thành công, bạn\nhãy sắp xếp đến đúng giờ nhé!"
        android:textColor="@color/tertiary"
        android:textSize="15sp"
        android:fontFamily="@font/be_vietnam_pro"
        app:layout_constraintTop_toBottomOf="@id/success_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Info Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="24dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/success_subtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/com_bg_popup_menu"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Row 0: Mã lịch hẹn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="Mã lịch hẹn"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/info_booking_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />
            </LinearLayout>

            <!-- Row 1: Chi nhánh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="Chi nhánh"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/info_store_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rootie Gò Vấp"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />
            </LinearLayout>

            <!-- Row 2: Ngày giờ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="Ngày giờ"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/info_date_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="25/05/2026 - 10:00"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />
            </LinearLayout>

            <!-- Row 3: Chuyên viên -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="Chuyên viên"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/info_specialist"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nguyễn Khánh Xuân"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />
            </LinearLayout>

            <!-- Row 4: Dịch vụ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="Dịch vụ"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />

                <TextView
                    android:id="@+id/info_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Soi da chuyên sâu"
                    android:textColor="@color/secondary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="@font/be_vietnam_pro" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Button -->
    <TextView
        android:id="@+id/btn_home"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/skin_bg_outline"
        android:gravity="center"
        android:text="Về trang chủ"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:fontFamily="@font/be_vietnam_pro"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
