<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/routine_icon"
            android:layout_width="40dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_routine_cleanser"
            android:tint="#C5B6A8" />

        <TextView
            android:id="@+id/routine_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:text="1. Sữa rửa mặt"
            android:textColor="@color/content"
            android:textSize="9sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/routine_arrow"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginHorizontal="6dp"
        android:src="@drawable/ic_arrow_next"
        android:tint="@color/content" />
</LinearLayout>