<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/branch_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Chọn chi nhánh"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/search_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/skin_bg_store_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/branch_header">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            app:tint="@color/primary" />

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@null"
            android:fontFamily="@font/be_vietnam_pro"
            android:hint="Tìm kiếm chi nhánh"
            android:textColor="@color/primary"
            android:textColorHint="@color/content"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Filters -->
    <HorizontalScrollView
        android:id="@+id/filter_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/search_container">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filter_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/skin_bg_btn_book"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Tất cả"
                android:textColor="@color/neutral"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/filter_hcm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/skin_bg_store_card"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Hồ Chí Minh"
                android:textColor="@color/primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/filter_hn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/skin_bg_store_card"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Hà Nội"
                android:textColor="@color/primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/filter_dn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_store_card"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Đà Nẵng"
                android:textColor="@color/primary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_branches"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll" />

    <!-- Tiếp tục Button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/neutral"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/skin_bg_btn_book"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:text="Tiếp tục"
            android:textColor="@color/neutral"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
