<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false">

    <!-- Hidden action buttons revealed on swipe left -->
    <LinearLayout
        android:id="@+id/layoutSwipeActions"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal">

        <!-- Mark as Read (green) -->
        <FrameLayout
            android:id="@+id/btnMarkReadAction"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:background="#4CAF50"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_circle_checked"
                app:tint="@color/white" />
        </FrameLayout>

        <!-- Delete (red) -->
        <FrameLayout
            android:id="@+id/btnDeleteAction"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:background="#F44336"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bin"
                app:tint="@color/white" />
        </FrameLayout>

    </LinearLayout>

    <!-- Foreground: notification content (slides left to reveal buttons) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- User Avatar -->
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/img_avatar"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Category badge icon -->
            <ImageView
                android:id="@+id/ivTypeBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/com_bg_post"
                android:backgroundTint="@color/white"
                android:padding="3dp"
                android:src="@drawable/ic_heart"
                app:tint="@color/primary"
                app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
                app:layout_constraintEnd_toEndOf="@id/ivAvatar" />

            <!-- Main Content Text -->
            <TextView
                android:id="@+id/tvContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/black"
                android:textSize="13.5sp"
                app:layout_constraintEnd_toStartOf="@id/viewUnreadDot"
                app:layout_constraintStart_toEndOf="@id/ivAvatar"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="&lt;b&gt;Mai Thy&lt;/b&gt; đã bình luận vào bài viết của bạn: 'Cảm ơn admin!'" />

            <!-- Time Label -->
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/gray_dark"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/tvContent"
                app:layout_constraintTop_toBottomOf="@id/tvContent"
                tools:text="14:32 • 15/06/2026" />

            <!-- Unread Dot Indicator -->
            <View
                android:id="@+id/viewUnreadDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/badge_dot"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
