<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Green checkmark icon -->
    <ImageView
        android:id="@+id/ivSuccessIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/ic_circle_checked"
        app:tint="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSuccessTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Đã gửi yêu cầu huỷ đơn"
        android:textColor="#3E4D44"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivSuccessIcon" />

    <TextView
        android:id="@+id/tvSuccessDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/be_vietnam_pro_regular"
        android:gravity="center"
        android:textColor="@color/gray_dark"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessTitle"
        tools:text="Yêu cầu huỷ đơn hàng #ORD-1511 của bạn đã được gửi thành công. Rootie sẽ xử lý yêu cầu trong thời gian sớm nhất." />

    <!-- Refund Info Card -->
    <LinearLayout
        android:id="@+id/llRefundInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_white_rounded_corner_border"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessDesc">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Thông tin hoàn tiền"
            android:textColor="#3E4D44"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

        <!-- Số tiền hoàn -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:text="Số tiền hoàn"
                android:textColor="@color/gray_dark"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvRefundAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                tools:text="775.000đ" />
        </LinearLayout>

        <!-- Phương thức hoàn tiền -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:text="Phương thức hoàn tiền"
                android:textColor="@color/gray_dark"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvRefundMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                tools:text="Ví RootiePay" />
        </LinearLayout>

        <!-- Thời gian dự kiến -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:text="Thời gian dự kiến"
                android:textColor="@color/gray_dark"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                android:text="1 - 3 ngày làm việc" />
        </LinearLayout>
    </LinearLayout>

    <!-- Notice Box -->
    <LinearLayout
        android:id="@+id/llNoticeBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_cart_voucher_bar"
        android:backgroundTint="#EDF3ED"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/llRefundInfo">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:gravity="center"
            android:text="Bạn có thể theo dõi trạng thái yêu cầu huỷ đơn trong mục Đơn hàng"
            android:textColor="@color/primary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Buttons at Bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTrackOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/primary"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Theo dõi đơn hàng"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoHome"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Về trang chủ"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            app:cornerRadius="12dp"
            app:strokeColor="@color/primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
