<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_header_gradient"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hệ thống cửa hàng"
            android:textColor="@color/primary"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Search Bar Mockup -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="1dp"
        app:layout_constraintTop_toBottomOf="@id/clToolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search_bar"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivSearchIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_search"
                app:tint="@color/gray_dark"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="Tìm cửa hàng theo địa chỉ"
                android:textColor="@color/gray_dark"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivFilterIcon"
                app:layout_constraintStart_toEndOf="@id/ivSearchIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivFilterIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_filter"
                app:tint="@color/gray_dark"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Map Area Layout -->
    <FrameLayout
        android:id="@+id/flMapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipChildren="true"
        android:clipToPadding="true"
        app:layout_constraintBottom_toTopOf="@id/clBottomPanel"
        app:layout_constraintTop_toBottomOf="@id/clSearchContainer">

        <!-- Zoomable Wrapper Container -->
        <FrameLayout
            android:id="@+id/flZoomableMapWrapper"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Map Image Background -->
            <ImageView
                android:id="@+id/ivMapBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_map_background" />

            <!-- Pins Overlay Layout (Using ConstraintLayout to position markers via bias) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clPinsOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Store Pin 1 -->
                <FrameLayout
                    android:id="@+id/pinStore1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_green"
                    android:backgroundTint="#2D3B32"
                    android:padding="8dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.4">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_store"
                        app:tint="@color/white" />
                </FrameLayout>

                <!-- Store Pin 2 -->
                <FrameLayout
                    android:id="@+id/pinStore2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_green"
                    android:backgroundTint="#2D3B32"
                    android:padding="8dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.7"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.3">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_store"
                        app:tint="@color/white" />
                </FrameLayout>

                <!-- Store Pin 3 -->
                <FrameLayout
                    android:id="@+id/pinStore3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_green"
                    android:backgroundTint="#2D3B32"
                    android:padding="8dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.8"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.6">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_store"
                        app:tint="@color/white" />
                </FrameLayout>

                <!-- Store Pin 4 -->
                <FrameLayout
                    android:id="@+id/pinStore4"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_green"
                    android:backgroundTint="#2D3B32"
                    android:padding="8dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.7">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_store"
                        app:tint="@color/white" />
                </FrameLayout>

                <!-- Store Pin 5 -->
                <FrameLayout
                    android:id="@+id/pinStore5"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_green"
                    android:backgroundTint="#2D3B32"
                    android:padding="8dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.8">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_store"
                        app:tint="@color/white" />
                </FrameLayout>

                <!-- Store Pin 6 -->
                <FrameLayout
                    android:id="@+id/pinStore6"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_green"
                    android:backgroundTint="#2D3B32"
                    android:padding="8dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.6"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.2">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_store"
                        app:tint="@color/white" />
                </FrameLayout>

                <!-- User Blue Location Dot -->
                <FrameLayout
                    android:id="@+id/pinUser"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.5">

                    <!-- Translucent outer glow -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_green"
                        android:backgroundTint="#402196F3" />

                    <!-- Solid blue center dot -->
                    <View
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_circle_green"
                        android:backgroundTint="#2196F3" />
                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>

        <!-- Use My Location Overlay Button (Image 2 style) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUseMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#2D3B32"
            android:text="Sử dụng vị trí hiện tại của tôi"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:textAllCaps="false"
            app:cornerRadius="23dp"
            app:icon="@drawable/ic_location"
            app:iconTint="@color/white"
            app:iconPadding="8dp" />

        <!-- Floating GPS Target FAB (Image 1 style) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnGpsTarget"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_location"
                app:tint="#2D3B32" />
        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Bottom sheet panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clBottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvCountLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Tìm kiếm 4 cửa hàng"
            android:textColor="@color/gray_dark"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/btnViewList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="Xem danh sách"
            android:textColor="@color/primary"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:textSize="14sp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Horizontal swipeable RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStoreCards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCountLabel" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Push Notification Overlay Slide-down Card (Image 4 style) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvNotificationBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Logo Rootie inside frame -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvNotiLogoFrame"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardBackgroundColor="#3E4D44"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:src="@drawable/ic_logo_rootie" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvNotiTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Ưu đãi gần bạn!"
                android:textColor="#3E4D44"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/cvNotiLogoFrame"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvNotiTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="vừa xong"
                android:textColor="@color/gray_dark"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:textSize="12sp"
                app:layout_constraintBaseline_toBaselineOf="@id/tvNotiTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvNotiMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="4dp"
                android:text="Bạn đang ở gần cửa hàng Rootie cơ sở 1, vào săn deal ngay!"
                android:textColor="#3E4D44"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/cvNotiLogoFrame"
                app:layout_constraintTop_toBottomOf="@id/tvNotiTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
