<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="16dp">

    <!-- Handle indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#D1D5DB"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tạo mới"
        android:fontFamily="@font/be_vietnam_pro"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#3E4D44"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- Item: Thước phim -->
    <LinearLayout
        android:id="@+id/llCreateReel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_reel_outline" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Thước phim"
            android:fontFamily="@font/be_vietnam_pro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E4D44" />
    </LinearLayout>
    
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" />

    <!-- Item: Bài viết -->
    <LinearLayout
        android:id="@+id/llCreateArticle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_article_outline"
            app:tint="@color/primary" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Bài viết"
            android:fontFamily="@font/be_vietnam_pro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E4D44" />
    </LinearLayout>
    
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" />

    <!-- Item: Tin -->
    <LinearLayout
        android:id="@+id/llCreateStory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_story_outline" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Tin"
            android:fontFamily="@font/be_vietnam_pro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E4D44" />
    </LinearLayout>
    
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" />

    <!-- Item: Tin nổi bật -->
    <LinearLayout
        android:id="@+id/llCreateHighlight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_circle_heart" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Tin nổi bật"
            android:fontFamily="@font/be_vietnam_pro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E4D44" />
    </LinearLayout>
    
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" />

    <!-- Item: Phát trực tiếp -->
    <LinearLayout
        android:id="@+id/llCreateLive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_live_outline" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Phát trực tiếp"
            android:fontFamily="@font/be_vietnam_pro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E4D44" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" />

    <!-- Item: AI -->
    <LinearLayout
        android:id="@+id/llCreateAi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_ai_outline"
            app:tint="@color/primary" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="AI"
            android:fontFamily="@font/be_vietnam_pro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E4D44" />
    </LinearLayout>

</LinearLayout>
