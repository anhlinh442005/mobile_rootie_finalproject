<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingTop="12dp"
    android:paddingBottom="24dp"
    android:paddingHorizontal="16dp">

    <!-- Drag Handle -->
    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="60dp"
        android:layout_height="10dp"
        android:src="@drawable/ic_dash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/be_vietnam_pro_semibold"
        android:text="Chọn cửa hàng nhận hàng"
        android:textColor="@color/primary"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dragHandle" />

    <!-- Store List Container -->
    <LinearLayout
        android:id="@+id/llStoreContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <!-- Store 1 Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clStore1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp">

            <!-- Radio Indicator -->
            <ImageView
                android:id="@+id/ivRadioStore1"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_circle_checked"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivRadioStore1"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvStoreName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend_medium"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:text="Cửa hàng mỹ phẩm Rootie - Cơ sở 1" />

                <TextView
                    android:id="@+id/tvStoreAddress1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/lexend_regular"
                    android:textColor="@color/gray_dark"
                    android:textSize="14sp"
                    android:text="235 Nguyễn Thị Minh Khai, P. Nguyễn Cư Trinh, Q.1, TP.HCM" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_light" />

        <!-- Store 2 Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clStore2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp">

            <!-- Radio Indicator -->
            <ImageView
                android:id="@+id/ivRadioStore2"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_circle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivRadioStore2"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvStoreName2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend_medium"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:text="Cửa hàng mỹ phẩm Rootie - Cơ sở 2" />

                <TextView
                    android:id="@+id/tvStoreAddress2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/lexend_regular"
                    android:textColor="@color/gray_dark"
                    android:textSize="14sp"
                    android:text="456 Hai Bà Trưng, P. Tân Định, Q.1, TP.HCM" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/llBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/llStoreContainer">

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmStore"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="@color/primary"
            android:fontFamily="@font/be_vietnam_pro_semibold"
            android:text="Xác nhận"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="10dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
