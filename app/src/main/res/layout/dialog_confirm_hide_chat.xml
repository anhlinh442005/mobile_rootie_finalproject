<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/neutral">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Mascot Avatar Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/primary_light"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/mascot_message"
                android:padding="8dp"
                android:scaleType="centerInside" />
        </androidx.cardview.widget.CardView>

        <!-- Title -->
        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ẩn Trợ lý Rootie AI?"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/lexend"
            android:layout_marginBottom="8dp" />

        <!-- Message -->
        <TextView
            android:id="@+id/dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bạn có chắc chắn muốn ẩn biểu tượng trợ lý nổi? Bạn có thể bật lại bất kỳ lúc nào trong phần cài đặt Tài khoản &amp; Bảo mật."
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:fontFamily="@font/lexend"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="24dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_dialog_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Hủy"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:background="@drawable/bg_dialog_btn_cancel" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_dialog_confirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Ẩn"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:background="@drawable/bg_dialog_btn_confirm" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
