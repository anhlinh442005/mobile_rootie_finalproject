<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/skin_bg_outline"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <!-- Phần Thông Tin Chính -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Cột Ngày -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:background="@drawable/skin_bg_store_card"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="20dp">

            <TextView
                android:id="@+id/tv_history_date_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="20"
                android:textColor="@color/black"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_history_month_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Tháng 5\nT.2"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Cột Chi Tiết -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp">

            <!-- Tên dịch vụ & Tag -->
            <LinearLayout
                android:id="@+id/ll_service_tag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_history_service_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Soi da cơ bản"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_history_status_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/skin_bg_btn_book"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Sắp diễn ra"
                    android:textColor="@color/white"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Thời gian -->
            <TextView
                android:id="@+id/tv_history_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/ll_service_tag"
                android:layout_marginTop="12dp"
                android:drawablePadding="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="10:00 - 10:45"
                android:textColor="@color/tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Địa điểm -->
            <TextView
                android:id="@+id/tv_history_store"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_history_time"
                android:layout_marginTop="12dp"
                android:drawablePadding="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Rootie Gò Vấp\n27 Quang Trung, P.10, Gò\nVấp, Tp. Hồ Chí Minh"
                android:textColor="@color/tertiary"
                android:textSize="11sp" />

            <!-- Mũi tên phải -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/tertiary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Nút hành động (chỉ hiện khi Sắp diễn ra) -->
    <LinearLayout
        android:id="@+id/ll_history_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/btn_view_detail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/skin_bg_outline"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Xem chi tiết"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_cancel_booking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@null"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Huỷ lịch"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
