<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white"
    app:cardMaxElevation="4dp"
    app:cardPreventCornerOverlap="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Content Area -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Date Block -->
            <LinearLayout
                android:id="@+id/ll_date_container"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_history_date_block"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tv_history_date_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:text="20"
                    android:textColor="@color/primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_history_month_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="Tháng 5\nT.2"
                    android:textColor="@color/content"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Service Name -->
            <TextView
                android:id="@+id/tv_history_service_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="Soi da cơ bản"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ll_date_container"
                app:layout_constraintEnd_toStartOf="@id/tv_history_status_tag"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Status Tag -->
            <TextView
                android:id="@+id/tv_history_status_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/skin_bg_badge_upcoming"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Sắp diễn ra"
                android:textColor="#1976D2"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Time -->
            <TextView
                android:id="@+id/tv_history_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:drawableStart="@drawable/ic_clock"
                android:drawablePadding="6dp"
                android:drawableTint="@color/content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="10:00 - 10:45"
                android:textColor="@color/content"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tv_history_service_name"
                app:layout_constraintEnd_toStartOf="@id/iv_chevron"
                app:layout_constraintTop_toBottomOf="@id/tv_history_service_name" />

            <!-- Store Location -->
            <TextView
                android:id="@+id/tv_history_store"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="8dp"
                android:drawableStart="@drawable/ic_location"
                android:drawablePadding="6dp"
                android:drawableTint="@color/tertiary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Rootie Gò Vấp\n27 Quang Trung, P.10, Gò Vấp, Tp. Hồ Chí Minh"
                android:textColor="@color/tertiary"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/tv_history_service_name"
                app:layout_constraintEnd_toStartOf="@id/iv_chevron"
                app:layout_constraintTop_toBottomOf="@id/tv_history_time" />

            <!-- Chevron Right -->
            <ImageView
                android:id="@+id/iv_chevron"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/tertiary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0" />

        <!-- Action Panel (only visible for upcoming/pending bookings) -->
        <LinearLayout
            android:id="@+id/ll_history_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="14dp"
            android:paddingTop="12dp"
            android:paddingHorizontal="16dp"
            android:background="#F9FAF9">

            <TextView
                android:id="@+id/btn_cancel_booking"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/skin_bg_btn_outline_red"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="Huỷ lịch"
                android:textColor="#C62828"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_view_detail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/skin_bg_btn_solid_dark"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="Xem chi tiết"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
