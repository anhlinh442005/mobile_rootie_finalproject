<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_container"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="24dp">

    <!-- Header: close + title -->
    <RelativeLayout
        android:id="@+id/headerRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnClose"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Thanh toán chuyển khoản"
            android:textColor="#3E4D44"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Đóng"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_cancel"
            app:tint="#677559" />
    </RelativeLayout>

    <!-- Bank / provider logo + name -->
    <LinearLayout
        android:id="@+id/bankRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerRow">

        <ImageView
            android:id="@+id/ivProviderLogo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_credit_card"
            app:tint="#3E4D44"
            tools:src="@drawable/ic_vnpay" />

        <TextView
            android:id="@+id/tvProviderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Ngân hàng TMCP Ngoại thương Việt Nam (Vietcombank)"
            android:textColor="#3E4D44"
            android:textSize="14sp"
            tools:text="Ngân hàng Vietcombank" />
    </LinearLayout>

    <!-- QR Code Card -->
    <LinearLayout
        android:id="@+id/qrCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_dialog_qr"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/bankRow">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Quét mã QR để thanh toán"
            android:textColor="#3E4D44"
            android:textSize="13sp" />

        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_qr_inner"
            android:padding="12dp">

            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Mã QR thanh toán"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:gravity="center"
            android:text="Sử dụng App ngân hàng hoặc Ví điện tử hỗ trợ VietQR để quét"
            android:textColor="#7E8A83"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Amount row -->
    <LinearLayout
        android:id="@+id/amountRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/qrCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_regular"
            android:text="Số tiền"
            android:textColor="#7E8A83"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="0đ"
            android:textColor="#B4202A"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="241.000đ" />
    </LinearLayout>

    <!-- Order code row with copy button -->
    <LinearLayout
        android:id="@+id/orderCodeRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_card_white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toBottomOf="@id/amountRow">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_regular"
                android:text="Nội dung chuyển khoản"
                android:textColor="#7E8A83"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvOrderCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:text="RDH..."
                android:textColor="#3E4D44"
                android:textSize="15sp"
                tools:text="RDH14062026184300" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnCopy"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Sao chép"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_content_copy" />
    </LinearLayout>

    <!-- Info chip -->
    <LinearLayout
        android:id="@+id/infoChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_info_chip_green"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/orderCodeRow">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_check"
            app:tint="#2E7D32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Đơn hàng sẽ tự động xác nhận sau khi nhận được chuyển khoản"
            android:textColor="#2E7D32"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Confirm button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmPayment"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/primary"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Kiểm tra thanh toán"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/infoChip" />

</androidx.constraintlayout.widget.ConstraintLayout>
