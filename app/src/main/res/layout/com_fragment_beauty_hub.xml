<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nsvHub"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="72dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ImageView
                            android:id="@+id/btnHome"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_home"
                            app:tint="@color/primary"
                            android:padding="6dp"
                            android:layout_marginEnd="8dp" />

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/mascot_hello" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Beauty Hub"
                            android:textColor="@color/primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivNotification"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/home_ic_notification"
                        app:tint="@color/primary"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Banner -->
                <ImageView
                    android:id="@+id/ivBanner"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/com_bg_card_rounded"
                    android:clipToOutline="true"
                    android:src="@drawable/img_beautyhub_banner"
                    tools:ignore="MissingPrefix" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/com_bg_shortcuts_container"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lối tắt của bạn"
                        android:textColor="@color/primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <LinearLayout
                            android:id="@+id/llShortcutNews"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/com_bg_card_rounded"
                            android:gravity="center_horizontal|top"
                            android:paddingTop="12dp"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_shortcut_news"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tin tức"
                                android:textColor="@color/primary"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/be_vietnam_pro" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llShortcutBlog"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/com_bg_card_rounded"
                            android:gravity="center_horizontal|top"
                            android:paddingTop="12dp"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_myskin"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Góc khoẻ\nđẹp"
                                android:gravity="center"
                                android:textColor="@color/primary"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/be_vietnam_pro" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llShortcutIngredient"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/com_bg_card_rounded"
                            android:gravity="center_horizontal|top"
                            android:paddingTop="12dp"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_leaf_ingredients"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thành phần"
                                android:textColor="@color/primary"
                                android:textSize="10sp"
                                android:textAlignment="center"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/be_vietnam_pro" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llShortcutHandbook"
                            android:layout_width="0dp"
                            android:layout_height="76dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/com_bg_card_rounded"
                            android:gravity="center_horizontal|top"
                            android:paddingTop="12dp"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_shortcut_handbook"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cẩm nang"
                                android:textColor="@color/primary"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/be_vietnam_pro" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Section: Popular Ingredients -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:paddingHorizontal="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thành phần phổ biến"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/be_vietnam_pro" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Xem tất cả &gt;&gt;"
                        android:textSize="12sp"
                        android:textColor="@color/secondary"
                        android:fontFamily="@font/be_vietnam_pro" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:clipToPadding="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/com_item_ingredient" />

                <!-- Section: Latest Knowledge (Blogs) -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:paddingHorizontal="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kiến thức mới nhất"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/be_vietnam_pro" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Xem tất cả &gt;&gt;"
                        android:textSize="12sp"
                        android:textColor="@color/secondary"
                        android:fontFamily="@font/be_vietnam_pro" />
                </RelativeLayout>

                <!-- Featured Blog -->
                <RelativeLayout
                    android:id="@+id/layoutFeaturedBlog"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="12dp">

                    <ImageView
                        android:id="@+id/ivFeaturedBlog"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_beautyhub_banner" />

                    <!-- Gradient overlay for text readability -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/com_bg_gradient_bottom" />
                        
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <TextView
                            android:id="@+id/tvFeaturedBlogTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nguyên nhân gây mụn trứng cá là gì? Cách xử lý như thế nào?"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:maxLines="2"
                            android:ellipsize="end" />
                            
                        <TextView
                            android:id="@+id/tvFeaturedBlogDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="30/4/2025 • Mụn trứng cá là tình trạng da liễu phổ biến thường gặp khi lỗ chân lông bị tắc nghẽn..."
                            android:textColor="#E0E0E0"
                            android:textSize="12sp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:layout_marginTop="4dp"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBlogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/com_item_latest_knowledge" />

                <!-- Section: Notebook (Cẩm nang chăm da) -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cẩm nang chăm da"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/be_vietnam_pro" />
                    <TextView
                        android:id="@+id/tvNotebookMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Sổ cẩm nang &gt;&gt;"
                        android:textSize="12sp"
                        android:textColor="@color/secondary"
                        android:fontFamily="@font/be_vietnam_pro" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNotebooks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:clipToPadding="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/com_item_notebook_video" />

                <Button
                    android:id="@+id/btnExploreFeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Khám phá bảng tin"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="24dp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <include
        android:id="@+id/com_bottom_nav"
        layout="@layout/com_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
