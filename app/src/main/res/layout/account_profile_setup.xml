                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="6dp"
                    android:text="CÀI ĐẶT ỨNG DỤNG"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <!-- Item: Cài đặt chat (Switch trực tiếp) -->
                    <RelativeLayout
                        android:id="@+id/btn_chat_settings"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@id/switch_chat_container"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bong bóng Trợ lý AI"
                                android:textColor="@color/primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Hiển thị bong bóng trợ lý AI nổi trên màn hình"
                                android:textColor="@color/gray_dark"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/switch_chat_container"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switch_chat_thumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_switch_thumb" />
                        </FrameLayout>
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- Item: Cài đặt thông báo (Mở trang chi tiết) -->
                    <RelativeLayout
                        android:id="@+id/btn_notification_settings"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Cài đặt thông báo"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#7E8A83" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- Item: Cài đặt riêng tư (Switch trực tiếp) -->
                    <RelativeLayout
                        android:id="@+id/btn_privacy_settings"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@id/switch_privacy_container"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chế độ riêng tư"
                                android:textColor="@color/primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Chỉ bạn bè mới xem được hoạt động da của bạn"
                                android:textColor="@color/gray_dark"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/switch_privacy_container"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switch_privacy_thumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_switch_thumb" />
                        </FrameLayout>
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- Item: Ngôn ngữ / Language (Xổ xuống trực tiếp) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:id="@+id/btn_language"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ngôn ngữ / Language"
                                    android:textColor="@color/primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/lexend" />

                                <TextView
                                    android:id="@+id/tv_current_language"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Tiếng Việt"
                                    android:textColor="@color/gray_dark"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/lexend" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/iv_language_chevron"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="#7E8A83" />
                        </RelativeLayout>

                        <!-- Expandable Language Options -->
                        <LinearLayout
                            android:id="@+id/expandable_language"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingBottom="12dp"
                            android:visibility="gone">

                            <RadioGroup
                                android:id="@+id/rg_language"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <RadioButton
                                    android:id="@+id/rb_lang_vi"
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:text="Tiếng Việt"
                                    android:textColor="@color/primary"
                                    android:textSize="13sp"
                                    android:checked="true"
                                    android:buttonTint="@color/primary"
                                    android:fontFamily="@font/lexend" />

                                <RadioButton
                                    android:id="@+id/rb_lang_en"
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:text="English"
                                    android:textColor="@color/primary"
                                    android:textSize="13sp"
                                    android:buttonTint="@color/primary"
                                    android:fontFamily="@font/lexend" />
                            </RadioGroup>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Group 3: Hỗ trợ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="6dp"
                    android:text="HỖ TRỢ &amp; ĐỒNG HÀNH"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <!-- Item: Trung tâm hỗ trợ -->
                    <RelativeLayout
                        android:id="@+id/btn_help_center"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Trung tâm hỗ trợ"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#7E8A83" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- Item: Tiêu chuẩn cộng đồng -->
                    <RelativeLayout
                        android:id="@+id/btn_community_guidelines"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Tiêu chuẩn cộng đồng"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#7E8A83" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E4E1" />

                    <!-- Item: Điều khoản Rootie -->
                    <RelativeLayout
                        android:id="@+id/btn_terms"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
