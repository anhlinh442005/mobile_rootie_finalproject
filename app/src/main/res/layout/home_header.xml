<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/home_header"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_gradient_header"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="6dp"
    android:paddingEnd="12dp"
    android:paddingBottom="6dp"
    android:elevation="8dp">

    <ImageView
        android:id="@+id/home_header_logo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/imv_logo" />

    <LinearLayout
        android:id="@+id/home_header_search_bar"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_weight="1"
        android:background="@drawable/home_bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <ImageView
            android:id="@+id/home_header_search_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_search"
            android:tint="@color/primary" />

        <TextView
            android:id="@+id/home_header_search_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/home_search_hint"
            android:textAppearance="@style/TextAppearance.Rootie.Content"
            android:textColor="@color/tertiary"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/home_header_qr_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_qrscan" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/home_header_cart_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_cart"
            android:tint="@color/primary" />

        <TextView
            android:id="@+id/home_header_cart_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="0dp"
            android:layout_marginEnd="0dp"
            android:background="@drawable/home_bg_notification_badge"
            android:gravity="center"
            android:minWidth="14dp"
            android:minHeight="14dp"
            android:paddingHorizontal="2dp"
            android:textColor="@color/white"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <include
        android:id="@+id/home_header_notification_btn"
        layout="@layout/include_notification_bell"
        android:layout_width="36dp"
        android:layout_height="36dp" />
</LinearLayout>
