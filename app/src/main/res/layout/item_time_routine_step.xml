<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp">

        <!-- Left Icon Container -->
        <FrameLayout
            android:id="@+id/layoutIconContainer"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/skin_bg_circle_grey"
            android:backgroundTint="#EEEFEC"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivStepIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_water_drop_outline"
                app:tint="#3E4D44" />
        </FrameLayout>

        <!-- Middle Text Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/layoutTimeBadge"
            app:layout_constraintStart_toEndOf="@+id/layoutIconContainer"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvStepName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:text="Sữa rửa mặt"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStepDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/lexend"
                android:text="Làm sạch nhẹ nhàng bụi bẩn"
                android:textColor="#97A49C"
                android:textSize="12sp"
                android:ellipsize="end"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvViewProductLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/lexend"
                android:text="🛒 Xem sản phẩm gợi ý"
                android:textColor="#38A169"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Time Badge Container -->
        <LinearLayout
            android:id="@+id/layoutTimeBadge"
            android:layout_width="wrap_content"
            android:layout_height="23dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/skin_bg_circle_grey"
            android:backgroundTint="#25B0A8A8"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ivCheckbox"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_clock"
                app:tint="#3E4D44"
                android:layout_marginEnd="3dp"/>

            <TextView
                android:id="@+id/tvStepTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="2p"
                android:textColor="#3E4D44"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right Checkbox Circle -->
        <ImageView
            android:id="@+id/ivCheckbox"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_circle"
            app:tint="#D9D9D9"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
