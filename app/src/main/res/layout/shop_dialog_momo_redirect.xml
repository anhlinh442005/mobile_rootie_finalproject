<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_container"
    android:paddingHorizontal="20dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <!-- Close -->
    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="Đóng"
        android:focusable="true"
        android:padding="6dp"
        android:src="@drawable/ic_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#677559" />

    <!-- MoMo rotating ring + inner pink circle + MoMo icon -->
    <FrameLayout
        android:id="@+id/ringContainer"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnClose">

        <ImageView
            android:id="@+id/ivRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Đang xử lý"
            android:src="@drawable/bg_momo_rotating_ring" />

        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_momo_pink_inner">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:contentDescription="MoMo"
                android:src="@drawable/ic_momo" />
        </FrameLayout>
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:gravity="center"
        android:text="Đang chuyển hướng sang ứng dụng MoMo..."
        android:textColor="#3E4D44"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ringContainer" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/be_vietnam_pro_regular"
        android:gravity="center"
        android:text="Vui lòng không đóng cửa sổ này cho đến khi giao dịch hoàn tất."
        android:textColor="#7E8A83"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- Order info chip -->
    <LinearLayout
        android:id="@+id/orderCodeRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_info_chip_green"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_check"
            app:tint="#2E7D32" />

        <TextView
            android:id="@+id/tvOrderCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Mã đơn: RDH..."
            android:textColor="#2E7D32"
            android:textSize="12sp"
            tools:text="Mã đơn: RDH14062026184300" />
    </LinearLayout>

    <!-- Confirm button (hidden until 2s elapsed) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmPayment"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/primary"
        android:enabled="false"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:text="Đang chờ mở MoMo..."
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/orderCodeRow" />

</androidx.constraintlayout.widget.ConstraintLayout>
