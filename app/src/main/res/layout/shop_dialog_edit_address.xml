<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@drawable/bg_dialog_container"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:fontFamily="@font/lexend"
            android:text="Chỉnh sửa địa chỉ"
            android:textColor="#02542D"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Recipient Name Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/lexend"
        android:text="Họ và tên người nhận"
        android:textColor="#677559"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Recipient Name Input -->
    <EditText
        android:id="@+id/et_dialog_name"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_dialog_input"
        android:fontFamily="@font/lexend"
        android:inputType="textPersonName"
        android:paddingHorizontal="12dp"
        android:textColor="#000000"
        android:textSize="14sp" />

    <!-- Phone Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/lexend"
        android:text="Số điện thoại"
        android:textColor="#677559"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Phone Input -->
    <EditText
        android:id="@+id/et_dialog_phone"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_dialog_input"
        android:fontFamily="@font/lexend"
        android:inputType="phone"
        android:paddingHorizontal="12dp"
        android:textColor="#000000"
        android:textSize="14sp" />

    <!-- Address Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/lexend"
        android:text="Địa chỉ giao hàng"
        android:textColor="#677559"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Address Input -->
    <EditText
        android:id="@+id/et_dialog_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_dialog_input"
        android:fontFamily="@font/lexend"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:minHeight="80dp"
        android:padding="12dp"
        android:textColor="#000000"
        android:textSize="14sp" />

    <!-- Default Address Toggle Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/lexend"
            android:text="Đặt làm địa chỉ mặc định"
            android:textColor="#677559"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_dialog_default"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbTint="@color/white"
            app:trackTint="@color/gray_light" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Cancel Button -->
        <FrameLayout
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_outlined"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/lexend"
                android:text="Hủy"
                android:textColor="#02542D"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Save Button -->
        <FrameLayout
            android:id="@+id/btn_dialog_save"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_solid"
            android:backgroundTint="#375633"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/lexend"
                android:text="Lưu"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

</LinearLayout>
