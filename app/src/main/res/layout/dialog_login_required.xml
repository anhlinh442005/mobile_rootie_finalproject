<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="#FEFBF4"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- Close Button (X) at top right -->
        <ImageView
            android:id="@+id/btnCancelLogin"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_circle_icon"
            android:backgroundTint="#FFFFFF"
            android:padding="8dp"
            app:tint="#6B7280"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Lock Image -->
        <ImageView
            android:id="@+id/ivLock"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/ic_lockerror"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng nhập để tiếp tục"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#3E4D44"
            android:fontFamily="@font/lexend"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/ivLock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Message -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tính năng này chỉ dành cho thành viên của Rootie. Đăng nhập để trải nghiệm đầy đủ các tính năng nhé!"
            android:textSize="14sp"
            android:textColor="#5C6860"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.25"
            android:fontFamily="@font/be_vietnam_pro"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Login Button -->
        <LinearLayout
            android:id="@+id/btnConfirmLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_btn_pill_solid"
            android:backgroundTint="#3E4D44"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tvMessage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ĐĂNG NHẬP"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/lexend"
                android:letterSpacing="0.03" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
