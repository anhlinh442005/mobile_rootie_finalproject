<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/com_bg_post"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="Thêm tài khoản"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etBankName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/com_bg_btn_outline"
        android:fontFamily="@font/be_vietnam_pro"
        android:hint="Ngân hàng (ví dụ: Vietcombank)"
        android:padding="12dp"
        android:textColor="@color/black"
        android:textColorHint="@color/gray_dark"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etAccountHolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/com_bg_btn_outline"
        android:fontFamily="@font/be_vietnam_pro"
        android:hint="Tên chủ tài khoản"
        android:padding="12dp"
        android:textColor="@color/black"
        android:textColorHint="@color/gray_dark"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etAccountNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/com_bg_btn_outline"
        android:fontFamily="@font/be_vietnam_pro"
        android:hint="Số tài khoản"
        android:padding="12dp"
        android:textColor="@color/black"
        android:textColorHint="@color/gray_dark"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Hủy"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Thêm"
            android:textColor="#56694E"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
