<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:id="@+id/skin_scan_result_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/skin_scan_result_btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="Kết quả phân tích da"
                android:textColor="@color/primary"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="AI soi da"
                android:textColor="@color/content"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/skin_scan_btn_top_history"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/skin_bg_card_outline"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_skin_history"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Lịch sử"
                android:textColor="@color/primary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/skin_scan_result_bottom_bar"
        app:layout_constraintTop_toBottomOf="@id/skin_scan_result_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- TOP SECTION: Score and Image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <!-- Left: Score Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Điểm da của bạn"
                        android:textColor="@color/content"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/skin_result_score_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/be_vietnam_pro_bold"
                            android:includeFontPadding="false"
                            android:text="78"
                            android:textColor="@color/primary"
                            android:textSize="48sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="/100"
                            android:textColor="@color/primary"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/skin_result_score_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="Da tốt"
                        android:textColor="@color/secondary"
                        android:textSize="14sp" />

                    <!-- Progress Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/skin_bg_badge_grey"
                        android:clipToOutline="true"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/skin_result_progress_fill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.78"
                            android:background="#677559" />

                        <View
                            android:id="@+id/skin_result_progress_empty"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.22"
                            android:background="#E6EBE6" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/skin_result_summary_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:lineSpacingExtra="2dp"
                        android:text="Làn da của bạn đang ở trạng thái tốt. Hãy duy trì chăm sóc da đều đặn để đạt kết quả tốt hơn!"
                        android:textColor="@color/content"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Right: Image -->
                <RelativeLayout
                    android:layout_width="160dp"
                    android:layout_height="180dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/skin_result_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/about_us_pd" />

                        <!-- Focus brackets overlay -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="10dp"
                            android:src="@drawable/ic_qrscan"
                            app:tint="#80FFFFFF" />
                    </androidx.cardview.widget.CardView>

                    <!-- Date Tag -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:layout_marginBottom="-12dp"
                        android:background="@drawable/skin_bg_card_outline"
                        android:backgroundTint="@color/white"
                        android:elevation="2dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/primary" />

                        <TextView
                            android:id="@+id/skin_result_date_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="24/05/2024 - 09:30"
                            android:textColor="@color/content"
                            android:textSize="10sp" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- MIDDLE SECTION: Radar Chart & Metrics List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <!-- Left Card: ĐÁNH GIÁ CHI TIẾT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:background="@drawable/skin_bg_card_outline"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/be_vietnam_pro_bold"
                            android:text="ĐÁNH GIÁ CHI TIẾT"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_article_outline"
                            app:tint="@color/content" />
                    </RelativeLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="8dp">
                        <com.github.mikephil.charting.charts.RadarChart
                            android:id="@+id/skin_result_radar_chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">
                        <View
                            android:layout_width="16dp"
                            android:layout_height="2dp"
                            android:background="@color/primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="Kết quả của bạn"
                            android:textColor="@color/content"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:text="- - Trung bình"
                            android:textColor="@color/content"
                            android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <!-- Right Card: GIẢI THÍCH KẾT QUẢ -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.3"
                    android:background="@drawable/skin_bg_card_outline"
                    android:backgroundTint="#FAFAF4"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="GIẢI THÍCH KẾT QUẢ"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/skin_result_metrics_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Metrics items populated dynamically -->
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- TÌNH TRẠNG DA SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/skin_bg_card_outline"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="TÌNH TRẠNG DA"
                        android:textColor="@color/secondary"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/skin_result_btn_view_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Xem chi tiết >"
                        android:textColor="@color/content"
                        android:textSize="11sp" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/skin_result_attributes_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">
                    <!-- Attributes populated dynamically -->
                </LinearLayout>
            </LinearLayout>

            <!-- GỢI Ý CHO BẠN SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/skin_bg_card_outline"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:text="GỢI Ý CHO BẠN"
                    android:textColor="@color/secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/skin_result_suggestions_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">
                        <!-- Bullets populated dynamically -->
                    </LinearLayout>

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/about_us_pd" /> <!-- Placeholder for illustration -->
                </LinearLayout>
            </LinearLayout>

            <!-- GỢI Ý QUY TRÌNH CHĂM SÓC -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/skin_bg_card_outline"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="GỢI Ý QUY TRÌNH CHĂM SÓC"
                        android:textColor="@color/secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/skin_bg_card_outline"
                            android:backgroundTint="#F4F5F7"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp">
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_sun_outline"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:fontFamily="@font/be_vietnam_pro_bold"
                                android:text="Buổi sáng"
                                android:textColor="@color/primary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/skin_bg_card_outline"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp">
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_moon_outline"
                                app:tint="@color/content" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:text="Buổi tối"
                                android:textColor="@color/content"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/skin_result_routine_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <!-- Routine items populated dynamically -->
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM BAR ===== -->
    <LinearLayout
        android:id="@+id/skin_scan_result_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/skin_result_btn_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/skin_bg_card_outline"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:gravity="center"
            android:text="Lưu kết quả"
            android:textColor="@color/primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/skin_result_btn_history_bottom"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/skin_bg_btn_solid_dark"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:gravity="center"
            android:text="Xem lịch sử"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
