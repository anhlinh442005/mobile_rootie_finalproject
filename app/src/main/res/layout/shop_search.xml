<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/neutral">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:background="@color/neutral">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/content" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@null"
                android:hint="Tìm kiếm sản phẩm"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/primary"
                android:textColorHint="@color/gray_dark"
                android:textSize="14sp" 
                android:fontFamily="@font/lexend"/>

            <ImageView
                android:id="@+id/btnClear"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:visibility="gone"
                android:padding="2dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@drawable/bg_circle_grey"
                app:tint="@color/content" />
        </LinearLayout>

        <!-- Placeholder cho QR Scan icon -->
        <ImageView
            android:id="@+id/btnScanQr"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="@color/primary" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Default Content -->
            <LinearLayout
                android:id="@+id/llDefaultContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Banner -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:src="@android:color/darker_gray" />

            <!-- Tra cứu hàng đầu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tra cứu hàng đầu"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" 
                    android:fontFamily="@font/be_vietnam_pro_bold"/>

                <!-- Mock Chips Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_search"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Chống nắng"
                        android:textColor="@color/primary"
                        android:textSize="13sp" 
                        android:fontFamily="@font/lexend"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_search"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Chống nắng"
                        android:textColor="@color/primary"
                        android:textSize="13sp" 
                        android:fontFamily="@font/lexend"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_search"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Tẩy trang"
                        android:textColor="@color/primary"
                        android:textSize="13sp" 
                        android:fontFamily="@font/lexend"/>
                </LinearLayout>

                <!-- Mock Chips Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_search"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Chống nắng"
                        android:textColor="@color/primary"
                        android:textSize="13sp" 
                        android:fontFamily="@font/lexend"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_search"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Chống nắng"
                        android:textColor="@color/primary"
                        android:textSize="13sp" 
                        android:fontFamily="@font/lexend"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_search"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="Chống nắng"
                        android:textColor="@color/primary"
                        android:textSize="13sp" 
                        android:fontFamily="@font/lexend"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Ưu đãi hot hôm nay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_hot_deals_outer"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Ưu đãi hot hôm nay"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" 
                    android:fontFamily="@font/be_vietnam_pro_bold"/>

                <!-- Inner White Container for list -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_hot_deals_inner"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvHotDeals"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/shop_item_product_horizontal"
                        tools:itemCount="3"/>

                </LinearLayout>

            </LinearLayout>
            
            </LinearLayout>

            <!-- Search Suggestions -->
            <LinearLayout
                android:id="@+id/llSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvKeywordSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="4dp"
                    android:background="@color/gray_light" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategorySuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="4dp"
                    android:background="@color/gray_light" />
            </LinearLayout>

            <!-- Search Results RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingTop="12dp"
                android:paddingBottom="24dp"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/shop_item_product_horizontal" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
