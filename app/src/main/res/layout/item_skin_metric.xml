<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="16dp">

    <FrameLayout
        android:id="@+id/metric_icon_container"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_circle_secondary"
        android:layout_marginEnd="12dp">
        <ImageView
            android:id="@+id/metric_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_skin_moisture"
            android:tint="@color/white" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/metric_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="Độ ẩm"
                android:textColor="@color/primary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/metric_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/skin_bg_pill_grey"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Trung bình"
                android:textColor="#5155C3"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/metric_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Da bạn cần bổ sung độ ẩm để mịn màng và căng mọng hơn."
            android:textColor="@color/content"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>
</LinearLayout>