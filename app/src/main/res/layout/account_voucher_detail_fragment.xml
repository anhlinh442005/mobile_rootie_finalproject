<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FEFBF4"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#02542D" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend"
            android:text="Chi tiết voucher"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnShare"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Chia sẻ"
                android:src="@drawable/ic_plane"
                app:tint="#02542D" />

            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Xoá voucher"
                android:src="@drawable/ic_bin"
                app:tint="#02542D" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/layoutButtons"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Ticket Card View -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutTicketContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTicket"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_points_card_gradient"
                        android:paddingVertical="32dp"
                        android:paddingHorizontal="24dp">

                        <ImageView
                            android:id="@+id/ivVoucherIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_voucher"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvVoucherTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/lexend"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@id/guidelineDivider"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/ivVoucherIcon"
                            tools:text="Giảm 50%" />

                        <TextView
                            android:id="@+id/tvVoucherSubtitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/lexend"
                            android:textColor="#E0E0E0"
                            android:textSize="14sp"
                            app:layout_constraintEnd_toStartOf="@id/guidelineDivider"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvVoucherTitle"
                            tools:text="Tối đa 100k" />

                        <!-- Vertical Dashed Separator Line -->
                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/guidelineDivider"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.80" />

                        <View
                            android:id="@+id/viewDashedLine"
                            android:layout_width="2dp"
                            android:layout_height="0dp"
                            android:background="@drawable/dashed_line_vertical"
                            android:layerType="software"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="@id/guidelineDivider"
                            app:layout_constraintEnd_toEndOf="@id/guidelineDivider" />

                        <!-- Decorative circles inside ticket -->
                        <View
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:background="@drawable/bg_dialog_btn_confirm"
                            android:backgroundTint="#20FFFFFF"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toEndOf="@id/guidelineDivider" />

                        <View
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:background="@drawable/bg_dialog_btn_confirm"
                            android:backgroundTint="#20FFFFFF"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/guidelineDivider" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Guideline at 80% to align cutouts and dashed line -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineTicketCutout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.80" />

                <!-- Top Circle Cutout -->
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/com_bg_post"
                    app:layout_constraintTop_toTopOf="@id/cardTicket"
                    app:layout_constraintBottom_toTopOf="@id/cardTicket"
                    app:layout_constraintStart_toStartOf="@id/guidelineTicketCutout"
                    app:layout_constraintEnd_toEndOf="@id/guidelineTicketCutout" />

                <!-- Bottom Circle Cutout -->
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/com_bg_post"
                    app:layout_constraintTop_toBottomOf="@id/cardTicket"
                    app:layout_constraintBottom_toBottomOf="@id/cardTicket"
                    app:layout_constraintStart_toStartOf="@id/guidelineTicketCutout"
                    app:layout_constraintEnd_toEndOf="@id/guidelineTicketCutout" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Description Block -->
            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:textColor="#1A202C"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Giảm 50% cho đơn hàng đầu tiên" />

            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/lexend"
                android:textColor="#4A5568"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.2"
                tools:text="Áp dụng cho tất cả các sản phẩm làm đẹp từ thiên nhiên. Tối đa giảm 100.000 VNĐ cho mỗi khách hàng." />

            <!-- Voucher Code Container -->
            <LinearLayout
                android:id="@+id/layoutCodeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_white_rounded_corner_border"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:id="@+id/tvVoucherCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/lexend"
                    android:textColor="#1A202C"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="SAVE50K" />

                <TextView
                    android:id="@+id/btnCopyCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/lexend"
                    android:text="Copy"
                    android:textColor="#3182CE"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Condition Header Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/lexend"
                android:text="Điều kiện sử dụng"
                android:textColor="#1A202C"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Condition Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Cond 1: Min Order -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            app:tint="#556348" />

                        <TextView
                            android:id="@+id/tvCondMinOrder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/lexend"
                            android:textColor="#4A5568"
                            android:textSize="13sp"
                            tools:text="Áp dụng cho đơn hàng từ 200.000 VNĐ." />
                    </LinearLayout>

                    <!-- Cond 2: Usage Limit -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            app:tint="#556348" />

                        <TextView
                            android:id="@+id/tvCondUsage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/lexend"
                            android:text="Mỗi tài khoản chỉ được sử dụng 1 lần."
                            android:textColor="#4A5568"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Cond 3: Others -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            app:tint="#556348" />

                        <TextView
                            android:id="@+id/tvCondOthers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/lexend"
                            android:text="Không áp dụng cùng các chương trình khuyến mãi khác."
                            android:textColor="#4A5568"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Table Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Hạn sử dụng -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:paddingHorizontal="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:text="Hạn sử dụng"
                            android:textColor="#718096"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvInfoExpiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:textColor="#1A202C"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="31/12/2024" />
                    </RelativeLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E8F0" />

                    <!-- Còn ngày -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:paddingHorizontal="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:text="Còn ngày"
                            android:textColor="#718096"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvInfoRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:textColor="#7A9161"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="15 ngày" />
                    </RelativeLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E8F0" />

                    <!-- Trạng thái -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:paddingHorizontal="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:text="Trạng thái"
                            android:textColor="#718096"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvInfoStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:textColor="#1A202C"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Có hiệu lực" />
                    </RelativeLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E8F0" />

                    <!-- Lần dùng -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:paddingHorizontal="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:text="Lần dùng"
                            android:textColor="#718096"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvInfoUsage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:textColor="#1A202C"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="0/1" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FEFBF4"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUseNow"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:fontFamily="@font/lexend"
            android:text="Sử dụng ngay"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#2D3A34"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareVoucher"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/lexend"
            android:text="Chia sẻ voucher"
            android:textColor="#2D3A34"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="#2D3A34" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
