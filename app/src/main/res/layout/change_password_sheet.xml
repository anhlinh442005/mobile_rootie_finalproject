<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg_sheet"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/com_bg_post"
            android:backgroundTint="@color/neutral" />

        <!-- Form đổi mật khẩu -->
        <LinearLayout
            android:id="@+id/cp_form_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Đổi mật khẩu"
                android:textColor="@color/neutral"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:alpha="0.8"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Nhập mật khẩu hiện tại và mật khẩu mới để cập nhật"
                android:textColor="@color/neutral"
                android:textSize="13sp" />

            <!-- Mật khẩu cũ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mật khẩu cũ"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/cp_input_old_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Nhập mật khẩu cũ"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Mật khẩu mới -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mật khẩu mới"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/cp_input_new_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Nhập mật khẩu mới"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nhập lại mật khẩu mới -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Nhập lại mật khẩu mới"
                android:textColor="@color/neutral"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/cp_input_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Nhập lại mật khẩu mới"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.7"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mật khẩu mới phải có ít nhất 6 ký tự"
                android:textColor="@color/neutral"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cp_btn_change_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Cập nhật mật khẩu"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

        </LinearLayout>

        <!-- Thành công -->
        <LinearLayout
            android:id="@+id/cp_success_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Đổi mật khẩu thành công!"
                android:textColor="@color/neutral"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp"
                android:alpha="0.8"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Mật khẩu của bạn đã được cập nhật an toàn"
                android:textColor="@color/neutral"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cp_btn_done"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Hoàn tất"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
