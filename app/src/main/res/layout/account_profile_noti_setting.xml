<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFBF4">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="56dp"
        android:paddingBottom="@dimen/home_nav_bar_height"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Card 1: General Settings (Bật/Tắt, Âm thanh, Rung, Lock screen) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 1. Bật/Tắt thông báo -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/lexend"
                        android:text="Bật/Tắt thông báo"
                        android:textColor="#3E4D44"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:id="@+id/switch_noti_enabled_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_noti_enabled_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="#D9D9D9" />

                <!-- 2. Âm thanh -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/lexend"
                        android:text="Âm thanh"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                    <FrameLayout
                        android:id="@+id/switch_sound_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_sound_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="#D9D9D9" />

                <!-- 3. Rung -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/lexend"
                        android:text="Rung"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                    <FrameLayout
                        android:id="@+id/switch_vibrate_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_vibrate_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="#D9D9D9" />

                <!-- 4. Hiển thị lock screen -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/lexend"
                        android:text="Hiển thị lock screen"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                    <FrameLayout
                        android:id="@+id/switch_lock_screen_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_lock_screen_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- Section 2: THÔNG BÀO ĐƠN HÀNG -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/lexend"
                android:text="THÔNG BÀO ĐƠN HÀNG"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Icon -->
                    <FrameLayout
                        android:id="@+id/icon_truck_container"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_rounded_grey">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shipping"
                            app:tint="#8E8E93" />
                    </FrameLayout>

                    <!-- Text labels -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toStartOf="@id/switch_order_status_container"
                        android:layout_toEndOf="@id/icon_truck_container"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Cập nhật trạng thái đơn"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/lexend"
                            android:text="Luôn bật để theo dõi hành trình"
                            android:textColor="#AEAEB2"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Switch -->
                    <FrameLayout
                        android:id="@+id/switch_order_status_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_order_status_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- Section 3: KHUYẾN MÃI & VOUCHER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/lexend"
                android:text="KHUYẾN MÃI &amp; VOUCHER"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Icon -->
                    <FrameLayout
                        android:id="@+id/icon_tag_container"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_rounded_green">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_tag"
                            app:tint="#02542D" />
                    </FrameLayout>

                    <!-- Text labels -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toStartOf="@id/switch_promotion_container"
                        android:layout_toEndOf="@id/icon_tag_container"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Khuyến mãi cá nhân"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Switch -->
                    <FrameLayout
                        android:id="@+id/switch_promotion_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_promotion_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Dropdown selectors container -->
                <LinearLayout
                    android:id="@+id/layout_promotion_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Frequency Dropdown -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="@font/lexend"
                            android:text="Tần suất"
                            android:textColor="#8E8E93"
                            android:textSize="11sp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/home_bg_input"
                            android:paddingHorizontal="12dp">

                            <Spinner
                                android:id="@+id/spinner_frequency"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                android:background="@android:color/transparent"
                                android:spinnerMode="dropdown" />

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_arrow_down"
                                app:tint="#8E8E93" />
                        </RelativeLayout>
                    </LinearLayout>

                    <!-- Time Range Dropdown -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="@font/lexend"
                            android:text="Khung giờ"
                            android:textColor="#8E8E93"
                            android:textSize="11sp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/home_bg_input"
                            android:paddingHorizontal="12dp">

                            <Spinner
                                android:id="@+id/spinner_time_range"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="16dp"
                                android:background="@android:color/transparent"
                                android:spinnerMode="dropdown" />

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_arrow_down"
                                app:tint="#8E8E93" />
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Section 4: TIN NHẮN & HỖ TRỢ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/lexend"
                android:text="TIN NHẮN &amp; HỖ TRỢ"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Row 1: Tin nhắn từ nhân viên -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Icon -->
                    <FrameLayout
                        android:id="@+id/icon_message_container"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_rounded_grey">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chat"
                            app:tint="#8E8E93" />
                    </FrameLayout>

                    <!-- Text labels -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toStartOf="@id/switch_staff_message_container"
                        android:layout_toEndOf="@id/icon_message_container"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Tin nhắn từ nhân viên"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Switch -->
                    <FrameLayout
                        android:id="@+id/switch_staff_message_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_staff_message_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>
            </LinearLayout>

             <!-- Section 5: THÔNG BÀO THỜI TIẾT & DA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/lexend"
                android:text="THÔNG BÀO THỜI TIẾT &amp; DA"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Row: Nhận thông báo đánh giá da hàng ngày -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Icon -->
                    <FrameLayout
                        android:id="@+id/icon_weather_noti_container"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_rounded_green">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_bell" />
                    </FrameLayout>

                    <!-- Text labels -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toStartOf="@id/switch_skin_weather_container"
                        android:layout_toEndOf="@id/icon_weather_noti_container"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Đánh giá da hàng ngày (07:00)"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/lexend"
                            android:text="Nhận lời khuyên da theo thời tiết mỗi sáng"
                            android:textColor="#AEAEB2"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Switch -->
                    <FrameLayout
                        android:id="@+id/switch_skin_weather_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_skin_weather_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- Section 6: CÀI ĐẶT THÔNG BÀO HẾT HẠN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/lexend"
                android:text="THÔNG BÀO HẾT HẠN SẢN PHẨM"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Icon -->
                    <FrameLayout
                        android:id="@+id/icon_expiry_container"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_rounded_green">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_clock"
                            app:tint="#02542D" />
                    </FrameLayout>

                    <!-- Text labels -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toStartOf="@id/switch_expiry_noti_container"
                        android:layout_toEndOf="@id/icon_expiry_container"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend"
                            android:text="Nhận thông báo hết hạn"
                            android:textColor="#3E4D44"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Switch -->
                    <FrameLayout
                        android:id="@+id/switch_expiry_noti_container"
                        android:layout_width="48dp"
                        android:layout_height="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_switch_track_off"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/switch_expiry_noti_thumb"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/bg_white_rounded_corner_border" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Expiry Options Container (Sub-settings under expiry reminder) -->
                <LinearLayout
                    android:id="@+id/layout_expiry_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="12dp"
                        android:background="#D9D9D9" />

                    <!-- Option 1: Nhắc nhở trước 2 tuần -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:text="Nhắc nhở trước 2 tuần"
                            android:textColor="#4A4A4A"
                            android:textSize="13sp" />

                        <FrameLayout
                            android:id="@+id/switch_expiry_week2_container"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switch_expiry_week2_thumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_white_rounded_corner_border" />
                        </FrameLayout>
                    </RelativeLayout>

                    <!-- Option 2: Nhắc nhở trước 1 tuần -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend"
                            android:text="Nhắc nhở trước 1 tuần"
                            android:textColor="#4A4A4A"
                            android:textSize="13sp" />

                        <FrameLayout
                            android:id="@+id/switch_expiry_week1_container"
                            android:layout_width="48dp"
                            android:layout_height="30dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/ic_switch_track_off"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/switch_expiry_week1_thumb"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="2dp"
                                android:src="@drawable/bg_white_rounded_corner_border" />
                        </FrameLayout>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Shared Bottom Navigation Bar -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/home_navapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp" />

    <!-- Top Header (overlay) -->
    <RelativeLayout
        android:id="@+id/rl_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_gradient_header"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="56dp"
            android:ellipsize="end"
            android:fontFamily="@font/be_vietnam_pro"
            android:maxLines="1"
            android:text="Cài đặt thông báo"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/layoutNotification"
            layout="@layout/include_notification_bell"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp" />
    </RelativeLayout>

</RelativeLayout>
