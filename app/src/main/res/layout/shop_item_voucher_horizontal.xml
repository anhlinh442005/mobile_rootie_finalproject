<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_card_container"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card_white">

    <!-- Top Part of the Voucher Card -->
    <RelativeLayout
        android:id="@+id/layout_top_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Icon container -->
        <FrameLayout
            android:id="@+id/iv_voucher_icon_bg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_rounded_green">

            <ImageView
                android:id="@+id/iv_voucher_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_voucher"
                app:tint="#02542D" />
        </FrameLayout>

        <!-- Details block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/iv_voucher_icon_bg"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_voucher_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:text="Giảm 50K Đơn từ 300K"
                android:textColor="#3E4D44"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_voucher_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/lexend"
                android:text="Áp dụng cho tất cả sản phẩm chăm sóc da"
                android:textColor="#555555"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="2" />

            <!-- Expiry date tag -->
            <TextView
                android:id="@+id/tv_voucher_hsd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/lexend"
                android:text="HSD: 31/12/2026"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Dotted horizontal separator line -->
    <View
        android:id="@+id/dashed_line"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_below="@id/layout_top_section"
        android:layout_marginHorizontal="12dp"
        android:background="@drawable/dashed_line_horizontal"
        android:layerType="software" />

    <!-- Bottom Part containing Code and Copy Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/dashed_line"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:id="@+id/layout_code_display"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_voucher_code_container"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_copy"
                app:tint="#666666"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_voucher_code_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend"
                android:text="RT50KDEC"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_voucher_action"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_btn_rounded_solid"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="SAO CHÉP"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </RelativeLayout>
</RelativeLayout>
