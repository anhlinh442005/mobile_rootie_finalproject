<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg_sheet"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/home_sheet_handle"
            android:backgroundTint="@color/neutral" />

        <TextView
            android:id="@+id/home_register_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Đăng ký tài khoản"
            android:fontFamily="@font/be_vietnam_pro"
            android:textColor="@color/neutral"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/home_register_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Tạo tài khoản để bắt đầu hành trình chăm da cùng Rootie"
            android:textAppearance="@style/TextAppearance.Rootie.Content"
            android:textColor="@color/neutral"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/home_register_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <!-- Full Name -->
            <EditText
                android:id="@+id/home_input_fullname"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/home_bg_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Họ và tên"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/primary"
                android:textSize="14sp" />

            <!-- Email or Phone -->
            <EditText
                android:id="@+id/home_input_email_phone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/home_bg_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/primary"
                android:textSize="14sp" />

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                android:layout_marginTop="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/home_input_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:hint="Mật khẩu"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                android:layout_marginTop="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/home_input_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:hint="Nhập lại mật khẩu"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone Number and OTP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="55dp"
                    android:background="@drawable/home_bg_input"
                    android:gravity="center"
                    android:text="+84 ▾"
                    android:textColor="@color/primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/home_input_phone_reg"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="55dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/home_bg_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Số điện thoại"
                    android:inputType="phone"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/primary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/home_btn_send_otp_reg"
                    android:layout_width="wrap_content"
                    android:layout_height="55dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/primary"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Gửi OTP"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ⓘ Mã OTP sẽ được gửi qua SMS đến số điện thoại của bạn."
                android:textColor="#888888"
                android:textSize="11sp" />

            <!-- OTP Input -->
            <EditText
                android:id="@+id/home_input_otp_reg"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/home_bg_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Nhập mã OTP (6 số)"
                android:inputType="number"
                android:maxLength="6"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/primary"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Checkbox Terms -->
            <CheckBox
                android:id="@+id/home_check_terms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:button="@drawable/home_checkbox_custom"
                android:buttonTint="@color/neutral"
                android:paddingStart="8dp"
                android:text="Tôi đã đọc và đồng ý với\nĐiều khoản sử dụng và Chính sách bảo mật"
                android:textColor="@color/neutral"
                android:textSize="12sp"
                android:fontFamily="@font/lexend" />

            <!-- Register Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/home_btn_register"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Xác nhận và đăng ký"
                android:textColor="@color/neutral"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <!-- Or Register With -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Hoặc đăng ký với"
                android:textColor="@color/neutral"
                android:textSize="13sp" />

            <!-- Social Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/home_register_google"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_google" />

                <ImageView
                    android:id="@+id/home_register_facebook"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_facebook" />

            </LinearLayout>

            <!-- Login Link -->
            <TextView
                android:id="@+id/home_login_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="@color/neutral"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
