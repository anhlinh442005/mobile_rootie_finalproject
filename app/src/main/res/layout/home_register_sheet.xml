<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_register_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg_auth_sheet"
    android:clipToPadding="false"
    android:fillViewport="false"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="18dp"
            android:alpha="0.75"
            android:background="@drawable/home_sheet_handle" />

        <TextView
            android:id="@+id/home_register_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:text="Đăng ký tài khoản"
            android:textColor="@color/home_register_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/home_register_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Tạo tài khoản để bắt đầu hành trình chăm da cùng Rootie"
            android:textColor="@color/home_register_text_secondary"
            android:textSize="14sp" />

        <View
            android:layout_width="56dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:background="@drawable/home_indicator_pill"
            android:backgroundTint="@color/primary_light" />

        <LinearLayout
            android:id="@+id/home_register_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Thông tin cá nhân"
                android:textColor="@color/home_register_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/home_input_fullname"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_auth_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Họ và tên"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/home_register_hint"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/home_input_email_phone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_auth_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/home_register_hint"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mật khẩu"
                android:textColor="@color/home_register_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/home_input_password"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/home_bg_auth_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Mật khẩu"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/home_register_hint"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/home_input_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/home_bg_auth_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Nhập lại mật khẩu"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/home_register_hint"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Xác minh số điện thoại"
                android:textColor="@color/home_register_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="50dp"
                    android:background="@drawable/home_bg_auth_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:gravity="center"
                    android:text="+84 ▾"
                    android:textColor="@color/primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/home_input_phone_reg"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_bg_auth_input"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:hint="Số điện thoại"
                    android:inputType="phone"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/primary"
                    android:textColorHint="@color/home_register_hint"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/home_btn_send_otp_reg"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="Gửi OTP"
                    android:textAllCaps="false"
                    android:textColor="@color/neutral"
                    android:textSize="13sp"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/neutral"
                    app:strokeWidth="1dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Mã OTP sẽ được gửi qua SMS đến số điện thoại của bạn."
                android:textColor="@color/home_register_text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/home_input_otp_reg"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/home_bg_auth_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Nhập mã OTP (6 số)"
                android:inputType="number"
                android:maxLength="6"
                android:paddingHorizontal="16dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/home_register_hint"
                android:textSize="14sp"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/home_check_terms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:button="@drawable/home_checkbox_custom"
                android:fontFamily="@font/lexend"
                android:gravity="top"
                android:lineSpacingExtra="2dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:text="Tôi đã đọc và đồng ý với\nĐiều khoản sử dụng và Chính sách bảo mật"
                android:textColor="@color/home_register_text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/home_btn_register"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Xác nhận và đăng ký"
                android:textAllCaps="false"
                android:textColor="@color/neutral"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/nav_icon_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:paddingHorizontal="12dp"
                    android:text="Hoặc đăng ký với"
                    android:textColor="@color/home_register_text_secondary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/nav_icon_color" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/home_bg_register_social">

                    <ImageView
                        android:id="@+id/home_register_google"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_google" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/home_bg_register_social">

                    <ImageView
                        android:id="@+id/home_register_facebook"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_facebook" />

                </FrameLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/home_login_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:textColor="@color/home_register_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
