<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/llTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Thêm sản phẩm"
            android:textColor="#3E4D44"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAvailable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_btn_buy"
                android:backgroundTint="#6E846A"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Sản phẩm khả dụng"
                android:textColor="@color/white"
                android:textSize="13sp" />
                
            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/com_bg_btn_outline"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Tất cả"
                android:textColor="@color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipFace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/com_bg_btn_outline"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Chăm sóc da mặt"
                android:textColor="@color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/com_bg_btn_outline"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Chăm sóc cơ thể"
                android:textColor="@color/black"
                android:textSize="13sp" />
                
            <TextView
                android:id="@+id/chipHair"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/com_bg_btn_outline"
                android:fontFamily="@font/be_vietnam_pro"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Chăm sóc tóc"
                android:textColor="@color/black"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/llAddProductsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>
