<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom depth layer -->
    <item android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="@color/status_level_yellow" />
        </shape>
    </item>
    <!-- Main face lifted for 3D effect -->
    <item android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:centerColor="@color/status_bg_yellow"
                android:endColor="@color/status_level_yellow"
                android:startColor="@color/status_pending_bg"
                android:type="linear" />
            <stroke
                android:width="1.5dp"
                android:color="@color/status_pending_text" />
        </shape>
    </item>
</layer-list>
