<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Rootie" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="android:windowBackground">@color/neutral</item>

        <!-- Font configurations -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Rootie.Headline</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Rootie.Headline</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Rootie.Headline</item>
        
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Rootie.Content</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Rootie.Content</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Rootie.Content</item>

        <item name="textAppearanceLabelLarge">@style/TextAppearance.Rootie.Label</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Rootie.Label</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Rootie.Label</item>
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.Rootie.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/be_vietnam_pro</item>
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
    </style>

    <style name="TextAppearance.Rootie.Content" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/lexend</item>
        <item name="android:fontFamily">@font/lexend</item>
        <item name="android:textColor">@color/content</item>
    </style>

    <style name="TextAppearance.Rootie.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/be_vietnam_pro</item>
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
    </style>

    <style name="TextAppearance.Rootie.Myriad" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/myriadpro</item>
        <item name="android:fontFamily">@font/myriadpro</item>
    </style>

    <style name="Theme.Rootie" parent="Base.Theme.Rootie" />
</resources>